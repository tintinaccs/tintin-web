# TINTIN WEB — variables de ejemplo para procesos privados o despliegues externos.
# La web pública de GitHub Pages NO consume este archivo.
# Nunca coloques secretos en HTML, CSS, js/ ni en archivos versionados.

# Firebase público: los identificadores del SDK web no sustituyen las reglas de seguridad.
FIREBASE_PROJECT_ID=tintin-accesorios

# Configuración exclusiva de funciones o automatizaciones privadas.
# Completar únicamente en el proveedor que ejecute el backend.
EMAIL_SENDER=
EMAIL_PROVIDER_API_KEY=
ORDER_WEBHOOK_SHARED_SECRET=

# Integraciones de pago: siempre del lado del servidor.
PAYMENT_PUBLIC_KEY=
PAYMENT_PRIVATE_KEY=
PAYMENT_WEBHOOK_SECRET=

# Observabilidad privada, cuando se habilite un proveedor externo.
ERROR_REPORTING_DSN=
