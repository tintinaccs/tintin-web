rules_version = '2';

// TINTIN — Reglas de Firebase Storage para la biblioteca multimedia de
// Super Admin. Solo se usa la carpeta media/{mediaId}/... — cualquier otra
// ruta queda cerrada por defecto (el match final del service la niega).
//
// Las imágenes públicas del sitio (logos, banners, colecciones, productos,
// etc.) viven acá como archivos servidos por su download URL pública; el
// control de QUIÉN puede subir/reemplazar/borrar es exclusivamente Super
// Admin, igual que el resto del panel administrativo.
service firebase.storage {
  match /b/{bucket}/o {

    match /media/{mediaId}/{fileName} {
      allow read: if true;

      allow write: if request.auth != null &&
        request.auth.token.email == "tintinaccs@gmail.com" &&
        request.resource.size < 15 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null &&
        request.auth.token.email == "tintinaccs@gmail.com";
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
