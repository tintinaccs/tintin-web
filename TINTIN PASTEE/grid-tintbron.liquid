}

@media (prefers-reduced-motion: reduce) {
  .bcg2-card-{{ ai_id }},
  .bcg2-img-{{ ai_id }},
  .bcg2-quick-{{ ai_id }},
  .bcg2-cta-{{ ai_id }},
  .bcg2-skel-img-{{ ai_id }},
  .bcg2-skel-line-{{ ai_id }},
  .bcg2-lb-panel-{{ ai_id }},
  .bcg2-lb-{{ ai_id }},
  .bcg2-lb-close-{{ ai_id }},
  .bcg2-toast-{{ ai_id }} {
    transition: none !important;
