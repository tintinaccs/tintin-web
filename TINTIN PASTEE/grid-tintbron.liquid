  pointer-events: none;
  transition: opacity 0.3s ease, transform 0.3s var(--spring), background 0.2s ease;
  white-space: nowrap;
  letter-spacing: 0.05em;
}

.bcg2-toast-{{ ai_id }}.is-open {
