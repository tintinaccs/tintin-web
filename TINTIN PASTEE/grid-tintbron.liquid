/* ── TOAST CARRITO ── */
.bcg2-toast-{{ ai_id }} {
  position: fixed;
  bottom: 90px;
  left: 50%;
  transform: translateX(-50%) translateY(12px) scale(0.94);
  z-index: 9500;
  background: linear-gradient(135deg, #f0b3c8, #fcd6e4);
  color: #ffffff;
  font-size: 13px;
  font-weight: 800;
  padding: 13px 24px;
  border-radius: 999px;
  box-shadow: 0 10px 32px rgba(212, 130, 154, 0.4);
