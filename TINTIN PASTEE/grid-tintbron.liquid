<!-- DATOS DE PRODUCTOS -->
<script type="application/json" id="bcg2-data-{{ ai_id }}">
[
{%- if collection != blank and collection.products_count > 0 -%}
{%- paginate collection.products by 250 -%}
{%- assign sorted_by_updated = collection.products | sort: 'updated_at' | reverse -%}
{%- assign now_ts = 'now' | date: '%s' | plus: 0 -%}
{%- assign new_threshold = new_days | times: 86400 -%}
{%- for p in sorted_by_updated -%}
  {%- assign rv = p.selected_or_first_available_variant -%}
  {%- assign cts = p.created_at | date: '%s' | plus: 0 -%}
  {%- assign uts = p.updated_at | date: '%s' | plus: 0 -%}
  {%- assign pts = p.published_at | date: '%s' | plus: 0 -%}
  {%- assign touch_ts = uts -%}
  {%- if cts > touch_ts -%}{%- assign touch_ts = cts -%}{%- endif -%}
  {%- if pts > touch_ts -%}{%- assign touch_ts = pts -%}{%- endif -%}
  {%- assign age = now_ts | minus: touch_ts -%}
  {%- assign is_new = false -%}
  {%- if touch_ts > 0 and age <= new_threshold -%}{%- assign is_new = true -%}{%- endif -%}
  {%- assign has_sale = false -%}
  {%- if rv.compare_at_price > rv.price -%}{%- assign has_sale = true -%}{%- endif -%}
  {%- assign sale_pct = 0 -%}
  {%- if has_sale -%}{%- assign sale_pct = rv.compare_at_price | minus: rv.price | times: 100 | divided_by: rv.compare_at_price -%}{%- endif -%}
  {%- assign is_tracked = false -%}
  {%- if rv.inventory_management != blank -%}{%- assign is_tracked = true -%}{%- endif -%}
  {
    "ord": {{ forloop.index0 | json }},
    "id": {{ p.id | json }},
    "vid": {{ rv.id | json }},
    "t": {{ p.title | json }},
    "u": {{ p.url | json }},
    "p": {{ rv.price | json }},
    "pm": {{ rv.price | money | json }},
    "cp": {{ rv.compare_at_price | json }},
    "cpm": {{ rv.compare_at_price | money | json }},
    "a": {{ rv.available | default: false | json }},
    "qty": {{ rv.inventory_quantity | default: 0 | json }},
    "tracked": {{ is_tracked | json }},
    "policy": {{ rv.inventory_policy | json }},
    "is_new": {{ is_new | json }},
"has_sale": {% if rv.compare_at_price > rv.price %}true{% else %}false{% endif %},
    "cpm": {% if rv.compare_at_price > rv.price %}{{ rv.compare_at_price | money | json }}{% else %}null{% endif %},
    "pm": {{ rv.price | money | json }},
    "cp": {{ rv.compare_at_price | default: 0 | json }},
    "p": {{ rv.price | default: 0 | json }},
    "sale_pct": {{ sale_pct | json }},
    "up": {{ rv.unit_price | default: 0 | json }},
    "upm": {% if rv.unit_price_measurement %}{{ rv.unit_price_measurement.reference_value | json }}{% else %}null{% endif %},
    "upu": {% if rv.unit_price_measurement %}"{{ rv.unit_price_measurement.reference_unit }}"{% else %}null{% endif %},
    "cts": {{ cts | json }},
    "uts": {{ uts | json }},
    "ts": {{ pts | json }},
    "touch_ts": {{ touch_ts | json }},
    "thumbs": [{% for img in p.images limit: 4 %}{{ img | image_url: width: 2000 | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
    "imgs": [{% for img in p.images limit: 4 %}{{ img | image_url: width: 1600 | json }}{% unless forloop.last %},{% endunless %}{% endfor %}]
  }{% unless forloop.last %},{% endunless %}
{%- endfor -%}
{%- endpaginate -%}
{%- endif -%}
]
</script>

<script>
(function() {
  'use strict';

  var AID = '{{ ai_id }}';
  var SECTION_ID = {{ section.id | json }};
  var COLLECTION_URL = {% if collection != blank %}{{ collection.url | json }}{% else %}window.location.pathname{% endif %};
  var COLLECTION_PRODUCTS_COUNT = {% if collection != blank %}{{ collection.products_count | default: 0 }}{% else %}0{% endif %};
  var PAGE_CHUNK = 250;
  var NEW_WINDOW = {{ new_days | default: 15 | times: 86400 }};
  var PER_PAGE_MOBILE = {{ section.settings.per_page_mobile | default: 8 | json }};
  var PER_PAGE_DESKTOP = {{ section.settings.per_page_desktop | default: 9 | json }};
  var MONEY_FMT = {{ shop.money_format | json }};
  var REDUCED_MOTION = !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches);

  var root = document.getElementById('bcg2-root-' + AID);
  var gridEl = document.getElementById('bcg2-grid-' + AID);
  var pagerEl = document.getElementById('bcg2-pager-' + AID);
  var lbEl = document.getElementById('bcg2-lb-' + AID);
  var lbBd = document.getElementById('bcg2-lb-bd-' + AID);
  var lbImg = document.getElementById('bcg2-lb-img-' + AID);
  var lbName = document.getElementById('bcg2-lb-name-' + AID);
  var lbPrice = document.getElementById('bcg2-lb-price-' + AID);
  var lbCounter = document.getElementById('bcg2-lb-counter-' + AID);
  var lbAdd = document.getElementById('bcg2-lb-add-' + AID);
  var lbGoto = document.getElementById('bcg2-lb-goto-' + AID);
  var lbCloseBtn = document.getElementById('bcg2-lb-close-' + AID);
  var lbPrev = document.getElementById('bcg2-lb-prev-' + AID);
  var lbNext = document.getElementById('bcg2-lb-next-' + AID);
  var toastEl = document.getElementById('bcg2-toast-' + AID);
  if (!root || !gridEl || !pagerEl) return;

  var rawProducts = [];
  try {
    var raw = document.getElementById('bcg2-data-' + AID);
    rawProducts = raw ? JSON.parse(raw.textContent || '[]') : [];
  } catch (e) {
    rawProducts = [];
  }

  var urlState;
  try {
    urlState = new URL(window.location.href);
  } catch (e) {
    urlState = null;
  }

  var initialServerPage = urlState ? num(urlState.searchParams.get('page')) || 1 : 1;
  var nowSec = Math.floor(Date.now() / 1000);
  var allRaw = rawProducts.map(function(product, index) {
    return normalizeProduct(product, index, initialServerPage);
  });
  var sortMode = 'default';
  var page = 1;
  var isMobile = window.innerWidth < 768;
  var cols = isMobile ? 2 : 3;
  var perPage = isMobile ? PER_PAGE_MOBILE : PER_PAGE_DESKTOP;
  var lbProduct = null;
  var lbImgIdx = 0;
  var lastFocusedEl = null;
  var renderToken = 0;
  var toastTmr;
  var preloaded = Object.create(null);
  var pagesHydrated = COLLECTION_PRODUCTS_COUNT <= allRaw.length && initialServerPage === 1;
  var hydratePromise = null;
  var io;

  gridEl.setAttribute('data-cols', String(cols));

  function num(v) {
    var n = parseInt(v, 10);
    return isNaN(n) ? 0 : n;
  }

  function fmtMoney(cents) {
    var v = Math.round(num(cents) / 100);
    return String(v).replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' Gs';
  }

  function moneyLabel(product, keyMoney, keyValue) {
    return fmtMoney(product[keyValue]);
  }

  function esc(s) {
    var d = document.createElement('div');
    d.textContent = s == null ? '' : String(s);
    return d.innerHTML;
  }

  function preload(src) {
    if (!src || preloaded[src]) return;
    preloaded[src] = true;
    var img = new Image();
    img.src = src;
  }

  function normalizeProduct(product, index, pageNum) {
    var pageBase = Math.max(0, num(pageNum) - 1) * PAGE_CHUNK;
    var localOrd = typeof product.ord === 'number' ? product.ord : index;
    var touchTs = Math.max(
      num(product.touch_ts),
      num(product.uts),
      num(product.cts),
      num(product.ts)
    );

    var isFresh = !!product.is_new || (touchTs > 0 && (nowSec - touchTs) <= NEW_WINDOW);

    return {
      ord: pageBase + localOrd,
      id: product.id,
      vid: product.vid,
      t: product.t || '',
      u: product.u || '#',
      p: num(product.p),
      pm: product.pm || '',
      cp: num(product.cp),
      cpm: product.cpm || '',
      a: !!product.a,
      qty: num(product.qty),
      tracked: !!product.tracked,
      policy: product.policy || '',
      is_new: isFresh,
      has_sale: !!product.has_sale,
      sale_pct: num(product.sale_pct),
      cts: num(product.cts),
      uts: num(product.uts),
      ts: num(product.ts),
      touch_ts: touchTs,
      thumbs: Array.isArray(product.thumbs) ? product.thumbs : [],
      imgs: Array.isArray(product.imgs) ? product.imgs : [],
      up: num(product.up),
      upm: product.upm != null ? product.upm : null,
      upu: product.upu || null,
      has_sale: product.has_sale,
      cpm: product.cpm,
      pm: product.pm,
      cp: product.cp,
      p: product.p
    };
  }

  function productTouchTs(product) {
    return num(product.touch_ts);
  }

  function productIsFresh(product) {
    return !!product.is_new;
  }

function productGroup(product) {
  if (!product.a) return 1;
  return 0;
}

  function compareAlphabetic(a, b) {
    return (a.t || '').localeCompare(b.t || '', 'es', { sensitivity: 'base' });
  }

  function compareTouchDesc(a, b) {
    return productTouchTs(b) - productTouchTs(a);
  }

  function compareFallback(a, b) {
    return num(a.ord) - num(b.ord);
  }

  function productKey(product) {
    return String(product.id || '') + ':' + String(product.vid || '');
  }

  function mergeProducts(products) {
    var seen = Object.create(null);
    var merged = [];

    products.forEach(function(product) {
      var key = productKey(product);
      if (!key || seen[key]) return;
      seen[key] = true;
      merged.push(product);
    });

    merged.sort(compareFallback);
    return merged;
  }

function compareWithinGroup(a, b, group) {
  if (group === 1) {
    return compareFallback(a, b);
  }

  var af = productIsFresh(a);
  var bf = productIsFresh(b);

  if (af !== bf) return af ? -1 : 1;
  if (af && bf) return compareTouchDesc(a, b) || compareFallback(a, b);

  return compareFallback(a, b);
}

  function getSorted() {
    var arr = allRaw.slice();

    arr.sort(function(a, b) {
      var ga = productGroup(a);
      var gb = productGroup(b);

      if (ga !== gb) return ga - gb;
      return compareWithinGroup(a, b, ga);
    });

    return arr;
  }

  function productGalleryLength(product) {
    var imgsLen = product && Array.isArray(product.imgs) ? product.imgs.length : 0;
    var thumbsLen = product && Array.isArray(product.thumbs) ? product.thumbs.length : 0;
    return Math.max(imgsLen, thumbsLen, 1);
  }

  function productGallerySrc(product, index) {
    if (!product) return '';
    return (product.imgs && product.imgs[index]) || (product.thumbs && product.thumbs[index]) || '';
  }

  function buildSectionPageUrl(pageNum) {
    var nextUrl;

    try {
      nextUrl = new URL(COLLECTION_URL || window.location.pathname, window.location.origin);

      if (urlState) {
        urlState.searchParams.forEach(function(value, key) {
          if (key === 'page' || key === 'section_id') return;
          nextUrl.searchParams.set(key, value);
        });
      }
    } catch (e) {
      return '';
    }

    nextUrl.searchParams.set('page', String(pageNum));
    nextUrl.searchParams.set('section_id', SECTION_ID);
    return nextUrl.toString();
  }

  function extractSectionProducts(markup) {
    if (!markup) return [];

    try {
      var doc = new DOMParser().parseFromString(markup, 'text/html');
      var dataEl = doc.getElementById('bcg2-data-' + AID);
      return dataEl ? JSON.parse(dataEl.textContent || '[]') : [];
    } catch (e) {
      return [];
    }
  }

  function hydrateAllProducts() {
    if (pagesHydrated || hydratePromise || COLLECTION_PRODUCTS_COUNT <= allRaw.length || COLLECTION_PRODUCTS_COUNT <= PAGE_CHUNK) {
      return hydratePromise;
    }

    var totalPages = Math.ceil(COLLECTION_PRODUCTS_COUNT / PAGE_CHUNK);
    var pagesToFetch = [];
    var pageNum;

    for (pageNum = 1; pageNum <= totalPages; pageNum++) {
      if (pageNum === initialServerPage) continue;
      pagesToFetch.push(pageNum);
    }

    if (!pagesToFetch.length) {
      pagesHydrated = true;
      return null;
    }

    hydratePromise = pagesToFetch.reduce(function(chain, currentPage) {
      return chain.then(function(acc) {
        var url = buildSectionPageUrl(currentPage);
        if (!url) return acc;

        return fetch(url, {
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(response) {
          return response.text();
        })
        .then(function(markup) {
          var items = extractSectionProducts(markup).map(function(product, index) {
            return normalizeProduct(product, index, currentPage);
          });

          acc.push(items);
          return acc;
        })
        .catch(function() {
          return acc;
        });
      });
    }, Promise.resolve([]))
    .then(function(chunks) {
      var merged = allRaw.slice();

      chunks.forEach(function(chunk) {
        if (chunk && chunk.length) {
          merged = merged.concat(chunk);
        }
      });

      allRaw = mergeProducts(merged);
      pagesHydrated = true;
      hydratePromise = null;
      renderPage();
      return allRaw;
    })
    .catch(function() {
      hydratePromise = null;
      return allRaw;
    });

    return hydratePromise;
  }

  function skeletons(n) {
    var h = '';
    for (var i = 0; i < n; i++) {
      h += '<div class="bcg2-skel-' + AID + '">'
        + '<div class="bcg2-skel-img-' + AID + '"></div>'
        + '<div class="bcg2-skel-body-' + AID + '">'
        + '<div class="bcg2-skel-line-' + AID + '"></div>'
        + '<div class="bcg2-skel-line-' + AID + ' short"></div>'
        + '</div></div>';
    }
    return h;
  }

  function cardHTML(product, idx) {
    var img0 = (product.thumbs && product.thumbs[0]) || '';
    var img1 = (product.thumbs && product.thumbs[1]) || '';
    var out = !product.a;
    var isFresh = productIsFresh(product);
    var load = idx < (isMobile ? 2 : 4) ? 'eager' : 'lazy';
    var fprio = idx < 4 ? 'high' : 'auto';
    var sizes = isMobile ? '50vw' : '(min-width: 1600px) 18vw, (min-width: 1024px) 22vw, 25vw';

    var badges = '';
    if (out && isFresh) {
      badges += '<div class="bcg2-badge-' + AID + ' bcg2-badge-new-' + AID + '">Nuevo</div>';
    }
    if (out) {
      badges += '<div class="bcg2-badge-' + AID + ' bcg2-badge-out-' + AID + '">Agotado</div>';
    } else {
      if (isFresh) {
        badges += '<div class="bcg2-badge-' + AID + ' bcg2-badge-new-' + AID + '">Nuevo</div>';
      }
      if (product.has_sale) {
        badges += '<div class="bcg2-badge-' + AID + ' bcg2-badge-sale-' + AID + '">-' + esc(product.sale_pct) + '%</div>';
      }
    }

    var priceRow = '';
    if (product.has_sale && product.cpm) {
      priceRow += '<span class="bcg2-price-compare-' + AID + '">' + product.cpm + '</span>';
    }
    if (product.pm) {
      priceRow += '<span class="bcg2-price-' + AID + '">' + product.pm + '</span>';
    } else {
      priceRow += '<span class="bcg2-price-' + AID + '">' + esc(moneyLabel(product, 'pm', 'p')) + '</span>';
    }
    if (product.up && product.upm && product.upu) {
      priceRow += '<span class="bcg2-price-unit-' + AID + '">' + fmtMoney(product.up) + ' / ' + esc(String(product.upm)) + esc(product.upu) + '</span>';
    }

    var quickAdd = '';
    if (!out) {
      quickAdd = '<button type="button" class="bcg2-quick-' + AID + '" data-bcg2-quick data-vid="' + esc(product.vid) + '" data-pid="' + esc(product.id) + '" aria-label="Agregar ' + esc(product.t) + ' al carrito">'
        + '<svg viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>'
        + 'Agregar'
        + '</button>';
    }

    return '<article class="bcg2-card-' + AID + (out ? ' is-out' : '') + '" role="listitem" data-has-second="' + (img1 ? '1' : '0') + '"'
      + ' data-bcg2-card data-pid="' + esc(product.id) + '" data-vid="' + esc(product.vid) + '"'
      + ' data-available="' + (product.a ? '1' : '0') + '"'
      + ' data-idx="' + idx + '"'
      + ' style="transition-delay:' + (idx * 0.028) + 's">'
      + '<a href="' + esc(product.u) + '" class="bcg2-hit-' + AID + '" data-bcg2-link aria-label="Ver ' + esc(product.t) + '"></a>'
      + '<div class="bcg2-thumb-' + AID + '">'
      + (img0
          ? '<img class="bcg2-img-' + AID + '" src="' + esc(img0) + '" alt="' + esc(product.t) + '" width="1200" height="1200" loading="' + load + '" fetchpriority="' + fprio + '" decoding="async" draggable="false">'
          : '<div class="bcg2-noimg-' + AID + '">Sin imagen</div>')
      + (img1
          ? '<img class="bcg2-img2-' + AID + '" src="" data-src="' + esc(img1) + '" alt="" width="1200" height="1200" loading="lazy" decoding="async" draggable="false">'
          : '')
      + (badges ? '<div class="bcg2-badges-' + AID + '">' + badges + '</div>' : '')
      + quickAdd
      + '</div>'
      + '<div class="bcg2-info-' + AID + '">'
      + '<div class="bcg2-name-' + AID + '">' + esc(product.t) + '</div>'
      + '<div class="bcg2-meta-' + AID + '"><div class="bcg2-price-row-' + AID + '">' + priceRow + '</div></div>'
      + '<div class="bcg2-cta-' + AID + '">Ver producto &rsaquo;</div>'
      + '</div>'
      + '</article>';
  }

  function pagesVisible(cur, total) {
    if (total <= 7) {
      return Array.from({ length: total }, function(_, i) { return i + 1; });
    }
    if (cur <= 4) return [1, 2, 3, 4, 5, '…', total];
    if (cur >= total - 3) return [1, '…', total - 4, total - 3, total - 2, total - 1, total];
    return [1, '…', cur - 1, cur, cur + 1, '…', total];
  }

  function renderPager(total) {
    if (total <= 1) {
      pagerEl.innerHTML = '';
      return;
    }

    var pages = pagesVisible(page, total);
    var h = '';
    h += '<button class="bcg2-page-btn-' + AID + '" ' + (page === 1 ? 'disabled' : 'data-bcg2-page="' + (page - 1) + '"') + ' aria-label="Anterior" type="button">&#8249;</button>';
    pages.forEach(function(v) {
      if (v === '…') {
        h += '<span class="bcg2-page-sep-' + AID + '">…</span>';
      } else {
        h += '<button class="bcg2-page-btn-' + AID + (v === page ? ' is-active' : '') + '" data-bcg2-page="' + v + '" aria-label="Página ' + v + '"' + (v === page ? ' aria-current="page"' : '') + ' type="button">' + v + '</button>';
      }
    });
    h += '<button class="bcg2-page-btn-' + AID + '" ' + (page === total ? 'disabled' : 'data-bcg2-page="' + (page + 1) + '"') + ' aria-label="Siguiente" type="button">&#8250;</button>';
    pagerEl.innerHTML = h;
  }

  function observeCards() {
    var cards = gridEl.querySelectorAll('[data-bcg2-card]');

    if (!('IntersectionObserver' in window) || REDUCED_MOTION) {
      cards.forEach(function(card) {
        card.classList.add('is-visible');
      });
      return;
    }

    if (io) io.disconnect();
    io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;

        entry.target.classList.add('is-visible');

        var img2 = entry.target.querySelector('.bcg2-img2-' + AID);
        if (img2 && img2.getAttribute('data-src')) {
          preload(img2.getAttribute('data-src'));
        }

        io.unobserve(entry.target);
      });
    }, {
      threshold: 0.08,
      rootMargin: '0px 0px -24px 0px'
    });

    cards.forEach(function(card) {
      io.observe(card);
    });
  }

  function primeImages(items) {
    items.slice(0, isMobile ? 4 : 6).forEach(function(product) {
      if (product.thumbs && product.thumbs[0]) preload(product.thumbs[0]);
      if (product.thumbs && product.thumbs[1]) preload(product.thumbs[1]);
    });
  }

  function renderPage() {
    var token = ++renderToken;
    var sorted = getSorted();
    var total = Math.max(1, Math.ceil(sorted.length / perPage));
    if (page > total) page = 1;

    var start = (page - 1) * perPage;
    var items = sorted.slice(start, start + perPage);

    gridEl.classList.add('is-fading');
    gridEl.setAttribute('aria-busy', 'true');
    gridEl.innerHTML = skeletons(perPage);

    window.setTimeout(function() {
      if (token !== renderToken) return;

      if (!items.length) {
        gridEl.innerHTML = '<div class="bcg2-empty-' + AID + '">No hay productos disponibles.</div>';
      } else {
        gridEl.innerHTML = items.map(function(product, i) {
          return cardHTML(product, i);
        }).join('');
        attachCardEvents(items);
        observeCards();
        primeImages(items);
      }

      gridEl.classList.remove('is-fading');
      gridEl.setAttribute('aria-busy', 'false');
      renderPager(total);
    }, REDUCED_MOTION ? 0 : 160);
  }

  function attachCardEvents(items) {
    gridEl.querySelectorAll('[data-bcg2-quick]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        quickAddToCart(btn.getAttribute('data-vid'), btn, null);
      });
    });

    gridEl.querySelectorAll('[data-bcg2-card]').forEach(function(card) {
      var product = items[num(card.getAttribute('data-idx'))] || null;

      card.addEventListener('mouseenter', function() {
        var img2 = card.querySelector('.bcg2-img2-' + AID);
        if (img2 && img2.getAttribute('data-src')) {
          img2.src = img2.getAttribute('data-src');
          img2.removeAttribute('data-src');
        }
      }, { once: true });

      var link = card.querySelector('[data-bcg2-link]');
      var thumb = card.querySelector('.bcg2-thumb-' + AID);
      var info = card.querySelector('.bcg2-info-' + AID);

function goToProduct(e) {
  if (e.target.closest('[data-bcg2-quick]')) return;

  if (!link || !link.href) return;

  e.preventDefault();
  e.stopPropagation();
  window.location.href = link.href;
}

      if (link) link.addEventListener('click', goToProduct);
      if (thumb) thumb.addEventListener('click', goToProduct);
      if (info) info.addEventListener('click', goToProduct);
    });
  }

  function parseJSONResponse(response) {
    return response.text().then(function(text) {
      var data = {};

      try {
        data = text ? JSON.parse(text) : {};
      } catch (e) {
        data = {};
      }

      if (!response.ok) {
        var message = data && data.description ? data.description : 'No se pudo completar la acción.';
        throw new Error(message);
      }

      return data;
    });
  }

  function quickAddToCart(vid, btn, callback) {
    if (!vid || !btn) return;

    btn.classList.add('is-adding');
    btn.disabled = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({
        items: [{ id: num(vid), quantity: 1 }]
      })
    })
    .then(parseJSONResponse)
    .then(function() {
      btn.classList.remove('is-adding');
      btn.classList.add('is-done');

      window.setTimeout(function() {
        btn.classList.remove('is-done');
        btn.disabled = false;
      }, 1800);

      showToast('Agregado al carrito', false);
      return fetch('/cart.js', {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      }).then(parseJSONResponse);
    })
    .then(function(cart) {
      document.dispatchEvent(new CustomEvent('bronn:cart:updated', {
        bubbles: true,
        detail: {
          count: cart.item_count,
          cart: cart,
          _bronn: true
        }
      }));

      document.dispatchEvent(new CustomEvent('cart:updated', {
        bubbles: true,
        detail: { cart: cart }
      }));

      if (typeof callback === 'function') callback();
    })
    .catch(function(err) {
      btn.classList.remove('is-adding');
      btn.classList.remove('is-done');
      btn.disabled = false;
      showToast(err && err.message ? err.message : 'No se pudo agregar al carrito', true);
    });
  }

  function showToast(message, isError) {
    if (!toastEl) return;

    toastEl.textContent = message || 'Agregado al carrito';
    toastEl.classList.toggle('is-error', !!isError);
    toastEl.classList.add('is-open');

    clearTimeout(toastTmr);
    toastTmr = window.setTimeout(function() {
      toastEl.classList.remove('is-open');
      toastEl.classList.remove('is-error');
    }, isError ? 2600 : 2000);
  }

  function lbOpen(product, triggerEl) {
    if (!lbEl || !lbImg) return;

    lbProduct = product;
    lbImgIdx = 0;
    lastFocusedEl = triggerEl || document.activeElement;

    if (lbName) lbName.textContent = product.t;
    if (lbPrice) lbPrice.textContent = moneyLabel(product, 'pm', 'p');
    if (lbAdd) {
      lbAdd.href = product.u;
      lbAdd.setAttribute('aria-label', 'Ver ' + product.t);
    }
    if (lbGoto) {
      lbGoto.classList.remove('is-done', 'is-adding');
      lbGoto.disabled = !product.vid || !product.a;
      lbGoto.setAttribute('aria-label', product.vid && product.a ? 'Agregar ' + product.t + ' al carrito' : 'Producto agotado');
    }

    lbLoadImg();
    lbUpdateNav();

    lbEl.classList.add('is-open');
    lbEl.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    if (lbCloseBtn && typeof lbCloseBtn.focus === 'function') {
      window.setTimeout(function() {
        lbCloseBtn.focus();
      }, 20);
    }
  }

  function closeLb() {
    if (!lbEl) return;

    lbEl.classList.remove('is-open');
    lbEl.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';

    if (lastFocusedEl && typeof lastFocusedEl.focus === 'function') {
      window.setTimeout(function() {
        try {
          lastFocusedEl.focus({ preventScroll: true });
        } catch (e) {
          lastFocusedEl.focus();
        }
      }, 0);
    }
  }

  function lbLoadImg() {
    if (!lbProduct || !lbImg) return;

    var src = productGallerySrc(lbProduct, lbImgIdx);
    if (!src) return;

    lbImg.style.opacity = '0.42';
    lbImg.alt = lbProduct.t || '';

    var img = new Image();
    img.onload = function() {
      lbImg.src = src;
      lbImg.style.opacity = '1';
    };
    img.src = src;

    if (lbCounter) {
      var total = productGalleryLength(lbProduct);
      lbCounter.textContent = (lbImgIdx + 1) + ' / ' + total;
    }

    if (productGallerySrc(lbProduct, lbImgIdx + 1)) preload(productGallerySrc(lbProduct, lbImgIdx + 1));
    if (productGallerySrc(lbProduct, lbImgIdx - 1)) preload(productGallerySrc(lbProduct, lbImgIdx - 1));
  }

  function lbUpdateNav() {
    if (!lbProduct) return;

    var total = productGalleryLength(lbProduct);
    if (lbPrev) lbPrev.classList.toggle('is-disabled', lbImgIdx === 0);
    if (lbNext) lbNext.classList.toggle('is-disabled', lbImgIdx >= total - 1);
  }

  if (lbCloseBtn) lbCloseBtn.addEventListener('click', closeLb);
  if (lbBd) lbBd.addEventListener('click', closeLb);
  if (lbPrev) {
    lbPrev.addEventListener('click', function(e) {
      e.stopPropagation();
      if (lbImgIdx > 0) {
        lbImgIdx--;
        lbLoadImg();
        lbUpdateNav();
      }
    });
  }
  if (lbNext) {
    lbNext.addEventListener('click', function(e) {
      e.stopPropagation();
      if (lbProduct && lbImgIdx < productGalleryLength(lbProduct) - 1) {
        lbImgIdx++;
        lbLoadImg();
        lbUpdateNav();
      }
    });
  }

  if (lbGoto) {
    lbGoto.addEventListener('click', function() {
      if (!lbProduct) return;
      quickAddToCart(lbProduct.vid, lbGoto, closeLb);
    });
  }

  var swipeX0 = null;
  if (lbEl) {
    lbEl.addEventListener('touchstart', function(e) {
      if (!e.touches || !e.touches.length) return;
      swipeX0 = e.touches[0].clientX;
    }, { passive: true });

    lbEl.addEventListener('touchend', function(e) {
      if (swipeX0 === null || !e.changedTouches || !e.changedTouches.length) return;

      var dx = e.changedTouches[0].clientX - swipeX0;
      swipeX0 = null;

      if (!lbProduct || Math.abs(dx) < 50) return;

      if (dx < 0 && lbImgIdx < productGalleryLength(lbProduct) - 1) {
        lbImgIdx++;
        lbLoadImg();
        lbUpdateNav();
      }

      if (dx > 0 && lbImgIdx > 0) {
        lbImgIdx--;
        lbLoadImg();
        lbUpdateNav();
      }
    }, { passive: true });
  }

  document.addEventListener('keydown', function(e) {
    if (!lbEl || !lbEl.classList.contains('is-open')) return;

    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft' && lbImgIdx > 0) {
      lbImgIdx--;
      lbLoadImg();
      lbUpdateNav();
    }
    if (e.key === 'ArrowRight' && lbProduct && lbImgIdx < productGalleryLength(lbProduct) - 1) {
      lbImgIdx++;
      lbLoadImg();
      lbUpdateNav();
    }
  });

  pagerEl.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-bcg2-page]');
    if (!btn) return;

    var nextPage = num(btn.getAttribute('data-bcg2-page'));
    if (!nextPage || nextPage === page) return;

    page = nextPage;
    renderPage();

    if (root && typeof root.scrollIntoView === 'function') {
      root.scrollIntoView({
        behavior: REDUCED_MOTION ? 'auto' : 'smooth',
        block: 'start'
      });
    }
  });

  document.addEventListener('bronn:collection:sort', function() {
    sortMode = 'default';
    page = 1;
    renderPage();
  });

  document.addEventListener('bronn:collection:columns', function(e) {
    var requested = e && e.detail ? num(e.detail.cols || e.detail.columns || e.detail.value) : 0;

    cols = requested || (isMobile ? 2 : 3);
    if (isMobile && cols > 2) cols = 2;

    gridEl.setAttribute('data-cols', String(cols));
  });

  var resizeTmr;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTmr);
    resizeTmr = window.setTimeout(function() {
      var nextMobile = window.innerWidth < 768;
      if (nextMobile === isMobile) return;

      isMobile = nextMobile;
      perPage = isMobile ? PER_PAGE_MOBILE : PER_PAGE_DESKTOP;
      cols = isMobile ? 2 : 3;
      page = 1;

      gridEl.setAttribute('data-cols', String(cols));

      if (!isMobile) closeLb();
      renderPage();
    }, 180);
  }, { passive: true });

  renderPage();
  hydrateAllProducts();
})();
</script>

