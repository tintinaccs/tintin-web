{% comment %}
  ════════════════════════════════════════════════
  TINTIN ACCESORIOS — Grid de Colección
  Available-first · Badges · Quick add · Toggle columnas
  Apple polish · Updated-first · Out of stock last
  ════════════════════════════════════════════════
{% endcomment %}

{% assign ai_id = section.id | replace: '_', '' | downcase | slice: 0, 8 %}
{% assign mw = section.settings.max_width | default: 1400 %}
{% assign new_days = section.settings.new_days | default: 15 %}

{% style %}
.bcg2-{{ ai_id }},
.bcg2-lb-{{ ai_id }},
.bcg2-toast-{{ ai_id }} {
  --gold: #d4829a;
  --gold-strong: #f0b3c8;
  --gold-soft: rgba(212, 130, 154, 0.14);
  --gold-dim: #e8a0b8;
  --bg: {{ section.settings.background_color }};
  --card: rgba(255, 242, 247, 0.88);
  --card-top: rgba(255, 248, 251, 0.96);
  --card-bottom: rgba(252, 232, 240, 0.96);
  --border: rgba(212, 130, 154, 0.18);
  --border-strong: rgba(212, 130, 154, 0.28);
  --border-gold: rgba(212, 130, 154, 0.38);
  --text: #c9566e;
  --text-sub: #c9566e;
  --text-soft: rgba(240, 179, 200, 0.72);
  --success: #30d158;
  --danger: #ff453a;
  --shadow-card: 0 18px 50px rgba(212, 130, 154, 0.18);
  --shadow-hover: 0 28px 70px rgba(212, 130, 154, 0.28);
  --surface-glow: radial-gradient(circle at top center, rgba(212, 130, 154, 0.22), transparent 38%);
  --ease: cubic-bezier(.25, .46, .45, .94);
  --spring: cubic-bezier(.34, 1.56, .64, 1);
  --radius: {{ section.settings.card_radius }}px;
  --font-sans: "SF Pro Display", "Avenir Next", "Helvetica Neue", "Segoe UI", sans-serif;
  --font-serif: "Cormorant Garamond", Georgia, serif;
}

.bcg2-{{ ai_id }} {
  background: transparent !important;
  padding: clamp(32px, 4vw, 56px) clamp(16px, 4vw, 48px) clamp(48px, 6vw, 80px);
  position: relative;
  overflow: clip;
  font-family: var(--font-sans);
}

.bcg2-{{ ai_id }}::before,
.bcg2-{{ ai_id }}::after {
  content: "";
  position: absolute;
  pointer-events: none;
}

.bcg2-{{ ai_id }}::before {
  display: none;
}

.bcg2-{{ ai_id }}::after {
  display: none;
}

.bcg2-inner-{{ ai_id }} {
  max-width: {{ mw }}px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.shopify-section:has(.bcg2-{{ ai_id }}) {
  background: transparent !important;
}

/* ── GRID ── */
.bcg2-grid-{{ ai_id }} {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: clamp(12px, 1.6vw, 18px);
  transition: opacity 0.2s ease;
  align-content: start;
}

.bcg2-grid-{{ ai_id }}.is-fading {
  opacity: 0;
}

.bcg2-grid-{{ ai_id }}[data-cols="2"] {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.bcg2-grid-{{ ai_id }}[data-cols="4"] {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.bcg2-grid-{{ ai_id }}[data-cols="5"] {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

@media (min-width: 768px) {
  .bcg2-grid-{{ ai_id }}[data-cols="2"] {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .bcg2-grid-{{ ai_id }}[data-cols="3"] {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .bcg2-grid-{{ ai_id }}[data-cols="4"] {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .bcg2-grid-{{ ai_id }}[data-cols="5"] {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .bcg2-grid-{{ ai_id }}:not([data-cols]) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

/* ── CARD ── */
.bcg2-card-{{ ai_id }} {
  position: relative;
  display: flex;
  flex-direction: column;
  min-width: 0;
  background:
    linear-gradient(180deg, var(--card-top), var(--card-bottom));
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  color: var(--text);
  box-shadow: var(--shadow-card);
  transition:
    border-color 0.3s ease,
    box-shadow 0.3s ease,
    transform 0.3s ease,
    opacity 0.55s var(--ease);
  opacity: 0;
  transform: translateY(18px) scale(0.985);
  will-change: transform, opacity;
  -webkit-tap-highlight-color: transparent;
  isolation: isolate;
}

.bcg2-card-{{ ai_id }}::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.55), transparent 28%),
    radial-gradient(circle at top, rgba(212, 130, 154, 0.2), transparent 42%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.bcg2-card-{{ ai_id }}.is-visible {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.bcg2-card-{{ ai_id }}.is-out {
  cursor: default;
}

.bcg2-hit-{{ ai_id }} {
  position: absolute;
  inset: 0;
  z-index: 2;
  border-radius: inherit;
  text-decoration: none;
}

.bcg2-hit-{{ ai_id }}:focus-visible {
  outline: 2px solid rgba(212, 130, 154, 0.85);
  outline-offset: -2px;
}

.bcg2-card-{{ ai_id }}:focus-within,
.bcg2-card-{{ ai_id }}:hover {
  border-color: var(--border-gold);
}

@media (min-width: 768px) {
  .bcg2-card-{{ ai_id }}:hover {
    box-shadow: var(--shadow-hover), 0 0 0 1px rgba(212, 130, 154, 0.22);
    transform: translateY(-6px) scale(1.003);
  }

  .bcg2-card-{{ ai_id }}:hover::after {
    opacity: 1;
  }
}

/* ── IMAGEN ── */
.bcg2-thumb-{{ ai_id }} {
  position: relative;
  width: 100%;
  aspect-ratio: {{ section.settings.card_aspect }};
  overflow: hidden;
  background: #fff0f4;
  flex-shrink: 0;
  cursor: pointer;
  z-index: 1;
}

.bcg2-img-{{ ai_id }},
.bcg2-img2-{{ ai_id }} {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  backface-visibility: hidden;
  background: #fff0f4;
}

.bcg2-img-{{ ai_id }} {
  transition: transform 0.75s var(--ease), opacity 0.3s ease, filter 0.3s ease;
  will-change: transform;
  opacity: 1;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  transform: translateZ(0);
}

.bcg2-img2-{{ ai_id }} {
  opacity: 0;
  transition: opacity 0.45s ease;
  pointer-events: none;
}

@media (min-width: 768px) {
  .bcg2-card-{{ ai_id }}:hover .bcg2-img-{{ ai_id }} {
    transform: translateZ(0) scale(1.055);
  }

  .bcg2-card-{{ ai_id }}[data-has-second="1"]:hover .bcg2-img-{{ ai_id }} {
    opacity: 0;
    transform: none;
  }
  .bcg2-card-{{ ai_id }}[data-has-second="1"]:hover .bcg2-img2-{{ ai_id }} {
    opacity: 1;
  }
}

.bcg2-noimg-{{ ai_id }} {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(212, 130, 154, 0.7);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

/* ── BADGES ── */
.bcg2-badges-{{ ai_id }} {
  position: absolute;
  top: 12px;
  left: 12px;
  z-index: 6;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.bcg2-badge-{{ ai_id }} {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 22px;
  padding: 5px 10px;
  border-radius: 999px;
  font-size: 8px;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  line-height: 1;
  white-space: nowrap;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid transparent;
}

.bcg2-badge-new-{{ ai_id }} {
  background: linear-gradient(135deg, #f0b3c8, #fcd6e4);
  color: #ffffff;
  box-shadow: 0 8px 20px rgba(212, 130, 154, 0.32);
}

.bcg2-badge-sale-{{ ai_id }} {
  background: rgba(255, 150, 160, 0.88);
  color: #ffffff;
  box-shadow: 0 8px 18px rgba(255, 130, 150, 0.22);
}

.bcg2-badge-out-{{ ai_id }} {
  background: rgba(240, 179, 200, 0.65);
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.38);
}

/* ── OUT OF STOCK ── */
.bcg2-card-{{ ai_id }}.is-out .bcg2-img-{{ ai_id }} {
  filter: grayscale(60%) brightness(0.78);
  opacity: 0.62;
}

.bcg2-card-{{ ai_id }}.is-out .bcg2-price-row-{{ ai_id }} {
  background-color: #f2a2be;
  box-shadow: none;
}

/* ── QUICK ADD HOVER (desktop) ── */
.bcg2-quick-{{ ai_id }} {
  position: absolute;
  bottom: 12px;
  left: 12px;
  right: 12px;
  z-index: 7;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 42px;
  padding: 11px 16px;
  background: rgba(240, 179, 200, 0.55);
  border: 1px solid rgba(212, 130, 154, 0.52);
  border-radius: 14px;
  backdrop-filter: blur(16px) saturate(140%);
  -webkit-backdrop-filter: blur(16px) saturate(140%);
  color: #ffffff;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  cursor: pointer;
  opacity: 0;
  transform: translateY(10px);
  transition:
    opacity 0.28s ease,
    transform 0.28s var(--spring),
    background 0.2s ease,
    border-color 0.2s ease,
    color 0.2s ease;
  pointer-events: none;
  font-family: inherit;
}

@media (min-width: 768px) {
  .bcg2-card-{{ ai_id }}:hover .bcg2-quick-{{ ai_id }},
  .bcg2-card-{{ ai_id }}:focus-within .bcg2-quick-{{ ai_id }} {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
}

.bcg2-quick-{{ ai_id }}:hover,
.bcg2-quick-{{ ai_id }}:focus-visible {
  background: rgba(212, 130, 154, 0.72);
  border-color: var(--gold);
}

.bcg2-quick-{{ ai_id }}:focus-visible {
  outline: none;
}

.bcg2-quick-{{ ai_id }}.is-adding,
.bcg2-lb-goto-{{ ai_id }}.is-adding {
  color: var(--success);
  border-color: rgba(48, 209, 88, 0.4);
  opacity: 0.82;
}

.bcg2-quick-{{ ai_id }}.is-done {
  color: var(--success);
  border-color: rgba(48, 209, 88, 0.4);
  background: rgba(48, 209, 88, 0.09);
}

.bcg2-quick-{{ ai_id }} svg {
  width: 13px;
  height: 13px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
}

/* ── INFO ── */
.bcg2-info-{{ ai_id }} {
  position: relative;
  z-index: 1;
  padding: clamp(12px, 1.6vw, 17px);
  display: flex;
  flex-direction: column;
  gap: 5px;
  flex: 1;
  min-width: 0;
  cursor: pointer;
  align-items: center;
  text-align: center;
}

.bcg2-name-{{ ai_id }} {
  font-size: clamp(15px, 1.3vw, 18px);
  font-weight: 650;
  font-family: var(--font-sans);
  letter-spacing: 0.02em;
  color: #c9566e;
  line-height: 1.38;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: color 0.2s ease;
}

@media (min-width: 768px) {
  .bcg2-card-{{ ai_id }}:hover .bcg2-name-{{ ai_id }} {
    color: rgba(240, 179, 200, 0.92);
  }
}

.bcg2-meta-{{ ai_id }} {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.bcg2-price-row-{{ ai_id }} {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin: 6px auto 2px auto;
  min-width: 0;
  background-color: #EA7EA3;
  padding: 6px 16px;
  border-radius: 999px;
  box-shadow: 0 4px 12px rgba(234, 126, 163, 0.25);
}

.bcg2-price-{{ ai_id }} {
  font-family: "Harrisson", var(--font-sans);
  font-size: clamp(15px, 1.3vw, 19px);
  font-weight: 600;
  color: #ffffff !important;
  letter-spacing: 0.02em;
  line-height: 1;
}

.bcg2-price-compare-{{ ai_id }} {
  font-size: clamp(10px, 0.85vw, 12px);
  color: rgba(255, 255, 255, 0.75);
  text-decoration: line-through;
  font-weight: 400;
  font-family: "Harrisson", var(--font-sans);
}

.bcg2-price-unit-{{ ai_id }} {
  font-size: clamp(9px, 0.8vw, 11px);
  color: var(--text-soft);
  font-weight: 500;
  letter-spacing: 0.04em;
  width: 100%;
  margin-top: 1px;
}

.bcg2-cta-{{ ai_id }} {
  display: none;
}

@media (min-width: 768px) {
  .bcg2-cta-{{ ai_id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-strong);
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .bcg2-card-{{ ai_id }}:hover .bcg2-cta-{{ ai_id }},
  .bcg2-card-{{ ai_id }}:focus-within .bcg2-cta-{{ ai_id }} {
    opacity: 0.82;
    transform: translateY(0);
  }
}

/* ── SKELETON ── */
.bcg2-skel-{{ ai_id }} {
  background: linear-gradient(180deg, var(--card-top), var(--card-bottom));
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.bcg2-skel-img-{{ ai_id }},
.bcg2-skel-line-{{ ai_id }} {
  background:
    linear-gradient(90deg, rgba(255, 235, 243, 1) 18%, rgba(240, 210, 225, 1) 50%, rgba(255, 235, 243, 1) 82%);
  background-size: 200% 100%;
  animation: bcg2-shim-{{ ai_id }} 1.25s ease infinite;
}

.bcg2-skel-img-{{ ai_id }} {
  width: 100%;
  aspect-ratio: {{ section.settings.card_aspect }};
}

.bcg2-skel-body-{{ ai_id }} {
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.bcg2-skel-line-{{ ai_id }} {
  height: 10px;
  border-radius: 999px;
}

.bcg2-skel-line-{{ ai_id }}.short {
  width: 40%;
}

@keyframes bcg2-shim-{{ ai_id }} {
  0% {
    background-position: 200% 0;
  }

  100% {
    background-position: -200% 0;
  }
}

/* ── EMPTY ── */
.bcg2-empty-{{ ai_id }} {
  grid-column: 1 / -1;
  padding: 84px 20px;
  text-align: center;
  color: var(--text-sub);
  font-size: 14px;
  border: 1px solid var(--border);
  border-radius: calc(var(--radius) + 8px);
  background: linear-gradient(180deg, rgba(255, 240, 245, 0.8), rgba(252, 230, 238, 0.84));
}

/* ── PAGINACIÓN ── */
.bcg2-pager-wrap-{{ ai_id }} {
  display: flex;
  justify-content: center;
  margin-top: clamp(36px, 5vw, 60px);
}

.bcg2-pager-{{ ai_id }} {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
  padding: 8px;
  border-radius: 999px;
  background: rgba(212, 130, 154, 0.08);
  border: 1px solid rgba(212, 130, 154, 0.22);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.bcg2-page-btn-{{ ai_id }} {
  min-width: 38px;
  height: 38px;
  padding: 0 12px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--text-sub);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.05em;
  border-radius: 999px;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.18s ease;
  font-family: inherit;
}

.bcg2-page-btn-{{ ai_id }}:hover:not(:disabled),
.bcg2-page-btn-{{ ai_id }}:focus-visible:not(:disabled) {
  border-color: var(--border-gold);
  color: var(--text);
  background: var(--gold-soft);
  outline: none;
}

.bcg2-page-btn-{{ ai_id }}.is-active {
  border-color: rgba(212, 130, 154, 0.5);
  background: rgba(212, 130, 154, 0.18);
  color: var(--gold-strong);
}

.bcg2-page-btn-{{ ai_id }}:disabled {
  opacity: 0.22;
  cursor: default;
}

.bcg2-page-sep-{{ ai_id }} {
  color: var(--text-sub);
  font-size: 13px;
  padding: 0 2px;
  user-select: none;
}

/* ── LIGHTBOX MOBILE ── */
.bcg2-lb-{{ ai_id }} {
  position: fixed;
  inset: 0;
  z-index: 9000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.28s ease, visibility 0.28s ease;
}

.bcg2-lb-{{ ai_id }}.is-open {
  opacity: 1;
  visibility: visible;
}

.bcg2-lb-bd-{{ ai_id }} {
  position: absolute;
  inset: 0;
  background: rgba(240, 179, 200, 0.55);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.bcg2-lb-panel-{{ ai_id }} {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 90%;
  background:
    radial-gradient(circle at top, rgba(212, 130, 154, 0.22), transparent 34%),
    linear-gradient(180deg, #fff8fb, #fce8f0);
  border-top-left-radius: 28px;
  border-top-right-radius: 28px;
  border-top: 1px solid rgba(212, 130, 154, 0.42);
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(.32, .72, 0, 1);
  overflow: hidden;
  box-shadow: 0 -18px 70px rgba(212, 130, 154, 0.22);
}

.bcg2-lb-{{ ai_id }}.is-open .bcg2-lb-panel-{{ ai_id }} {
  transform: translateY(0);
}

.bcg2-lb-handle-{{ ai_id }} {
  display: flex;
  justify-content: center;
  padding: 12px 0 8px;
  flex-shrink: 0;
}

.bcg2-lb-handle-{{ ai_id }} span {
  width: 36px;
  height: 4px;
  border-radius: 999px;
  background: rgba(212, 130, 154, 0.38);
}

.bcg2-lb-imgwrap-{{ ai_id }} {
  flex: 1;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px;
}

.bcg2-lb-img-{{ ai_id }} {
  position: absolute;
  inset: 12px;
  width: calc(100% - 24px);
  height: calc(100% - 24px);
  object-fit: contain;
  display: block;
  pointer-events: none;
  user-select: none;
  transition: opacity 0.2s ease;
}

.bcg2-lb-arr-{{ ai_id }} {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(212, 130, 154, 0.22);
  border: 1px solid rgba(212, 130, 154, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.2s ease;
}

.bcg2-lb-arr-{{ ai_id }}.is-disabled {
  opacity: 0.2;
  pointer-events: none;
}

.bcg2-lb-arr-{{ ai_id }}:active {
  background: rgba(212, 130, 154, 0.42);
  transform: translateY(-50%) scale(0.92);
}

.bcg2-lb-arr-prev-{{ ai_id }} {
  left: 12px;
}

.bcg2-lb-arr-next-{{ ai_id }} {
  right: 12px;
}

.bcg2-lb-arr-{{ ai_id }} svg {
  width: 18px;
  height: 18px;
  stroke: #f0b3c8;
  fill: none;
  stroke-width: 2.2;
  stroke-linecap: round;
  stroke-linejoin: round;
  pointer-events: none;
}

.bcg2-lb-footer-{{ ai_id }} {
  flex-shrink: 0;
  padding: 15px 18px calc(env(safe-area-inset-bottom) + 18px);
  background: rgba(255, 240, 245, 0.96);
  border-top: 1px solid rgba(212, 130, 154, 0.22);
  display: flex;
  flex-direction: column;
  gap: 12px;
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

.bcg2-lb-info-{{ ai_id }} {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.bcg2-lb-name-{{ ai_id }} {
  font-size: 13px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #f0b3c8;
  line-height: 1.3;
}

.bcg2-lb-price-{{ ai_id }} {
