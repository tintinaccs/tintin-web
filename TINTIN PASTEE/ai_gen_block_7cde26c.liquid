{% assign g = block.id | replace: '_', '' | downcase %}

{% style %}
/* ══════════════════════════════════════════════════════
   TINTIN — CARRUSEL DE COLECCIONES PREMIUM
   RESPONSIVE FULL FIX
   Adaptado desde móvil pequeño hasta pantallas 4K
══════════════════════════════════════════════════════ */

.tcc-{{ g }},
.tcc-{{ g }} + *,
.tcc-{{ g }}::after,
.tcc-{{ g }}::before,
.tcc-{{ g }} *::after,
.tcc-{{ g }} *::before,
.shopify-section:has(.tcc-{{ g }}),
.shopify-section:has(.tcc-{{ g }})::after,
.shopify-section:has(.tcc-{{ g }})::before,
.shopify-section:has(.tcc-{{ g }}) + .shopify-section,
body:has(.tcc-{{ g }}) .shopify-section:has(.tcc-{{ g }}) {
.shopify-section:has(.tcc-{{ g }}) + .shopify-section{
  border-top:none !important;
}

.shopify-section:has(.tcc-{{ g }}) + .shopify-section::after,
.shopify-section:has(.tcc-{{ g }}) + .shopify-section::before{
  content:none !important;
  display:none !important;
}
  border: none !important;
  outline: none !important;
  box-shadow: none !important;
  border-top: none !important;
  border-bottom: none !important;
  background-image: none !important;
}

.tcc-{{ g }} {
  border: none !important;
border-top: none !important;
border-bottom: none !important;
background-image: none !important;
box-shadow: none !important;
  --acc:      {{ block.settings.accent_color }};
  --acc2:     {{ block.settings.accent2_color }};
  --bg:       {{ block.settings.section_bg }};
  --card-bg:  {{ block.settings.card_bg }};
  --txt:      {{ block.settings.text_color }};
  --txt2:     {{ block.settings.text_color2 }};
  --btn-bg:   {{ block.settings.btn_bg }};
  --btn-txt:  {{ block.settings.btn_txt }};
  --nav-bg:   {{ block.settings.nav_bg }};
  --nav-txt:  {{ block.settings.nav_txt }};
  --dot:      {{ block.settings.dot_color }};
  --r:        {{ block.settings.card_radius }}px;
  --gap:      {{ block.settings.card_gap }}px;
  --ease:     cubic-bezier(.4,0,.2,1);

  --section-pad-y: {{ block.settings.section_padding }}px;
  --section-pad-x: {{ block.settings.side_padding }}px;
  --card-pad: {{ block.settings.card_padding }}px;
  --title-size: {{ block.settings.title_size }}px;
  --subtitle-size: {{ block.settings.subtitle_size }}px;
  --card-title-size: {{ block.settings.card_title_size }}px;
  --card-desc-size: {{ block.settings.card_desc_size }}px;
  --nav-size: {{ block.settings.nav_size_desktop }}px;
  --nav-icon-size: {{ block.settings.nav_icon_size_desktop }}px;
  --nav-offset: clamp(6px, 1vw, 14px);
  --hover-lift: {{ block.settings.hover_lift }}px;
  --shadow-soft: {{ block.settings.shadow_strength | times: 2 }}px;
  --shadow-strong: {{ block.settings.shadow_strength | times: 3 }}px;

  display: block;
  width: 100vw;
  max-width: 100vw;
  margin-inline: calc(50% - 50vw);
  background: var(--bg);
  padding: var(--section-pad-y) 0;
  overflow-x: hidden;
  overflow-y: visible;

  opacity: 0;
  transform: translateY(20px);
  transition: opacity .6s ease, transform .6s ease;
}
.tcc-{{ g }}.ttc-vis-{{ g }} {
  opacity: 1;
  transform: translateY(0);
}

/* ── Contenedor ── */
.tcc-inner-{{ g }} {
  width: 100%;
  max-width: none;
  margin: 0;
  padding-inline: var(--section-pad-x);
}

@media (max-width: 749px) {
  .tcc-{{ g }} {
    --gap: {{ block.settings.card_gap_mobile }}px;
    --section-pad-y: {{ block.settings.section_padding_mobile }}px;
    --section-pad-x: {{ block.settings.side_padding_mobile }}px;
    --card-pad: {{ block.settings.card_padding_mobile }}px;
    --title-size: {{ block.settings.title_size_mobile }}px;
    --subtitle-size: {{ block.settings.subtitle_size_mobile }}px;
    --card-title-size: {{ block.settings.card_title_size_mobile }}px;
    --card-desc-size: {{ block.settings.card_desc_size_mobile }}px;
    --nav-size: {{ block.settings.nav_size_mobile }}px;
    --nav-icon-size: {{ block.settings.nav_icon_size_mobile }}px;
  }

  .tcc-hide-mobile-{{ g }} {
    display: none !important;
  }
}

@media (min-width: 750px) {
  .tcc-hide-desktop-{{ g }} {
    display: none !important;
  }
}

/* ── Header ── */
.tcc-head-{{ g }} {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  text-align: {{ block.settings.heading_align }};
  gap: clamp(10px, 1.2vw, 16px);
  margin: 0 0 clamp(24px, 3vw, {{ block.settings.head_margin | plus: 10 }}px);
  padding: 0;
}

.tcc-title-{{ g }} {
  display: block;
  width: 100%;
  max-width: none;
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 900;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--acc);
  margin: 0;
  line-height: 1.0;
  text-wrap: balance;
  text-shadow: none;
}

.tcc-subtitle-{{ g }} {
  display: block;
  width: 100%;
  max-width: none;
  font-size: clamp(10px, 1vw, 12px);
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--txt2);
  opacity: 0.85;
  margin: 0;
  line-height: 1.5;
  text-wrap: balance;
  text-shadow: none;
}

/* ── Wrapper del carrusel ── */
.tcc-wrap-{{ g }} {
  position: relative;
  overflow: hidden;
  touch-action: pan-y;
  width: 100%;
  padding-inline: calc(var(--nav-size) + clamp(8px, 1vw, 16px));
  padding-block: clamp(2px, .6vw, 6px);
}

@media (max-width: 749px) {
  .tcc-wrap-{{ g }} {
    padding-inline: calc(var(--nav-size) + 2px);
  }
}

@media (max-width: 479px) {
  .tcc-wrap-{{ g }} {
    padding-inline: calc(var(--nav-size) + 1px);
  }

}

/* ── Track ── */
.tcc-track-outer-{{ g }} {
  overflow: hidden;
  border-radius: max(4px, calc(var(--r) * 0.45));
  width: 100%;
  touch-action: pan-y pinch-zoom;
  overscroll-behavior-x: contain;
  cursor: grab;
  user-select: none;
  -webkit-user-select: none;
}

.tcc-track-outer-{{ g }}.is-dragging {
  cursor: grabbing;
}

.tcc-track-{{ g }} {
  display: flex;
  gap: var(--gap);
  will-change: transform;
  transform: translate3d(0,0,0);
  transition: transform .38s cubic-bezier(.22,.61,.36,1);
  backface-visibility: hidden;
  align-items: stretch;
}

/* ── Slide ── */
.tcc-slide-{{ g }} {
  flex: 0 0 calc((100% - var(--gap) * ({{ block.settings.slides_mobile }} - 1)) / {{ block.settings.slides_mobile }});
  min-width: 0;
  display: flex;
  backface-visibility: hidden;
  opacity: 1;
  transform: translateY(0);
  transition:
    opacity .55s var(--ease),
    transform .55s var(--ease);
}

.tcc-slide-{{ g }}.tcc-visible-{{ g }} {
  opacity: 1;
  transform: translateY(0);
}

@media (min-width: 750px) {
  .tcc-slide-{{ g }} {
    flex: 0 0 calc((100% - var(--gap) * ({{ block.settings.slides_tablet }} - 1)) / {{ block.settings.slides_tablet }});
  }
}

@media (min-width: 990px) {
  .tcc-slide-{{ g }} {
    flex: 0 0 calc((100% - var(--gap) * ({{ block.settings.slides_desktop }} - 1)) / {{ block.settings.slides_desktop }});
  }
}

/* Ajuste real para pantallas ultra anchas */
@media (min-width: 1800px) {
  .tcc-inner-{{ g }} {
    padding-inline: clamp(24px, 2vw, 56px);
  }
}
/* ══════════════════════════════════════════════════════
   BASE TARJETAS
══════════════════════════════════════════════════════ */

.tcc-card-{{ g }} {
  position: relative;
  width: 100%;
  border-radius: var(--r);
  overflow: hidden;
  background: var(--card-bg);
  border: 1px solid rgba(255,255,255,.55);
  height: 100%;
  display: flex;
  flex-direction: column;
  cursor: pointer;
  text-decoration: none;
  color: inherit;
  transform: translateZ(0);
  backface-visibility: hidden;
  isolation: isolate;
  box-shadow: none;
  transition:
    transform .28s var(--ease),
    border-color .28s var(--ease);
}

@media (hover:hover) and (pointer:fine) {
  .tcc-card-{{ g }}:hover {
    transform: translateY(calc(var(--hover-lift) * -1));
    box-shadow: none;
    border-color: rgba(255,255,255,.82);
  }
}

/* ── Imagen wrapper ── */
.tcc-img-wrap-{{ g }} {
  position: relative;
  width: 100%;
  padding-bottom: {{ block.settings.img_ratio }}%;
  overflow: hidden;
  flex-shrink: 0;
  background: #f7f2f4;
}

.tcc-img-{{ g }} {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .42s var(--ease);
  display: block;
  transform: translateZ(0);
  pointer-events: none;
  user-select: none;
  -webkit-user-drag: none;
}

@media (hover:hover) and (pointer:fine) {
  .tcc-card-{{ g }}:hover .tcc-img-{{ g }} {
    transform: scale(1.07);
  }
}

/* shimmer */
.tcc-img-wrap-{{ g }}::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    transparent 30%,
    rgba(255,255,255,.35) 50%,
    transparent 70%
  );
  transform: translateX(-120%);
  transition: none;
  pointer-events: none;
}

@media (hover:hover) and (pointer:fine) {
  .tcc-card-{{ g }}:hover .tcc-img-wrap-{{ g }}::after {
    transform: translateX(120%);
    transition: transform .6s ease;
  }
}

/* Placeholder */
.tcc-placeholder-{{ g }} {
  position: absolute;
  inset: 0;
  background: #f4ecf0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tcc-placeholder-{{ g }} svg {
  width: 50%;
  height: 50%;
  opacity: .2;
}

/* ══════════════════════════════════════════════════════
   ESTILOS DE TARJETA
══════════════════════════════════════════════════════ */

{% if block.settings.card_style == 'classic' %}
.tcc-body-{{ g }} {
  padding: clamp(14px, 1.5vw, var(--card-pad));
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: {{ block.settings.card_text_align }};
}

{% elsif block.settings.card_style == 'overlay' %}
.tcc-img-wrap-{{ g }} {
  padding-bottom: {{ block.settings.img_ratio | plus: 24 }}%;
}
.tcc-img-wrap-{{ g }}::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0,0,0,.72) 0%,
    rgba(0,0,0,.18) 55%,
    transparent 100%
  );
  z-index: 1;
  transition: opacity .3s ease;
}
@media (hover:hover) and (pointer:fine) {
  .tcc-card-{{ g }}:hover .tcc-img-wrap-{{ g }}::before {
    opacity: .85;
  }
}
.tcc-body-{{ g }} {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  z-index: 2;
  padding: clamp(14px, 1.5vw, {{ block.settings.card_padding }}px);
  text-align: {{ block.settings.card_text_align }};
  transform: translateY(6px);
  transition: transform .32s var(--ease);
}
@media (hover:hover) and (pointer:fine) {
  .tcc-card-{{ g }}:hover .tcc-body-{{ g }} {
    transform: translateY(0);
  }
}
.tcc-card-name-{{ g }},
.tcc-card-desc-{{ g }} {
  color: #fff !important;
  text-shadow: 0 1px 4px rgba(0,0,0,.4);
}

{% elsif block.settings.card_style == 'horizontal' %}
.tcc-card-{{ g }} {
  flex-direction: row;
  align-items: stretch;
}

.tcc-img-wrap-{{ g }} {
  width: clamp(38%, 42%, 45%);
  padding-bottom: 0;
  flex-shrink: 0;
  align-self: stretch;
}

.tcc-img-{{ g }} {
  position: absolute;
  inset: 0;
  height: 100%;
  min-height: 190px;
}

.tcc-body-{{ g }} {
  padding: clamp(14px, 1.5vw, {{ block.settings.card_padding }}px);
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: {{ block.settings.card_text_align }};
}

@media (max-width: 749px) {
  .tcc-card-{{ g }} {
    flex-direction: column;
  }
  .tcc-img-wrap-{{ g }} {
    width: 100%;
    padding-bottom: {{ block.settings.img_ratio }}%;
  }
  .tcc-img-{{ g }} {
    min-height: 0;
  }
}

{% elsif block.settings.card_style == 'float' %}
.tcc-img-wrap-{{ g }} {
  padding-bottom: {{ block.settings.img_ratio | plus: 20 }}%;
}
.tcc-body-{{ g }} {
  position: absolute;
  bottom: 12px; left: 12px; right: 12px;
  z-index: 2;
  background: rgba(255,255,255,.88);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: calc(var(--r) - 4px);
  padding: 10px 14px;
  text-align: {{ block.settings.card_text_align }};
  transform: translateY(4px);
  transition: transform .3s var(--ease), opacity .3s ease;
  opacity: .92;
}
@media (hover:hover) and (pointer:fine) {
  .tcc-card-{{ g }}:hover .tcc-body-{{ g }} {
    transform: translateY(0);
    opacity: 1;
  }
}
.tcc-card-desc-{{ g }},
.tcc-card-btn-{{ g }} { display: none !important; }
{% endif %}

/* ── Contenido de la tarjeta ── */
.tcc-card-name-{{ g }} {
  font-size: clamp(11px, 1.1vw, var(--card-title-size));
  font-weight: 800;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  color: var(--acc);
  margin: 0 0 8px;
  line-height: 1.25;
  overflow-wrap: break-word;
  word-break: normal;
  hyphens: none;
  white-space: normal;
  width: 100%;
  text-shadow: none;
  min-height: 2.6em;
  display: flex;
  align-items: center;
  justify-content: {% if block.settings.card_text_align == 'center' %}center{% elsif block.settings.card_text_align == 'right' %}flex-end{% else %}flex-start{% endif %};
  text-align: {{ block.settings.card_text_align }};
}

.tcc-card-name-{{ g }} span {
  display: inline-block;
  max-width: 100%;
}

.tcc-card-desc-{{ g }} {
  font-size: clamp(11px, .88vw, var(--card-desc-size));
  font-weight: 600;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  color: var(--txt2);
  margin: 0 0 14px;
  line-height: 1.5;
  flex: 1;
  overflow-wrap: anywhere;
  display: none;
}

.tcc-card-btn-{{ g }} {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40px;
  padding: 9px 20px;
  background: var(--btn-bg);
  color: var(--btn-txt);
  border-radius: {{ block.settings.btn_radius }}px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-decoration: none;
  transition: background .22s ease, transform .22s ease;
  align-self: {% if block.settings.card_text_align == 'center' %}center{% elsif block.settings.card_text_align == 'right' %}flex-end{% else %}flex-start{% endif %};
  max-width: 100%;
  text-align: center;
  box-shadow: none;
}

@media (hover:hover) and (pointer:fine) {
  .tcc-card-btn-{{ g }}:hover {
    background: var(--acc2);
    transform: scale(1.04);
  }
}

/* Tilt */
.tcc-card-{{ g }}.tcc-tilt-{{ g }} {
  transform-style: preserve-3d;
  perspective: 800px;
}

/* ══════════════════════════════════════════════════════
   NAVEGACIÓN — Flechas
══════════════════════════════════════════════════════ */
{% if block.settings.show_arrows %}
.tcc-arrow-{{ g }} {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  width: var(--nav-size);
  height: var(--nav-size);
  border-radius: 999px;
  background: var(--nav-bg);
  color: var(--nav-txt);
  border: 1px solid rgba(255,255,255,.58);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  box-shadow: none;
  transition: background .22s ease, transform .22s ease, opacity .22s ease, color .22s ease;
  opacity: 1;
  pointer-events: auto;
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
}

@media (hover:hover) and (pointer:fine) {
  .tcc-arrow-{{ g }}:hover {
    transform: translateY(-50%) scale(1.04);
  }
}

.tcc-arrow-{{ g }}:disabled {
  opacity: 1;
  cursor: pointer;
  pointer-events: auto;
}

.tcc-arrow-prev-{{ g }} { left: var(--nav-offset); }
.tcc-arrow-next-{{ g }} { right: var(--nav-offset); }

.tcc-arrow-{{ g }} svg {
  width: var(--nav-icon-size);
  height: var(--nav-icon-size);
}
{% endif %}

/* ══════════════════════════════════════════════════════
   NAV inferior
══════════════════════════════════════════════════════ */
.tcc-nav-{{ g }} {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: clamp(10px, 1.5vw, 16px);
  margin-top: clamp(14px, 2vw, {{ block.settings.nav_margin }}px);
  flex-wrap: wrap;

  border: none !important;
  border-top: none !important;
  border-bottom: none !important;
  box-shadow: none !important;
  outline: none !important;
  background-image: none !important;
}

.tcc-nav-{{ g }}::after,
.tcc-nav-{{ g }}::before,
.tcc-dots-{{ g }}::after,
.tcc-dots-{{ g }}::before,
.tcc-{{ g }}::after,
.tcc-{{ g }}::before,
.shopify-section:has(.tcc-{{ g }})::after,
.shopify-section:has(.tcc-{{ g }})::before,
.shopify-section:has(.tcc-{{ g }}) + .shopify-section::after,
.shopify-section:has(.tcc-{{ g }}) + .shopify-section::before{
  content:none !important;
  display:none !important;
  border:none !important;
  background:none !important;
  box-shadow:none !important;
}

.tcc-inner-{{ g }} {
  border-bottom: none !important;
}

{% if block.settings.show_dots %}
.tcc-dots-{{ g }} {
  display: flex;
  gap: 8px;
  align-items: center;
  max-width: min(100%, 90vw);
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding: 2px;
}
.tcc-dots-{{ g }}::-webkit-scrollbar {
  display: none;
}
.tcc-dot-{{ g }} {
  flex: 0 0 auto;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--dot);
  opacity: .3;
  border: none;
  cursor: pointer;
  padding: 0;
  transition: opacity .25s ease, transform .25s ease, width .25s ease, border-radius .25s ease;
}
.tcc-dot-{{ g }}.active {
  opacity: 1;
  width: 24px;
  border-radius: 4px;
  background: var(--acc);
}
{% endif %}

{% if block.settings.show_progress %}
.tcc-progress-wrap-{{ g }} {
  width: clamp(110px, 14vw, 160px);
  height: 3px;
  background: {{ block.settings.dot_color }}44;
  border-radius: 2px;
  overflow: hidden;
}
.tcc-progress-bar-{{ g }} {
  height: 100%;
  background: var(--acc);
  border-radius: 2px;
  transition: width .52s var(--ease);
}
{% endif %}

{% if block.settings.show_counter %}
.tcc-counter-{{ g }} {
  font-size: 13px;
  color: var(--txt2);
  font-weight: 500;
  min-width: 48px;
  text-align: center;
}
.tcc-counter-{{ g }} span {
  color: var(--acc);
  font-weight: 700;
}
{% endif %}

/* ══════════════════════════════════════════════════════
   AUTOPLAY
══════════════════════════════════════════════════════ */
{% if block.settings.enable_autoplay and block.settings.show_autoplay_bar %}
.tcc-autoplay-bar-wrap-{{ g }} {
display:none !important;
  width: 100%;
  height: 2px;
  background: {{ block.settings.dot_color }}33;
  border-radius: 1px;
  overflow: hidden;
  margin-top: 12px;
}
.tcc-autoplay-bar-{{ g }} {
  height: 100%;
  width: 0%;
  background: var(--acc);
  border-radius: 1px;
  transition: width linear;
}
{% endif %}

/* ── Reveal reversible ── */
.tcc-{{ g }}.tcc-anim-ready-{{ g }} .tcc-head-{{ g }},
.tcc-{{ g }}.tcc-anim-ready-{{ g }} .tcc-wrap-{{ g }},
.tcc-{{ g }}.tcc-anim-ready-{{ g }} .tcc-nav-{{ g }} {
  opacity: 0;
  filter: blur(8px);
  transform: translate3d(0, 56px, 0) scale(0.98);
  transition:
    opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.85s cubic-bezier(0.22, 1, 0.36, 1),
    filter 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform, filter;
}

.tcc-{{ g }}.tcc-anim-ready-{{ g }}.tcc-anim-top-{{ g }} .tcc-head-{{ g }},
.tcc-{{ g }}.tcc-anim-ready-{{ g }}.tcc-anim-top-{{ g }} .tcc-wrap-{{ g }},
.tcc-{{ g }}.tcc-anim-ready-{{ g }}.tcc-anim-top-{{ g }} .tcc-nav-{{ g }} {
  transform: translate3d(0, -56px, 0) scale(0.98);
}

.tcc-{{ g }}.tcc-anim-ready-{{ g }}.tcc-anim-vis-{{ g }} .tcc-head-{{ g }},
.tcc-{{ g }}.tcc-anim-ready-{{ g }}.tcc-anim-vis-{{ g }} .tcc-wrap-{{ g }},
.tcc-{{ g }}.tcc-anim-ready-{{ g }}.tcc-anim-vis-{{ g }} .tcc-nav-{{ g }} {
  opacity: 1;
  filter: blur(0);
  transform: translate3d(0, 0, 0) scale(1);
}

.tcc-{{ g }}.tcc-anim-ready-{{ g }}.tcc-anim-vis-{{ g }} .tcc-wrap-{{ g }} {
  transition-delay: 0.1s;
}

.tcc-{{ g }}.tcc-anim-ready-{{ g }}.tcc-anim-vis-{{ g }} .tcc-nav-{{ g }} {
  transition-delay: 0.2s;
}

/* ── Accesibilidad / motion reduction ── */
@media (prefers-reduced-motion: reduce) {
  .tcc-track-{{ g }},
  .tcc-slide-{{ g }},
  .tcc-card-{{ g }},
  .tcc-img-{{ g }},
  .tcc-body-{{ g }},
  .tcc-progress-bar-{{ g }},
  .tcc-autoplay-bar-{{ g }} {
    transition: none !important;
    animation: none !important;
  }
}

/* ── Seguridad extra para móviles muy estrechos ── */
@media (max-width: 359px) {
  .tcc-inner-{{ g }} {
    padding-inline: 10px;
  }

  .tcc-wrap-{{ g }} {
    padding-inline: calc(var(--nav-size) + 2px);
  }

  .tcc-card-btn-{{ g }} {
    width: 100%;
  }
}
{% endstyle %}
{%- comment -%} ══ HTML ══ {%- endcomment -%}
{%- liquid
  assign tcc_render = true
  case request.page_type
    when 'index'
      assign tcc_render = block.settings.show_on_home
    when 'product'
      assign tcc_render = block.settings.show_on_product
    when 'collection'
      assign tcc_render = block.settings.show_on_collection
    else
      assign tcc_render = block.settings.show_on_other_pages
  endcase
-%}
{% if tcc_render %}
<div class="tcc-{{ g }} tcc-ready{% unless block.settings.show_on_mobile %} tcc-hide-mobile-{{ g }}{% endunless %}{% unless block.settings.show_on_desktop %} tcc-hide-desktop-{{ g }}{% endunless %}" id="tcc-root-{{ g }}" {{ block.shopify_attributes }} style="border:none!important;border-bottom:none!important;box-shadow:none!important;outline:none!important;">
  <div class="tcc-inner-{{ g }}">

    {%- if block.settings.title != blank or block.settings.subtitle != blank -%}
    <div class="tcc-head-{{ g }}">
      {%- if block.settings.title != blank -%}
        <h2 class="tcc-title-{{ g }}">{{ block.settings.title }}</h2>
      {%- endif -%}
      {%- if block.settings.subtitle != blank -%}
        <p class="tcc-subtitle-{{ g }}">{{ block.settings.subtitle }}</p>
      {%- endif -%}
    </div>
    {%- endif -%}

    <div class="tcc-wrap-{{ g }}">

      {%- if block.settings.show_arrows -%}
      <button class="tcc-arrow-{{ g }} tcc-arrow-prev-{{ g }}" aria-label="Anterior" id="tcc-prev-{{ g }}">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="tcc-arrow-{{ g }} tcc-arrow-next-{{ g }}" aria-label="Siguiente" id="tcc-next-{{ g }}">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
      </button>
      {%- endif -%}

      <div class="tcc-track-outer-{{ g }}" tabindex="0" aria-label="Carrusel de colecciones">
        <div class="tcc-track-{{ g }}" id="tcc-track-{{ g }}">

          {%- assign src_cols = block.settings.collections -%}
          {%- if src_cols != blank -%}
            {%- for col in src_cols -%}
              <div class="tcc-slide-{{ g }}" data-index="{{ forloop.index0 }}">
                <a href="{{ col.url }}" class="tcc-card-{{ g }}" aria-label="{{ col.title | escape }}">
                  <div class="tcc-img-wrap-{{ g }}">
                    {%- if col.featured_image -%}
                      <img
                        srcset="
                          {{ col.featured_image | image_url: width: 220 }} 220w,
                          {{ col.featured_image | image_url: width: 280 }} 280w,
                          {{ col.featured_image | image_url: width: 360 }} 360w,
                          {{ col.featured_image | image_url: width: 480 }} 480w,
                          {{ col.featured_image | image_url: width: 720 }} 720w
                        "
                        sizes="(max-width: 479px) 280px, (max-width: 749px) 320px, (max-width: 989px) calc((100vw - 150px) / {{ block.settings.slides_tablet }}), calc((100vw - 220px) / {{ block.settings.slides_desktop }})"
                        src="{{ col.featured_image | image_url: width: 360 }}"
                        alt="{{ col.featured_image.alt | default: col.title | escape }}"
                        class="tcc-img-{{ g }}"
                        loading="lazy"
                        decoding="async"
                        draggable="false"
                        width="360"
                        height="{{ 360 | times: block.settings.img_ratio | divided_by: 100 | round }}"
                      >
                    {%- else -%}
                      <div class="tcc-placeholder-{{ g }}">{{ 'collection-1' | placeholder_svg_tag }}</div>
                    {%- endif -%}
                  </div>
                  <div class="tcc-body-{{ g }}">
                    <h3 class="tcc-card-name-{{ g }}"><span class="tcc-fit-text-{{ g }}">{{ col.title }}</span></h3>
                    {%- comment -%}Descripción deshabilitada{%- endcomment -%}
                    {%- if block.settings.show_btn -%}
                      <span class="tcc-card-btn-{{ g }}">{{ block.settings.btn_text }}</span>
                    {%- endif -%}
                  </div>
                </a>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <div class="tcc-slide-{{ g }}" data-index="{{ forloop.index0 }}">
                <a href="#" class="tcc-card-{{ g }}">
                  <div class="tcc-img-wrap-{{ g }}">
                    <div class="tcc-placeholder-{{ g }}">{{ 'collection-1' | placeholder_svg_tag }}</div>
                  </div>
                  <div class="tcc-body-{{ g }}">
                    <h3 class="tcc-card-name-{{ g }}"><span class="tcc-fit-text-{{ g }}">Colección {{ i }}</span></h3>
                    {%- comment -%}Descripción deshabilitada{%- endcomment -%}
                    {%- if block.settings.show_btn -%}
                      <span class="tcc-card-btn-{{ g }}">{{ block.settings.btn_text }}</span>
                    {%- endif -%}
                  </div>
                </a>
              </div>
            {%- endfor -%}
          {%- endif -%}

        </div>
      </div>
    </div>

    <div class="tcc-nav-{{ g }}">
      {%- if block.settings.show_counter -%}
        <div class="tcc-counter-{{ g }}" id="tcc-counter-{{ g }}"><span>1</span> / <span id="tcc-total-{{ g }}">1</span></div>
      {%- endif -%}
      {%- if block.settings.show_dots -%}
        <div class="tcc-dots-{{ g }}" id="tcc-dots-{{ g }}"></div>
      {%- endif -%}
      {%- if block.settings.show_progress -%}
        <div class="tcc-progress-wrap-{{ g }}">
          <div class="tcc-progress-bar-{{ g }}" id="tcc-progress-{{ g }}"></div>
        </div>
      {%- endif -%}
    </div>

  

  </div>
</div>

<script>
(function(){
'use strict';

const G             = {{ g | json }};
const GAP           = {{ block.settings.card_gap }};
const AUTOPLAY      = {{ block.settings.enable_autoplay | json }};
const AUTOPLAY_SPD  = {{ block.settings.autoplay_speed | times: 1000 }};
const SHOW_DOTS     = {{ block.settings.show_dots | json }};
const SHOW_PROGRESS = {{ block.settings.show_progress | json }};
const SHOW_COUNTER  = {{ block.settings.show_counter | json }};
const SHOW_ABAR     = {{ block.settings.show_autoplay_bar | json }};
const ENABLE_TILT   = {{ block.settings.enable_tilt | json }};
const SLIDES_MOB    = Number({{ block.settings.slides_mobile | json }});
const SLIDES_TAB    = Number({{ block.settings.slides_tablet | json }});
const SLIDES_DSK    = Number({{ block.settings.slides_desktop | json }});

const root     = document.getElementById('tcc-root-' + G);
if (!root) return;

const viewport = root.querySelector('.tcc-track-outer-' + G);
const track    = document.getElementById('tcc-track-' + G);
const prevBtn  = document.getElementById('tcc-prev-' + G);
const nextBtn  = document.getElementById('tcc-next-' + G);
const dotsEl   = document.getElementById('tcc-dots-' + G);
const progEl   = document.getElementById('tcc-progress-' + G);
const ctrEl    = document.getElementById('tcc-counter-' + G);
const totEl    = document.getElementById('tcc-total-' + G);
const abarEl   = document.getElementById('tcc-abar-' + G);


if (!viewport || !track) return;

const CLONE_CLASS = 'tcc-clone-' + G;

let originalSlides = Array.from(track.querySelectorAll('.tcc-slide-' + G));
if (!originalSlides.length) return;

let slides = [];
let perView = 1;
let cloneCount = 0;
let current = 0;
let autoTimer = null;
let resizeTimer = null;
let wheelTimer = null;
let wheelDelta = 0;
let isDragging = false;
let dragMoved = false;
let startX = 0;
let startY = 0;
let startTranslate = 0;
let currentTranslate = 0;
let lastPointerId = null;


function getPerView(){
  const w = window.innerWidth;
  if (w >= 990) return Math.max(1, SLIDES_DSK);
  if (w >= 750) return Math.max(1, SLIDES_TAB);
  return Math.max(1, SLIDES_MOB);
}

function getGapPx(){
  const styles = getComputedStyle(track);
  const gap = parseFloat(styles.columnGap || styles.gap || GAP || 0);
  return Number.isFinite(gap) ? gap : GAP;
}

function itemSize(){
  const first = slides[0];
  if (!first) return 0;
  const rect = first.getBoundingClientRect();
  return Math.round(rect.width + getGapPx());
}

function trackXFor(index){
  return -(index * itemSize());
}

function setTrackX(x, animate){
  track.style.willChange = 'transform';
  track.style.transition = animate === false ? 'none' : '';
  track.style.transform = 'translate3d(' + x + 'px,0,0)';

  if (animate === false){
    requestAnimationFrame(function(){
      track.style.willChange = 'auto';
    });
  }
}

function realIndex(index){
  const total = originalSlides.length;
  let i = (index - cloneCount) % total;
  if (i < 0) i += total;
  return i;
}

function updateUI(){
  const total = originalSlides.length;
  const real = realIndex(current);

  if (SHOW_COUNTER && ctrEl){
    const spans = ctrEl.querySelectorAll('span');
    if (spans[0]) spans[0].textContent = real + 1;
    if (spans[1]) spans[1].textContent = total;
  }

  if (SHOW_PROGRESS && progEl){
    progEl.style.width = (((real + 1) / total) * 100) + '%';
  }

  if (SHOW_DOTS && dotsEl){
    dotsEl.querySelectorAll('.tcc-dot-' + G).forEach((dot, i) => {
      dot.classList.toggle('active', i === real);
    });
  }
}

function buildDots(){
  if (!dotsEl) return;
  dotsEl.innerHTML = '';

  originalSlides.forEach((_, i) => {
    const d = document.createElement('button');
    d.type = 'button';
    d.className = 'tcc-dot-' + G + (i === 0 ? ' active' : '');
    d.setAttribute('aria-label', 'Ir a la colección ' + (i + 1));
    d.addEventListener('click', function(){
      goTo(cloneCount + i);
    });
    dotsEl.appendChild(d);
  });
}

function buildInfinite(){
  const prevReal = slides.length ? realIndex(current) : 0;
  track.querySelectorAll('.' + CLONE_CLASS).forEach(function(el){ el.remove(); });

  originalSlides = Array.from(
    track.querySelectorAll('.tcc-slide-' + G + ':not(.' + CLONE_CLASS + ')')
  );

  const total = originalSlides.length;
  if (!total) return;

  perView = getPerView();
  cloneCount = total > 1 ? Math.min(perView, total) : 0;

  if (total > 1 && cloneCount > 0){
    const prependFrag = document.createDocumentFragment();
    const appendFrag  = document.createDocumentFragment();

    /* Clones al FINAL: copias de los primeros slides */
    for (let i = 0; i < cloneCount; i++){
      const clone = originalSlides[i % total].cloneNode(true);
      clone.classList.add(CLONE_CLASS);
      clone.setAttribute('aria-hidden', 'true');
      clone.querySelectorAll('a, button, input, select, textarea').forEach(function(focusable){
        focusable.setAttribute('tabindex', '-1');
      });
      appendFrag.appendChild(clone);
    }

    /* Clones al INICIO: copias de los últimos slides (en orden) */
    for (let i = cloneCount - 1; i >= 0; i--){
      const clone = originalSlides[(total - 1 - i + total) % total].cloneNode(true);
      clone.classList.add(CLONE_CLASS);
      clone.setAttribute('aria-hidden', 'true');
      clone.querySelectorAll('a, button, input, select, textarea').forEach(function(focusable){
        focusable.setAttribute('tabindex', '-1');
      });
      prependFrag.appendChild(clone);
    }

    track.insertBefore(prependFrag, track.firstChild);
    track.appendChild(appendFrag);
  }

  slides = Array.from(track.querySelectorAll('.tcc-slide-' + G));
  current = cloneCount + Math.min(prevReal, total - 1);

  setTrackX(trackXFor(current), false);
  track.offsetHeight;
  track.style.transition = '';

  buildDots();

  if (prevBtn) prevBtn.style.display = total > 1 ? '' : 'none';
  if (nextBtn) nextBtn.style.display = total > 1 ? '' : 'none';
  if (dotsEl) dotsEl.style.display = total > 1 ? '' : 'none';
  if (progEl && progEl.parentElement) progEl.parentElement.style.display = total > 1 ? '' : 'none';
  if (ctrEl) ctrEl.style.display = total > 1 ? '' : 'none';

  if (totEl) totEl.textContent = total;
  updateUI();
}

function jumpIfNeeded(){
  const total = originalSlides.length;
  if (total <= 1) return;

  if (current >= cloneCount + total || current < cloneCount){
    const real = ((current - cloneCount) % total + total) % total;
    current = cloneCount + real;
    track.style.transition = 'none';
    setTrackX(trackXFor(current), false);
    track.offsetHeight;
    track.style.transition = '';
  }
}

function goTo(index, instant){
  current = index;
  setTrackX(trackXFor(current), instant ? false : true);
  updateUI();
  resetAutoplay();
}

function goBy(step){
  const total = originalSlides.length;
  if (total <= 1) return;

  current += step;

  /* Si salió del rango de clones, saltar instantáneamente al espejo y luego animar */
  if (current >= cloneCount + total){
    const real = ((current - cloneCount) % total + total) % total;
    const jumpTo = cloneCount + real;
    track.style.transition = 'none';
    setTrackX(trackXFor(jumpTo), false);
    track.offsetHeight;
    current = jumpTo + step;
  } else if (current < cloneCount){
    const real = ((current - cloneCount) % total + total) % total;
    const jumpTo = cloneCount + real;
    track.style.transition = 'none';
    setTrackX(trackXFor(jumpTo), false);
    track.offsetHeight;
    current = jumpTo + step;
  }

  setTrackX(trackXFor(current), true);
  updateUI();
  resetAutoplay();
}

track.addEventListener('transitionend', function(){
  jumpIfNeeded();
  updateUI();
  track.style.willChange = 'auto';
});

if (prevBtn) {
  prevBtn.addEventListener('click', function(){
    goBy(-1);
  });
}

if (nextBtn) {
  nextBtn.addEventListener('click', function(){
    goBy(1);
  });
}

function startAutoplay(){
  if (!AUTOPLAY || originalSlides.length <= 1) return;
  if (document.hidden) return;

  stopAutoplay();

  autoTimer = setInterval(function(){
    goBy(1);
  }, AUTOPLAY_SPD);

  if (abarEl && SHOW_ABAR){
    abarEl.style.transition = 'none';
    abarEl.style.width = '0%';

    requestAnimationFrame(function(){
      abarEl.style.transition = 'width ' + (AUTOPLAY_SPD / 1000) + 's linear';
      abarEl.style.width = '100%';
    });
  }
}

function stopAutoplay(){
  clearInterval(autoTimer);
  autoTimer = null;

  if (abarEl){
    abarEl.style.transition = 'none';
    abarEl.style.width = '0%';
  }
}

function resetAutoplay(){
  if (!AUTOPLAY) return;
  stopAutoplay();
  startAutoplay();
}

root.addEventListener('mouseenter', stopAutoplay);
root.addEventListener('mouseleave', startAutoplay);
root.addEventListener('focusin', stopAutoplay);
root.addEventListener('focusout', startAutoplay);

document.addEventListener('visibilitychange', function(){
  if (document.hidden) stopAutoplay();
  else startAutoplay();
});

function onPointerDown(e){
  if (e.pointerType === 'mouse' && e.button !== 0) return;
  if (originalSlides.length <= 1) return;

  isDragging = true;
  dragMoved = false;
  lastPointerId = e.pointerId;
  startX = e.clientX;
  startY = e.clientY;
  startTranslate = trackXFor(current);
  currentTranslate = startTranslate;

  viewport.classList.add('is-dragging');
  track.style.transition = 'none';

  stopAutoplay();

if (e.pointerType !== 'mouse' && viewport.setPointerCapture) {
  viewport.setPointerCapture(e.pointerId);
}
}

function onPointerMove(e){
  if (!isDragging || e.pointerId !== lastPointerId) return;

  const dx = e.clientX - startX;

const dy = e.clientY - startY;

if (Math.abs(dx) > 10 && Math.abs(dx) > Math.abs(dy)) {
  dragMoved = true;
}


  currentTranslate = startTranslate + dx;
  track.style.willChange = 'transform';
  track.style.transform = 'translate3d(' + currentTranslate + 'px,0,0)';
}

function onPointerUp(e){
  if (!isDragging || e.pointerId !== lastPointerId) return;

  isDragging = false;
  viewport.classList.remove('is-dragging');

  const dx = e.clientX - startX;
  const size = Math.max(1, itemSize() * 0.92);
  const movedSlides = Math.floor(Math.abs(dx) / size);

  let step = 0;

  if (Math.abs(dx) > size * 0.18){
    step = Math.max(1, movedSlides);
  }

  if (step > 0){
    if (dx < 0) current += step;
    else if (dx > 0) current -= step;
  }

  setTrackX(trackXFor(current), true);
  updateUI();
  resetAutoplay();

  if (viewport.releasePointerCapture) {
    try { viewport.releasePointerCapture(e.pointerId); } catch(err) {}
  }

lastPointerId = null;

setTimeout(function(){
  dragMoved = false;
}, 0);

}

viewport.addEventListener('pointerdown', onPointerDown);
viewport.addEventListener('pointermove', onPointerMove);
viewport.addEventListener('pointerup', onPointerUp);
viewport.addEventListener('pointercancel', onPointerUp);
viewport.addEventListener('dragstart', function(e){
  e.preventDefault();
});

viewport.addEventListener('lostpointercapture', function(){
  if (!isDragging) return;
  isDragging = false;
  lastPointerId = null;
  viewport.classList.remove('is-dragging');
  setTrackX(trackXFor(current), true);
});

window.addEventListener('blur', function(){
  if (!isDragging) return;
  isDragging = false;
  lastPointerId = null;
  viewport.classList.remove('is-dragging');
  setTrackX(trackXFor(current), true);
});

track.addEventListener('click', function(e){
  if (!dragMoved) return;

  e.preventDefault();
  e.stopPropagation();
});

viewport.addEventListener('keydown', function(e){
  if (originalSlides.length <= 1) return;

  if (e.key === 'ArrowLeft'){
    e.preventDefault();
    goBy(-1);
  }

  if (e.key === 'ArrowRight'){
    e.preventDefault();
    goBy(1);
  }
});

viewport.addEventListener('wheel', function(e){
  if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

  const delta = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
  if (Math.abs(delta) < 18) return;

  e.preventDefault();
  wheelDelta += delta;

  clearTimeout(wheelTimer);
  wheelTimer = setTimeout(function(){
    const step = Math.max(1, Math.round(Math.abs(wheelDelta) / 140));
    goBy(wheelDelta > 0 ? step : -step);
    wheelDelta = 0;
  }, 70);
}, { passive: false });

function initReveal() {
  function show() {
    root.classList.add('ttc-vis-' + G);
  }

  if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    show();
    return;
  }

  if (!('IntersectionObserver' in window)) {
    show();
    return;
  }

  var observer = new IntersectionObserver(function (entries) {
    var entry = entries[0];
    if (!entry) return;

    if (entry.isIntersecting) {
      window.requestAnimationFrame(show);
      observer.unobserve(root);
    }
  }, {
    threshold: 0.12,
    rootMargin: '0px 0px -10% 0px'
  });

  observer.observe(root);
}

function fitCardTitles(){
  var titles = root.querySelectorAll('.tcc-fit-text-' + G);

  titles.forEach(function(span){
    var parent = span.closest('.tcc-card-name-' + G);
    if (!parent) return;

    span.style.fontSize = '';
    var maxHeight = parent.clientHeight;
    var attempts = 0;

    while (span.scrollHeight > maxHeight && attempts < 12) {
      var current = parseFloat(getComputedStyle(span).fontSize);
      span.style.fontSize = (current - 1) + 'px';
      attempts++;
    }
  });
}

function initTilt(){
  if (!ENABLE_TILT || window.matchMedia('(hover: none)').matches) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  originalSlides.forEach(function(slide){
    const card = slide.querySelector('.tcc-card-' + G);
    if (!card) return;

    card.classList.add('tcc-tilt-' + G);

    let rafId = null;

    card.addEventListener('mousemove', function(e){
      if (rafId) cancelAnimationFrame(rafId);

      rafId = requestAnimationFrame(function(){
        const rect = card.getBoundingClientRect();
        const dx = (e.clientX - rect.left) / rect.width - 0.5;
        const dy = (e.clientY - rect.top) / rect.height - 0.5;
        const rotX = dy * -5;
        const rotY = dx * 6;

        card.style.transform =
          'translateY(-4px) rotateX(' + rotX + 'deg) rotateY(' + rotY + 'deg)';
      });
    }, { passive: true });

    card.addEventListener('mouseleave', function(){
      if (rafId) cancelAnimationFrame(rafId);
      card.style.transform = '';
    });
  });
}

window.addEventListener('resize', function(){
  clearTimeout(resizeTimer);
  resizeTimer = setTimeout(function(){
    buildInfinite();
    resetAutoplay();
    fitCardTitles();
  }, 120);
}, { passive: true });

buildInfinite();
initReveal();
initTilt();
startAutoplay();
updateUI();
fitCardTitles();

/* ── Neutralizar borde del section padre ── */
(function(){
  var el = document.getElementById('tcc-root-' + G);
  if (!el) return;
  var parent = el.parentElement;
  while (parent) {
    parent.style.setProperty('border', 'none', 'important');
    parent.style.setProperty('border-top', 'none', 'important');
    parent.style.setProperty('border-bottom', 'none', 'important');
    parent.style.setProperty('box-shadow', 'none', 'important');
    parent.style.setProperty('outline', 'none', 'important');
    parent.style.setProperty('background-image', 'none', 'important');
    if (parent.tagName === 'SECTION' || parent.classList.contains('shopify-section')) {
      parent.style.setProperty('border', 'none', 'important');
      parent.style.setProperty('border-bottom', 'none', 'important');
      var next = parent.nextElementSibling;
      if (next && next.classList && next.classList.contains('shopify-section')) {
        next.style.setProperty('border-top', 'none', 'important');
      }
      break;
    }
    parent = parent.parentElement;
  }
})();

/* ── Reveal reversible ── */
(function(){
  var el = document.getElementById('tcc-root-' + G);
  if (!el) return;

  el.classList.add('tcc-anim-ready-' + G);

  var prevY = window.scrollY || 0;

  function showEl() {
    el.classList.add('tcc-anim-vis-' + G);
    el.classList.remove('tcc-anim-top-' + G, 'tcc-anim-bot-' + G);
  }

  function hideEl() {
    var y = window.scrollY || 0;
    var goingDown = y >= prevY;
    prevY = y;
    el.classList.remove('tcc-anim-vis-' + G);
    if (goingDown) {
      el.classList.add('tcc-anim-top-' + G);
      el.classList.remove('tcc-anim-bot-' + G);
    } else {
      el.classList.add('tcc-anim-bot-' + G);
      el.classList.remove('tcc-anim-top-' + G);
    }
  }

  if ('IntersectionObserver' in window) {
    var io2 = new IntersectionObserver(function(entries) {
      prevY = window.scrollY || 0;
      requestAnimationFrame(function() {
        if (entries[0].isIntersecting) { showEl(); } else { hideEl(); }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px 0px 0px' });
    io2.observe(el);
  } else {
    showEl();
  }

  document.addEventListener('shopify:section:select', function(e) {
    if (e.detail && e.detail.sectionId && el.closest('[id*="' + e.detail.sectionId + '"]')) showEl();
  });
})();
})();
</script>
{%- endif -%}

