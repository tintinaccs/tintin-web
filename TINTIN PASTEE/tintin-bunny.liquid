{%- comment -%}
  snippets/tintin-bunny.liquid
  Conejito animado con sistema de descuento 15%
  Incluir en theme.liquid antes de </body>:
    {% render 'tintin-bunny' %}
{%- endcomment -%}

{%- liquid
  assign customer_logged_in = false
  assign customer_id = ''
  assign customer_email = ''
  if customer
    assign customer_logged_in = true
    assign customer_id = customer.id | append: ''
    assign customer_email = customer.email | downcase
  endif
-%}

<style>
/* ══════════════════════════════════════════
   TINTIN BUNNY SYSTEM
   Conejito + Popups de descuento
══════════════════════════════════════════ */

/* ── Conejito flotante ── */
#tnb-bunny-wrap {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 99990;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  animation: tnb-peek 3.2s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  will-change: transform;
}

#tnb-bunny-wrap.tnb-hidden {
  display: none !important;
}

@keyframes tnb-peek {
  0%   { transform: translateX(-50%) translateY(70%); }
  18%  { transform: translateX(-50%) translateY(0%); }
  55%  { transform: translateX(-50%) translateY(0%); }
  72%  { transform: translateX(-50%) translateY(70%); }
  100% { transform: translateX(-50%) translateY(70%); }
}

/* Píldora "¡Ayudame y clickeame!" */
#tnb-pill {
  background: #fff;
  border: 2px solid #ea7ea3;
  border-radius: 999px;
  padding: 6px 16px;
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(10px, 1.2vw, 13px);
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #ea7ea3;
  white-space: nowrap;
  margin-bottom: 8px;
  box-shadow: 0 2px 12px rgba(234,126,163,0.25);
  animation: tnb-pill-pulse 1.8s ease-in-out infinite;
  pointer-events: none;
}

@keyframes tnb-pill-pulse {
  0%, 100% { box-shadow: 0 2px 12px rgba(234,126,163,0.25); transform: scale(1); }
  50%       { box-shadow: 0 4px 20px rgba(234,126,163,0.5); transform: scale(1.04); }
}

/* SVG Conejito */
#tnb-bunny-svg {
  width: clamp(64px, 10vw, 96px);
  height: auto;
  filter: drop-shadow(0 4px 16px rgba(234,126,163,0.35));
  transition: filter 0.3s ease;
}

#tnb-bunny-wrap:hover #tnb-bunny-svg {
  filter: drop-shadow(0 6px 24px rgba(234,126,163,0.6));
}

/* Botón X cerrar */
#tnb-close-btn {
  position: fixed;
  bottom: 90px;
  left: calc(50% + 36px);
  z-index: 99991;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #ea7ea3;
  border: none;
  color: #fff;
  font-size: 12px;
  font-weight: 900;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(234,126,163,0.4);
  transition: background 0.2s ease, transform 0.2s ease;
  line-height: 1;
  -webkit-tap-highlight-color: transparent;
}

#tnb-close-btn:hover {
  background: #d4608a;
  transform: scale(1.1);
}

#tnb-close-btn.tnb-hidden {
  display: none !important;
}

/* ── Overlay base ── */
.tnb-overlay {
  position: fixed;
  inset: 0;
  z-index: 99995;
  background: rgba(255, 240, 245, 0.88);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(16px, 4vw, 32px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}

.tnb-overlay.tnb-show {
  opacity: 1;
  pointer-events: auto;
}

/* ── Popup 1: ¿Querés saber cómo ganar descuento? ── */
#tnb-popup1 {
  z-index: 99996;
}

#tnb-popup1-card {
  background: #fff;
  border: 2px solid #ea7ea3;
  border-radius: clamp(18px, 2.5vw, 28px);
  padding: clamp(28px, 4vw, 48px) clamp(24px, 4vw, 44px);
  max-width: clamp(280px, 90vw, 460px);
  width: 100%;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: clamp(14px, 2vw, 22px);
  transform: translateY(24px) scale(0.96);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}

#tnb-popup1.tnb-show #tnb-popup1-card {
  transform: translateY(0) scale(1);
}

.tnb-popup-close {
  position: absolute;
  top: 14px;
  right: 16px;
  background: none;
  border: none;
  cursor: pointer;
  color: rgba(234,126,163,0.5);
  font-size: 20px;
  line-height: 1;
  padding: 2px 5px;
  transition: color 0.2s ease;
  -webkit-tap-highlight-color: transparent;
}

.tnb-popup-close:hover { color: #ea7ea3; }

.tnb-bunny-emoji {
  font-size: clamp(36px, 5vw, 52px);
  animation: tnb-wiggle 1.4s ease-in-out infinite;
}

@keyframes tnb-wiggle {
  0%, 100% { transform: rotate(-6deg); }
  50%       { transform: rotate(6deg); }
}

.tnb-popup-title {
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(15px, 2vw, 20px);
  font-weight: 900;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #ea7ea3;
  line-height: 1.2;
  margin: 0;
}

.tnb-popup-sub {
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(11px, 1.1vw, 13px);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #b07090;
  opacity: 0.85;
  margin: 0;
}

.tnb-btn-main {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: clamp(12px, 1.4vw, 16px) clamp(24px, 3vw, 40px);
  border-radius: 999px;
  border: none;
  background: #ea7ea3;
  color: #fff;
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(11px, 1.1vw, 13px);
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  cursor: pointer;
  box-shadow: none;
  transition: background 0.3s ease, transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
  width: 100%;
  animation: tnb-breathe 2.6s cubic-bezier(0.45,0,0.55,1) infinite;
  text-decoration: none;
}

@keyframes tnb-breathe {
  0%, 100% { transform: scale(1); }
  50%       { transform: scale(1.02) translateY(-2px); }
}

.tnb-btn-main:hover {
  background: #d4608a;
  animation-play-state: paused;
  transform: scale(1.04) translateY(-3px);
}

/* ── Popup 2: Imagen con pasos ── */
#tnb-popup2 {
  z-index: 99997;
}

#tnb-popup2-card {
  background: #fff;
  border: 2px solid #ea7ea3;
  border-radius: clamp(18px, 2.5vw, 28px);
  padding: clamp(20px, 3vw, 36px);
  max-width: clamp(300px, 92vw, 540px);
  width: 100%;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: clamp(12px, 1.8vw, 20px);
  transform: translateY(24px) scale(0.96);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}

#tnb-popup2.tnb-show #tnb-popup2-card {
  transform: translateY(0) scale(1);
}

#tnb-steps-img-link {
  display: block;
  width: 100%;
  border-radius: clamp(10px, 1.5vw, 16px);
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.3s cubic-bezier(0.22,1,0.36,1);
  text-decoration: none;
}

#tnb-steps-img-link:hover {
  transform: scale(1.02);
}

#tnb-steps-img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: clamp(10px, 1.5vw, 16px);
}

/* Placeholder si no hay imagen aún */
#tnb-steps-placeholder {
  width: 100%;
  min-height: 200px;
  background: linear-gradient(135deg, #fff0f5, #f6dce6);
  border-radius: clamp(10px, 1.5vw, 16px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  color: #ea7ea3;
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0.6;
  cursor: pointer;
}

/* ── Popup 3: Cupón del cliente logueado ── */
#tnb-popup-coupon {
  z-index: 99998;
}

#tnb-coupon-card {
  background: #fff;
  border: 2px solid #ea7ea3;
  border-radius: clamp(18px, 2.5vw, 28px);
  padding: clamp(28px, 4vw, 48px) clamp(24px, 4vw, 44px);
  max-width: clamp(300px, 90vw, 480px);
  width: 100%;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: clamp(14px, 2vw, 22px);
  transform: translateY(24px) scale(0.96);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}

#tnb-popup-coupon.tnb-show #tnb-coupon-card {
  transform: translateY(0) scale(1);
}

.tnb-coupon-badge {
  background: linear-gradient(135deg, #ea7ea3, #d4608a);
  color: #fff;
  border-radius: 999px;
  padding: 6px 20px;
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(10px, 1vw, 12px);
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.tnb-coupon-title {
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(16px, 2.2vw, 24px);
  font-weight: 900;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #ea7ea3;
  line-height: 1.1;
  margin: 0;
}

.tnb-coupon-desc {
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(10px, 1vw, 12px);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #b07090;
  opacity: 0.85;
  margin: 0;
  line-height: 1.5;
}

/* Caja del código */
.tnb-code-wrap {
  width: 100%;
  background: #fff0f5;
  border: 2px dashed #ea7ea3;
  border-radius: clamp(10px, 1.5vw, 16px);
  padding: clamp(14px, 1.8vw, 20px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.tnb-code-label {
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(9px, 0.85vw, 11px);
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #b07090;
  opacity: 0.75;
}

.tnb-code-value {
  font-family: "Courier New", "Courier", monospace;
  font-size: clamp(18px, 2.5vw, 28px);
  font-weight: 900;
  letter-spacing: 0.18em;
  color: #ea7ea3;
  user-select: all;
}

#tnb-copy-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: clamp(12px, 1.4vw, 16px) clamp(20px, 2.5vw, 32px);
  border-radius: 999px;
  border: none;
  background: #ea7ea3;
  color: #fff;
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(11px, 1.1vw, 13px);
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.3s ease, transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
}

#tnb-copy-btn:hover {
  background: #d4608a;
  transform: translateY(-2px) scale(1.02);
}

#tnb-copy-btn.tnb-copied {
  background: #4caf78;
}

.tnb-coupon-note {
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(9px, 0.85vw, 11px);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #b07090;
  opacity: 0.65;
  margin: 0;
  line-height: 1.5;
  text-align: center;
}

/* ── Responsive ── */
@media (max-width: 480px) {
  #tnb-close-btn {
    left: calc(50% + 28px);
    bottom: 75px;
  }
}

@media (prefers-reduced-motion: reduce) {
  #tnb-bunny-wrap { animation: none !important; transform: translateX(-50%) translateY(0) !important; }
  #tnb-pill { animation: none !important; }
  .tnb-bunny-emoji { animation: none !important; }
  .tnb-btn-main { animation: none !important; }
}
</style>

