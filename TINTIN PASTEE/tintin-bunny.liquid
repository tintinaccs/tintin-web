<script>
(function () {
  'use strict';

  /* ── Config ── */
  var STORAGE_KEY_CLOSED  = 'tnb_bunny_closed';
  var STORAGE_KEY_COUPON  = 'tnb_coupon_';
  var STORAGE_KEY_SHOWN   = 'tnb_coupon_shown_';
  var TNB_STEPS_IMAGE_URL = ''; /* ← POné aquí la URL de tu imagen cuando esté lista */

  var IS_LOGGED_IN    = {{ customer_logged_in | json }};
  var CUSTOMER_ID     = {{ customer_id | json }};
  var CUSTOMER_EMAIL  = {{ customer_email | json }};
  var REGISTER_URL    = {{ routes.account_register_url | json }};
  var HOME_URL        = {{ routes.root_url | json }};

  /* ── Elementos ── */
  var bunnyWrap   = document.getElementById('tnb-bunny-wrap');
  var closeBtn    = document.getElementById('tnb-close-btn');
  var popup1      = document.getElementById('tnb-popup1');
  var popup2      = document.getElementById('tnb-popup2');
  var popupCoupon = document.getElementById('tnb-popup-coupon');
  var btnSteps    = document.getElementById('tnb-btn-show-steps');
  var stepsImg    = document.getElementById('tnb-steps-img');
  var stepsPlaceholder = document.getElementById('tnb-steps-placeholder');
  var couponCode  = document.getElementById('tnb-coupon-code');
  var copyBtn     = document.getElementById('tnb-copy-btn');

  if (!bunnyWrap) return;

  /* ── Imagen de pasos ── */
  if (TNB_STEPS_IMAGE_URL && stepsImg) {
    stepsImg.src = TNB_STEPS_IMAGE_URL;
    stepsImg.style.display = 'block';
    if (stepsPlaceholder) stepsPlaceholder.style.display = 'none';
  }

  /* ── Generar cupón único por cliente ── */
  function generateCouponCode(customerId, email) {
    /* Hash simple basado en customer ID + email + salt fijo */
    var raw = 'TINTIN' + customerId + email + 'tntsalt2025';
    var hash = 0;
    for (var i = 0; i < raw.length; i++) {
      var ch = raw.charCodeAt(i);
      hash = ((hash << 5) - hash) + ch;
      hash = hash & hash; /* 32bit int */
    }
    /* Convertir a base36 alfanumérico y tomar 6 chars */
    var code = Math.abs(hash).toString(36).toUpperCase().slice(0, 6);
    /* Asegurar que siempre tenga 6 caracteres */
    while (code.length < 6) { code = '0' + code; }
    return 'TINTIN-' + code;
  }

  function getCoupon() {
    if (!IS_LOGGED_IN || !CUSTOMER_ID) return null;
    var storageKey = STORAGE_KEY_COUPON + CUSTOMER_ID;
    var saved = localStorage.getItem(storageKey);
    if (saved) return saved;
    var code = generateCouponCode(CUSTOMER_ID, CUSTOMER_EMAIL);
    localStorage.setItem(storageKey, code);
    return code;
  }

  /* ── Helpers popup ── */
  function openPopup(el) {
    if (!el) return;
    /* Cerrar todos primero */
    [popup1, popup2, popupCoupon].forEach(function (p) {
      if (p && p !== el) {
        p.classList.remove('tnb-show');
      }
    });
    el.classList.add('tnb-show');
    document.body.style.overflow = 'hidden';
  }

  function closePopup(el) {
    if (!el) return;
    el.classList.remove('tnb-show');
    /* Restaurar scroll solo si ningún popup está abierto */
    setTimeout(function () {
      var anyOpen = [popup1, popup2, popupCoupon].some(function (p) {
        return p && p.classList.contains('tnb-show');
      });
      if (!anyOpen) document.body.style.overflow = '';
    }, 50);
  }

  function closeAllPopups() {
    [popup1, popup2, popupCoupon].forEach(function (p) { closePopup(p); });
  }

  /* ── Cerrar con botones X internos ── */
  document.querySelectorAll('.tnb-popup-close').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var target = btn.getAttribute('data-tnb-close');
      if (target === 'popup1') closePopup(popup1);
      else if (target === 'popup2') closePopup(popup2);
      else if (target === 'coupon') closePopup(popupCoupon);
    });
  });

  /* ── Cerrar al clickear el overlay (fuera de la card) ── */
  [popup1, popup2, popupCoupon].forEach(function (overlay) {
    if (!overlay) return;
    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) closeAllPopups();
    });
  });

  /* ── ESC para cerrar ── */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeAllPopups();
  });

  /* ── Flujo de clicks del conejito ── */
  function onBunnyClick() {
    /* Si está logueado → mostrar popup del cupón */
    if (IS_LOGGED_IN) {
      var code = getCoupon();
      if (couponCode) couponCode.textContent = code || 'ERROR';
      openPopup(popupCoupon);
    } else {
      /* No logueado → mostrar popup 1 */
      openPopup(popup1);
    }
  }

  bunnyWrap.addEventListener('click', onBunnyClick);
  bunnyWrap.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      onBunnyClick();
    }
  });

  /* ── Popup 1 → Popup 2 ── */
  if (btnSteps) {
    btnSteps.addEventListener('click', function () {
      closePopup(popup1);
      setTimeout(function () { openPopup(popup2); }, 180);
    });
  }

  /* ── Botón cerrar conejito permanentemente ── */
  if (closeBtn) {
    closeBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      localStorage.setItem(STORAGE_KEY_CLOSED, '1');
      bunnyWrap.classList.add('tnb-hidden');
      closeBtn.classList.add('tnb-hidden');
    });
  }

  /* ── Restaurar estado cerrado ── */
  if (localStorage.getItem(STORAGE_KEY_CLOSED) === '1') {
    bunnyWrap.classList.add('tnb-hidden');
    if (closeBtn) closeBtn.classList.add('tnb-hidden');
  }

  /* ── Copiar cupón ── */
  if (copyBtn && couponCode) {
    copyBtn.addEventListener('click', function () {
      var code = couponCode.textContent;
      if (!code || code === 'Cargando...') return;

      var copied = false;

      /* Método moderno */
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(code).then(function () {
          showCopied();
        }).catch(function () {
          fallbackCopy(code);
        });
      } else {
        fallbackCopy(code);
      }
    });
  }

  function fallbackCopy(text) {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0;';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    try { document.execCommand('copy'); showCopied(); } catch (e) {}
    document.body.removeChild(ta);
  }

  function showCopied() {
    if (!copyBtn) return;
    var original = copyBtn.innerHTML;
    copyBtn.innerHTML = '✅ ¡Copiado!';
    copyBtn.classList.add('tnb-copied');
    setTimeout(function () {
      copyBtn.innerHTML = original;
      copyBtn.classList.remove('tnb-copied');
    }, 2400);
  }

  /* ── Popup automático del cupón en el home (solo logueados, solo 1 vez) ── */
  if (IS_LOGGED_IN && CUSTOMER_ID) {
    var shownKey = STORAGE_KEY_SHOWN + CUSTOMER_ID;
    var isHome = window.location.pathname === HOME_URL
              || window.location.pathname === '/'
              || window.location.pathname === '';

    if (isHome && !localStorage.getItem(shownKey)) {
      localStorage.setItem(shownKey, '1');
      setTimeout(function () {
        var code = getCoupon();
        if (couponCode) couponCode.textContent = code || 'ERROR';
        openPopup(popupCoupon);
      }, 2200); /* Aparece 2.2s después de cargar */
    }
  }

}());
</script>