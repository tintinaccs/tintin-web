{% comment %}
  ╔══════════════════════════════════════════════════════╗
  ║  TINTIN — 01 HERO PRODUCTO                          ║
  ║  Archivo: 01-tintin-hero-producto.liquid            ║
  ║  Posición: 1° en la plantilla de producto           ║
  ║  Sincroniza: emite TinCart:variantChange            ║
  ╚══════════════════════════════════════════════════════╝
{% endcomment %}

{%- assign g = 'tinhero' -%}
{%- assign fv = product.selected_or_first_available_variant -%}
{%- assign initial_img = fv.featured_image | default: product.featured_image -%}

{% style %}
.{{ g }} {
  --acc: {{ section.settings.accent_color }};
  --bg: {{ section.settings.background_color }};
  --fg: {{ section.settings.text_color }};
  --pbtn: {{ section.settings.primary_button_color }};
  --pbtnT: {{ section.settings.primary_button_text_color }};
  --sbtn: {{ section.settings.secondary_button_color }};
  --sbtnT: {{ section.settings.secondary_button_text_color }};
  --r: {{ section.settings.border_radius }}px;
  --rlg: calc({{ section.settings.border_radius }}px * 2);
  --ease: .24s cubic-bezier(.4,0,.2,1);
  background: var(--bg);
  color: var(--fg);
  width: 100%;
}

.{{ g }} *,
.{{ g }} *::before,
.{{ g }} *::after {
  box-sizing: border-box;
}

.{{ g }}-wrap {
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: clamp(24px,4vw,{{ section.settings.section_padding }}px) clamp(16px,4vw,72px);
}

.{{ g }}-hero {
  display: grid;
  grid-template-columns: minmax(0,1.05fr) minmax(380px,.95fr);
  gap: clamp(24px,4vw,72px);
  align-items: start;
}

/* ─────────────────────────────
   IMAGEN
───────────────────────────── */
.{{ g }}-imgcol {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.{{ g }}-imgbox {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: var(--rlg);
  overflow: hidden;
  background: #fff;
  box-shadow: 0 24px 80px rgba(0,0,0,.08), 0 8px 30px rgba(0,0,0,.05);
  cursor: zoom-in;
}

.{{ g }}-imgbox::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--rlg);
  border: 1px solid rgba(212,120,154,.1);
  pointer-events: none;
  z-index: 2;
  transition: border-color var(--ease);
}

.{{ g }}-imgbox:hover::after {
  border-color: rgba(212,120,154,.42);
}

.{{ g }}-mainimg {
  width: 100% !important;
  height: 100% !important;
  object-fit: contain !important;
  object-position: center center !important;
  padding: clamp(10px,1.6vw,18px) !important;
  display: block !important;
  background: #ffffff !important;
}

.{{ g }}-mainimg.tin-loading {
  opacity: 0;
}

.{{ g }}-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #fff5f9, #f7dce8);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(45,45,45,.45);
  font-size: 13px;
  letter-spacing: .08em;
  text-transform: uppercase;
}

/* BADGE */
.{{ g }}-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  z-index: 3;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  backdrop-filter: blur(8px);
}

.{{ g }}-bavail {
  background: {{ section.settings.available_badge_color }};
  color: {{ section.settings.available_badge_text_color }};
}

.{{ g }}-bsold {
  background: {{ section.settings.sold_out_badge_color }};
  color: #fff;
}

/* FLECHAS */
.{{ g }}-arr {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 11;
  width: clamp(38px,3vw,50px);
  height: clamp(38px,3vw,50px);
  border-radius: 50%;
  background: rgba(255,255,255,.96);
  border: 1px solid rgba(212,120,154,.18);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  box-shadow: 0 6px 22px rgba(0,0,0,.12);
  transition: box-shadow .18s, transform .18s, background .18s;
}

.{{ g }}-arr:hover {
  background: #fff;
  box-shadow: 0 10px 30px rgba(0,0,0,.18);
  transform: translateY(-50%) scale(1.06);
}

.{{ g }}-arr-prev {
  left: clamp(10px,1.2vw,18px);
}

.{{ g }}-arr-next {
  right: clamp(10px,1.2vw,18px);
}

.{{ g }}-arr svg {
  width: 18px;
  height: 18px;
}

/* DOTS */
.{{ g }}-dots {
  display: flex;
  justify-content: center;
  gap: 6px;
  margin-top: 4px;
}

.{{ g }}-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(212,120,154,.2);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: all .18s;
}

.{{ g }}-dot.active {
  background: var(--acc);
  width: 16px;
  border-radius: 999px;
}

/* MINIATURAS */
.{{ g }}-thumbs {
  display: flex;
  gap: 9px;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  margin-top: 4px;
  padding: 0 4px;
}

.{{ g }}-thumb {
  width: 64px;
  height: 64px;
  border-radius: 12px;
  overflow: hidden;
  cursor: pointer;
  border: 2px solid transparent;
  background: #ffffff;
  transition: border-color var(--ease), box-shadow var(--ease), transform var(--ease), opacity var(--ease);
  flex-shrink: 0;
  box-shadow: 0 4px 14px rgba(212,120,154,.10);
}

.{{ g }}-thumb img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center center;
  display: block;
  background: #ffffff;
}

.{{ g }}-thumb.active {
  border-color: var(--acc);
  box-shadow: 0 3px 10px rgba(212,120,154,.35);
  transform: scale(1.05);
}

/* ─────────────────────────────
   PANEL INFO
───────────────────────────── */
.{{ g }}-panel {
  display: flex;
  flex-direction: column;
  gap: clamp(12px,1.2vw,18px);
  position: sticky;
  top: clamp(12px,1.6vw,24px);
  width: 100%;
  max-width: 560px;
  align-self: start;
}

.{{ g }}-title {
  font-size: clamp(28px,3.6vw,{{ section.settings.title_size }}px);
  font-weight: 500;
  color: var(--fg);
  margin: 0;
  line-height: 1.1;
  letter-spacing: -.03em;
}

.{{ g }}-pricerow {
  display: flex;
  align-items: baseline;
  gap: 10px;
}

.{{ g }}-price {
  font-size: clamp(24px,2.4vw,{{ section.settings.price_size }}px);
  font-weight: 700;
  color: var(--acc);
  letter-spacing: -.03em;
}

.{{ g }}-divider {
  height: 1px;
  background: linear-gradient(90deg, rgba(212,120,154,.3), transparent);
}

.{{ g }}-desc {
  font-size: clamp(14px,1vw,17px);
  line-height: 1.8;
  color: rgba(45,45,45,.68);
  width: 100%;
  max-width: none;
}

/* VARIANTES */
.{{ g }}-vgroup {
  display: flex;
  flex-direction: column;
  gap: 10px;
  width: 100%;
  min-width: 0;
}

.{{ g }}-vlabel {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: rgba(45,45,45,.62);
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  line-height: 1.35;
}

.{{ g }}-vsel {
  display: none !important;
}

.{{ g }}-vopts {
  display: grid;
  grid-template-columns: repeat(auto-fit,minmax(140px,1fr));
  gap: 10px;
  width: 100%;
}

.{{ g }}-vopt {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 44px;
  padding: 10px 18px;
  border: 1.5px solid rgba(212,120,154,.28);
  border-radius: 999px;
  font-size: clamp(13px,.95vw,15px);
  font-weight: 600;
  color: var(--fg);
  background: #fff;
  cursor: pointer;
  white-space: normal;
  text-align: center;
  line-height: 1.2;
  transition: .22s ease;
}

.{{ g }}-vopt.active {
  background: var(--acc) !important;
  color: #fff !important;
  border-color: var(--acc) !important;
  box-shadow: 0 8px 24px rgba(212,120,154,.3);
}

.{{ g }}-vopt.unavail {
  opacity: .45;
  filter: grayscale(.4);
}

/* SWATCHES */
.{{ g }}-swatches {
  display: flex !important;
  flex-wrap: wrap !important;
  align-items: center !important;
  gap: 14px !important;
  row-gap: 14px !important;
  width: 100% !important;
  padding: 2px 0 4px !important;
}

.{{ g }}-swatch {
  width: 42px !important;
  height: 42px !important;
  min-width: 42px !important;
  min-height: 42px !important;
  border-radius: 50% !important;
  cursor: pointer !important;
  border: 3px solid #fff !important;
  position: relative !important;
  flex: 0 0 auto !important;
  outline: 3px solid rgba(212,120,154,.22) !important;
  outline-offset: 2px !important;
  box-shadow: 0 4px 14px rgba(0,0,0,.10) !important;
  transition: transform .18s ease, outline-color .18s ease, box-shadow .18s ease, opacity .18s ease, filter .18s ease !important;
}

.{{ g }}-swatch:hover {
  transform: scale(1.08) !important;
  outline-color: rgba(212,120,154,.55) !important;
}

.{{ g }}-swatch.active {
  outline-color: var(--acc) !important;
  box-shadow: 0 6px 18px rgba(212,120,154,.35) !important;
  transform: scale(1.08) !important;
  z-index: 2 !important;
}

.{{ g }}-swatch.unavail {
  opacity: .65;
  filter: saturate(.45);
}

.{{ g }}-swatch.unavail::after {
  content: '';
  position: absolute;
  inset: -3px;
  border-radius: 50%;
  background: linear-gradient(to bottom right, transparent 46%, rgba(229,62,62,.72) 47%, rgba(229,62,62,.72) 53%, transparent 54%);
  pointer-events: none;
}

/* STOCK */
.{{ g }}-stock {
  font-size: clamp(12px,1vw,14px);
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 6px;
}

.{{ g }}-stock-dot {
  display: inline-block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--acc);
  flex-shrink: 0;
}

.{{ g }}-stock.low .{{ g }}-stock-dot {
  background: #ed8936;
}

.{{ g }}-stock.out .{{ g }}-stock-dot {
  background: #e53e3e;
}

/* BOTONES */
.{{ g }}-actions {
  display: grid;
  grid-template-columns: repeat(2,minmax(0,1fr));
  gap: 12px;
  margin-top: 6px;
  width: 100%;
}

.{{ g }}-btn {
  flex: 1;
  border: none;
  cursor: pointer;
  min-height: 54px;
  padding: clamp(14px,1.1vw,18px) clamp(18px,1.4vw,28px);
  font-size: clamp(14px,1vw,16px);
  font-weight: 700;
  border-radius: 16px;
  transition: all var(--ease);
}

.{{ g }}-btn:disabled {
  opacity: .42;
  cursor: not-allowed;
  transform: none !important;
}

.{{ g }}-btn-primary {
  background: var(--pbtn);
  color: var(--pbtnT);
  box-shadow: 0 10px 26px rgba(212,120,154,.28);
}

.{{ g }}-btn-primary:not(:disabled):hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 32px rgba(212,120,154,.44);
}

.{{ g }}-btn-secondary {
  background: #fff;
  color: var(--fg);
  border: 1.5px solid rgba(212,120,154,.24);
}

.{{ g }}-btn-secondary:not(:disabled):hover {
  opacity: .88;
  transform: translateY(-2px);
}

.{{ g }}-btn.is-loading {
  pointer-events: none;
  opacity: .72;
}

.{{ g }}-btn.is-done {
  background: var(--acc) !important;
  color: #fff !important;
}

/* LIGHTBOX */
.{{ g }}-lb {
  position: fixed;
  inset: 0;
  z-index: 99999;
  background: rgba(0,0,0,.88);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity .25s, visibility .25s;
  cursor: zoom-out;
}

.{{ g }}-lb.open {
  opacity: 1;
  visibility: visible;
}

.{{ g }}-lb img {
  max-width: 88vw;
  max-height: 86vh;
  object-fit: contain;
  border-radius: 16px;
  box-shadow: 0 24px 80px rgba(0,0,0,.5);
  cursor: default;
}

.{{ g }}-lb-close {
  position: absolute;
  top: 20px;
  right: 20px;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(255,255,255,.18);
  border: 1.5px solid rgba(255,255,255,.3);
  color: #fff;
  font-size: 20px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(8px);
  z-index: 100000;
}

/* OOS */
.{{ g }}-oos {
  position: absolute;
  inset: 0;
  z-index: 9999;
  background: rgba(0,0,0,.44);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
}

.{{ g }}-oos-box {
  background: var(--bg);
  padding: 40px 32px;
  border-radius: var(--rlg);
  text-align: center;
  max-width: 380px;
  box-shadow: 0 20px 60px rgba(0,0,0,.12);
  border: 1px solid rgba(212,120,154,.1);
}

.{{ g }}-oos-title {
  font-size: 20px;
  font-weight: 600;
  color: var(--fg);
  margin: 0 0 8px;
}

.{{ g }}-oos-text {
  font-size: 14px;
  color: rgba(45,45,45,.6);
  margin: 0 0 22px;
}

.{{ g }}-oos-close {
  background: var(--pbtn);
  color: var(--pbtnT);
  border: none;
  padding: 12px 28px;
  border-radius: 30px;
  font-weight: 700;
  cursor: pointer;
  font-size: 14px;
}

/* TOAST */
.{{ g }}-toast {
  position: fixed;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom, 0px) + 26px);
  transform: translateX(-50%) translateY(18px) scale(.96);
  z-index: 100000;
  min-width: 220px;
  max-width: min(92vw, 420px);
  padding: 13px 20px;
  border-radius: 999px;
  background: #fff;
  color: var(--acc);
  border: 1px solid rgba(212,120,154,.18);
  box-shadow: 0 12px 40px rgba(0,0,0,.12);
  font-size: 13px;
  font-weight: 700;
  text-align: center;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .24s ease, visibility .24s ease, transform .24s ease;
}

.{{ g }}-toast.show {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0) scale(1);
}

.{{ g }}-toast.error {
  color: #e53e3e;
  border-color: rgba(229,62,62,.2);
}

/* RESPONSIVE */
@media(max-width:768px) {
  .{{ g }}-wrap {
    padding: 0 0 24px !important;
  }

  .{{ g }}-hero {
    grid-template-columns: 1fr !important;
    gap: 0 !important;
    align-items: start !important;
  }

  .{{ g }}-imgcol {
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
  }

  .{{ g }}-imgbox {
    width: 100% !important;
    height: auto !important;
    min-height: 0 !important;
    aspect-ratio: 4 / 3 !important;
    border-radius: 0 !important;
    display: block !important;
    overflow: hidden !important;
  }

  .{{ g }}-mainimg {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain !important;
    padding: 10px !important;
    display: block !important;
  }

  .{{ g }}-panel {
    position: relative !important;
    top: auto !important;
    width: 100% !important;
    max-width: none !important;
    padding: 22px 16px 16px !important;
    gap: 14px !important;
    border-radius: 28px 28px 0 0 !important;
    margin-top: -16px !important;
    background: var(--bg) !important;
    box-shadow: 0 -8px 24px rgba(0,0,0,.05) !important;
    z-index: 2 !important;
  }

  .{{ g }}-title {
    font-size: clamp(24px,7vw,32px) !important;
  }

  .{{ g }}-price {
    font-size: clamp(20px,6vw,26px) !important;
  }

  .{{ g }}-vopts {
    grid-template-columns: 1fr !important;
  }

  .{{ g }}-actions {
    grid-template-columns: 1fr !important;
    gap: 10px !important;
  }

  .{{ g }}-btn {
    min-height: 50px !important;
    font-size: 15px !important;
  }

  .{{ g }}-thumb {
  width: 52px !important;
  height: 52px !important;
  border-radius: 11px !important;
}
}

@media(min-width:769px) and (max-width:1279px) {
  .{{ g }}-wrap {
    max-width: 780px !important;
    padding: clamp(22px,4vw,44px) clamp(18px,4vw,42px) !important;
  }

  .{{ g }}-hero {
    grid-template-columns: 1fr !important;
    gap: 24px !important;
    align-items: start !important;
  }

  .{{ g }}-imgcol {
    width: 100% !important;
    max-width: 660px !important;
    margin: 0 auto !important;
    align-self: start !important;
  }

  .{{ g }}-imgbox {
    width: 100% !important;
    height: auto !important;
    min-height: 0 !important;
    aspect-ratio: auto !important;
    display: block !important;
    overflow: hidden !important;
    border-radius: var(--rlg) !important;
  }

  .{{ g }}-mainimg {
    width: 100% !important;
    height: auto !important;
    object-fit: contain !important;
    padding: clamp(10px,1.8vw,18px) !important;
    display: block !important;
  }

  .{{ g }}-panel {
    position: relative !important;
    top: auto !important;
    width: 100% !important;
    max-width: 660px !important;
    margin: 0 auto !important;
    align-self: start !important;
  }

  .{{ g }}-title,
  .{{ g }}-pricerow,
  .{{ g }}-desc,
  .{{ g }}-vgroup,
  .{{ g }}-stock,
  .{{ g }}-actions {
    width: 100% !important;
    max-width: none !important;
  }

  .{{ g }}-vopts {
    grid-template-columns: repeat(auto-fit,minmax(160px,1fr)) !important;
  }

  .{{ g }}-actions {
    display: grid !important;
    grid-template-columns: repeat(2,minmax(0,1fr)) !important;
    gap: 12px !important;
    width: 100% !important;
  }
}

@media(min-width:1280px) {
  .{{ g }}-wrap {
    max-width: {{ section.settings.max_width }}px !important;
  }

  .{{ g }}-hero {
    display: grid !important;
    grid-template-columns: minmax(560px,1.08fr) minmax(420px,.92fr) !important;
    gap: clamp(34px,4vw,86px) !important;
    align-items: start !important;
  }

  .{{ g }}-imgcol {
    width: 100% !important;
    align-self: start !important;
  }

  .{{ g }}-imgbox {
    width: 100% !important;
    height: auto !important;
    min-height: 0 !important;
    aspect-ratio: 1 / 1 !important;
    display: block !important;
    overflow: hidden !important;
    border-radius: var(--rlg) !important;
  }

  .{{ g }}-mainimg {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain !important;
    padding: clamp(10px,1.6vw,18px) !important;
    display: block !important;
  }

  .{{ g }}-panel {
    width: 100% !important;
    max-width: 560px !important;
    position: sticky !important;
    top: clamp(12px,1.6vw,24px) !important;
    align-self: start !important;
  }

  .{{ g }}-vopts {
    grid-template-columns: repeat(auto-fit,minmax(150px,1fr)) !important;
  }

  .{{ g }}-actions {
    display: grid !important;
    grid-template-columns: repeat(2,minmax(0,1fr)) !important;
    gap: 12px !important;
    width: 100% !important;
  }
}

@media (prefers-reduced-motion: reduce) {
  .{{ g }} *,
  .{{ g }} *::before,
  .{{ g }} *::after {
    transition: none !important;
    animation: none !important;
  }
}

/* ─────────────────────────────
   FIX FINAL: imagen completa siempre
   La imagen nunca se corta en ninguna pantalla
───────────────────────────── */

.{{ g }}-imgbox {
  width: 100% !important;
  aspect-ratio: 1 / 1 !important;
  height: auto !important;
  min-height: 0 !important;
  background: #ffffff !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  overflow: hidden !important;
}

.{{ g }}-mainimg {
  width: 100% !important;
  height: 100% !important;
  max-width: 100% !important;
  max-height: 100% !important;
  object-fit: contain !important;
  object-position: center center !important;
  padding: clamp(8px, 1.4vw, 18px) !important;
  background: #ffffff !important;
  display: block !important;
}

/* Móvil: desde el más chico hasta 768px */
@media screen and (max-width: 768px) {
  .{{ g }}-imgbox {
    aspect-ratio: 1 / 1 !important;
    width: 100% !important;
    height: auto !important;
    border-radius: 0 !important;
  }

  .{{ g }}-mainimg {
    object-fit: contain !important;
    width: 100% !important;
    height: 100% !important;
    padding: 8px !important;
  }
}

/* Tablet: 769px a 1279px */
@media screen and (min-width: 769px) and (max-width: 1279px) {
  .{{ g }}-imgbox {
    aspect-ratio: 1 / 1 !important;
    width: 100% !important;
    height: auto !important;
  }

  .{{ g }}-mainimg {
    object-fit: contain !important;
    width: 100% !important;
    height: 100% !important;
    padding: clamp(10px, 1.8vw, 18px) !important;
  }
}

/* Desktop grande: 1280px en adelante */
@media screen and (min-width: 1280px) {
  .{{ g }}-imgbox {
    aspect-ratio: 1 / 1 !important;
    width: 100% !important;
    height: auto !important;
  }

  .{{ g }}-mainimg {
    object-fit: contain !important;
    width: 100% !important;
    height: 100% !important;
    padding: clamp(10px, 1.6vw, 18px) !important;
  }
}

{% endstyle %}

<div class="{{ g }}" id="{{ g }}-root" data-product-id="{{ product.id }}">
  <div class="{{ g }}-wrap">
    <div class="{{ g }}-hero">

      <div class="{{ g }}-imgcol">
        <div class="{{ g }}-imgbox" id="{{ g }}-imgbox">

          {%- if product.available == false -%}
            <div class="{{ g }}-oos">
              <div class="{{ g }}-oos-box">
                <p class="{{ g }}-oos-title">Sin stock por ahora</p>
                <p class="{{ g }}-oos-text">Este accesorio no está disponible. ¡Volvé pronto!</p>
                <button type="button" class="{{ g }}-oos-close" onclick="this.closest('.{{ g }}-oos').remove()">Seguir viendo</button>
              </div>
            </div>
          {%- endif -%}



          {%- if initial_img -%}
            <img
              src="{{ initial_img | image_url: width: 900 }}"
              srcset="{{ initial_img | image_url: width: 480 }} 480w, {{ initial_img | image_url: width: 900 }} 900w, {{ initial_img | image_url: width: 1400 }} 1400w"
              sizes="(max-width:768px) 100vw, 55vw"
              alt="{{ initial_img.alt | default: product.title | escape }}"
              id="{{ g }}-mainimg"
              class="{{ g }}-mainimg"
              loading="eager"
              width="{{ initial_img.width }}"
              height="{{ initial_img.height }}"
              fetchpriority="high">
          {%- else -%}
            <div class="{{ g }}-placeholder">Sin imagen</div>
          {%- endif -%}

          <button type="button" class="{{ g }}-arr {{ g }}-arr-prev" id="{{ g }}-prev" aria-label="Anterior">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>

          <button type="button" class="{{ g }}-arr {{ g }}-arr-next" id="{{ g }}-next" aria-label="Siguiente">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
        </div>

        <div class="{{ g }}-dots" id="{{ g }}-dots"></div>

        {%- if product.images.size > 1 -%}
          <div class="{{ g }}-thumbs" id="{{ g }}-thumbs">
            {%- for img in product.images -%}
              <div
                class="{{ g }}-thumb{% if initial_img and img.id == initial_img.id %} active{% endif %}"
                data-src="{{ img | image_url: width: 900 }}"
                data-idx="{{ forloop.index0 }}"
                role="button"
                tabindex="0"
                aria-label="Ver imagen {{ forloop.index }}">
                <img
                  src="{{ img | image_url: width: 130 }}"
                  alt="{{ img.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="68"
                  height="68">
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="{{ g }}-panel">
        <h1 class="{{ g }}-title">{{ product.title }}</h1>

        <div class="{{ g }}-pricerow">
          <div class="{{ g }}-price" id="{{ g }}-price" data-raw="{{ fv.price }}">
            {{ fv.price | money_without_trailing_zeros }}
          </div>
        </div>

        {%- if section.settings.show_divider -%}
          <div class="{{ g }}-divider"></div>
        {%- endif -%}

        {%- if section.settings.show_description and product.description != blank -%}
          <div class="{{ g }}-desc">{{ product.description | strip_html | truncatewords: 50 }}</div>
        {%- endif -%}

        {%- if section.settings.show_variants -%}
          {%- for option in product.options_with_values -%}
            {%- assign oname = option.name | downcase -%}
            {%- assign is_color = false -%}
            {%- if oname contains 'color' or oname contains 'colour' or oname contains 'colores' or oname contains 'tono' -%}
              {%- assign is_color = true -%}
            {%- endif -%}

            <div class="{{ g }}-vgroup">
              <div class="{{ g }}-vlabel">
                {{ option.name }}
                <span class="{{ g }}-vsel" id="{{ g }}-sel-{{ forloop.index0 }}"></span>
              </div>

              {%- if is_color -%}
                <div class="{{ g }}-swatches" data-opt="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    {%- assign vd = value | downcase | replace: ' ', '' -%}
                    {%- assign vc = '#d9d9d9' -%}
                    {%- if vd == 'dorado' or vd == 'gold' or vd == 'golden' -%}
                      {%- assign vc = '#c9a96e' -%}
                    {%- elsif vd == 'champagne' -%}
                      {%- assign vc = '#f3e1c8' -%}
                    {%- elsif vd == 'plateado' or vd == 'silver' or vd == 'plata' or vd == 'acero' or vd == 'aceroinoxidable' or vd == 'steel' -%}
                      {%- assign vc = '#b0b8c1' -%}
                    {%- elsif vd == 'rosado' or vd == 'rosa' or vd == 'pink' or vd == 'rose' -%}
                      {%- assign vc = '#e8a0b4' -%}
                    {%- elsif vd == 'fucsia' or vd == 'fuchsia' -%}
                      {%- assign vc = '#d53f8c' -%}
                    {%- elsif vd == 'negro' or vd == 'black' or vd == 'negra' -%}
                      {%- assign vc = '#1c1c1e' -%}
                    {%- elsif vd == 'blanco' or vd == 'white' or vd == 'blanca' -%}
                      {%- assign vc = '#f4f4f4' -%}
                    {%- elsif vd == 'crema' or vd == 'ivory' or vd == 'marfil' -%}
                      {%- assign vc = '#f3eedf' -%}
                    {%- elsif vd == 'beige' or vd == 'nude' -%}
                      {%- assign vc = '#d8c3a5' -%}
                    {%- elsif vd == 'rojo' or vd == 'red' or vd == 'roja' -%}
                      {%- assign vc = '#d64545' -%}
                    {%- elsif vd == 'azul' or vd == 'blue' or vd == 'celeste' -%}
                      {%- assign vc = '#3182ce' -%}
                    {%- elsif vd == 'verde' or vd == 'green' -%}
                      {%- assign vc = '#38a169' -%}
                    {%- elsif vd == 'bronce' or vd == 'bronze' -%}
                      {%- assign vc = '#cd7f32' -%}
                    {%- elsif vd == 'cobre' or vd == 'copper' -%}
                      {%- assign vc = '#b87333' -%}
                    {%- elsif vd == 'marron' or vd == 'marrón' or vd == 'brown' or vd == 'cafe' or vd == 'café' -%}
                      {%- assign vc = '#8B5E3C' -%}
                    {%- elsif vd == 'morado' or vd == 'violeta' or vd == 'purple' or vd == 'lila' -%}
                      {%- assign vc = '#805ad5' -%}
                    {%- elsif vd == 'naranja' or vd == 'orange' -%}
                      {%- assign vc = '#ed8936' -%}
                    {%- elsif vd == 'gris' or vd == 'gray' or vd == 'grey' -%}
                      {%- assign vc = '#a0aec0' -%}
                    {%- elsif vd == 'multicolor' or vd == 'multi' -%}
                      {%- assign vc = 'linear-gradient(135deg,#e8a0b4 0%,#c9a96e 50%,#b0b8c1 100%)' -%}
                    {%- endif -%}

                    <button
                      type="button"
                      class="{{ g }}-swatch{% if value == option.selected_value %} active{% endif %} tin-swatch"
                      data-opt="{{ forloop.parentloop.index0 }}"
                      data-val="{{ value | escape }}"
                      title="{{ value | escape }}"
                      aria-label="{{ value | escape }}"
                      style="background:{{ vc }};"></button>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <div class="{{ g }}-vopts" data-opt="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="{{ g }}-vopt{% if value == option.selected_value %} active{% endif %} tin-vopt"
                      data-opt="{{ forloop.parentloop.index0 }}"
                      data-val="{{ value | escape }}">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endif -%}

        {%- if section.settings.show_stock -%}
          <div class="{{ g }}-stock" id="{{ g }}-stock">
            <span class="{{ g }}-stock-dot"></span>
<span id="{{ g }}-stock-text">
  {%- if fv.available -%}
    Disponible
  {%- else -%}
    Agotado
  {%- endif -%}
</span>
          </div>
        {%- endif -%}

        <script type="application/json" id="{{ g }}-variants-json">
[
  {%- for variant in product.variants -%}
    {
      "id": {{ variant.id | json }},
      "title": {{ variant.title | json }},
      "available": {{ variant.available | json }},
      "price": {{ variant.price | json }},
      "options": {{ variant.options | json }},
      "inventory_quantity": {{ variant.inventory_quantity | default: 0 | json }},
      "inventory_management": {{ variant.inventory_management | json }},
      "image_src": {%- if variant.featured_image -%}
        {{ variant.featured_image | image_url: width: 1400 | json }}
      {%- elsif variant.featured_media and variant.featured_media.preview_image -%}
        {{ variant.featured_media.preview_image | image_url: width: 1400 | json }}
      {%- else -%}
        null
      {%- endif -%},
      "image_id": {%- if variant.featured_image -%}
        {{ variant.featured_image.id | json }}
      {%- elsif variant.featured_media -%}
        {{ variant.featured_media.id | json }}
      {%- else -%}
        null
      {%- endif -%}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
        </script>

        <script type="application/json" id="{{ g }}-images-json">{{ product.images | json }}</script>

        <div class="{{ g }}-actions" id="{{ g }}-actions">
          <button type="button" class="{{ g }}-btn {{ g }}-btn-primary" id="{{ g }}-atc">
            {{ section.settings.add_to_cart_text }}
          </button>

          <button type="button" class="{{ g }}-btn {{ g }}-btn-secondary" id="{{ g }}-buynow">
            {{ section.settings.buy_now_text }}
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="{{ g }}-lb" id="{{ g }}-lb">
    <img id="{{ g }}-lb-img" alt="Imagen ampliada" width="1400" height="1400">
    <button type="button" class="{{ g }}-lb-close" id="{{ g }}-lb-close" aria-label="Cerrar">✕</button>
  </div>

  <div class="{{ g }}-toast" id="{{ g }}-toast" role="status" aria-live="polite"></div>
</div>

<script>
(function(){
  'use strict';

  const G = {{ g | json }};
  const ROOT = document.getElementById('{{ g }}-root');
  const PRODUCT_ID = {{ product.id }};
  const FALLBACK_IMAGE = {{ product.featured_image | image_url: width: 900 | json }};
  const UPDATE_URL = {{ section.settings.update_url | json }};
  const TXT_ATC = {{ section.settings.add_to_cart_text | json }};
  const TXT_BUY = {{ section.settings.buy_now_text | json }};
  const TXT_BADGE_AVAILABLE = {{ section.settings.badge_available_text | json }};
  const TXT_BADGE_SOLD = {{ section.settings.badge_sold_text | json }};

  if(!ROOT) return;

  let VARIANTS = [];
  let IMAGES = [];
  let selectedOpts = {};
  let currentImgIdx = 0;
  let toastTimer = null;

  try {
    VARIANTS = JSON.parse(document.getElementById('{{ g }}-variants-json').textContent || '[]');
  } catch(e) {
    VARIANTS = [];
  }

  try {
    IMAGES = JSON.parse(document.getElementById('{{ g }}-images-json').textContent || '[]');
  } catch(e) {
    IMAGES = [];
  }

  const $ = id => document.getElementById(id);
  const $$ = (sel, root) => Array.from((root || ROOT).querySelectorAll(sel));

  const mainImg = $('{{ g }}-mainimg');
  const imgbox = $('{{ g }}-imgbox');
  const dots = $('{{ g }}-dots');
  const thumbs = $('{{ g }}-thumbs');
  const lb = $('{{ g }}-lb');
  const lbImg = $('{{ g }}-lb-img');
  const toast = $('{{ g }}-toast');

  const imgList = (IMAGES || []).filter(img => img && img.src);
  const hasMultipleImages = imgList.length > 1;

  function normalizeText(value){
    return String(value || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g,'')
      .trim();
  }

  function fmtPY(cents){
    const amount = Math.round((parseInt(cents, 10) || 0) / 100);
    return 'Gs. ' + amount.toLocaleString('es-PY').replace(/,/g,'.');
  }

  function normalizeImageUrl(src, width){
    if(!src) return '';
    let clean = String(src).replace(/&amp;/g, '&');

    if(clean.startsWith('//')) {
      clean = 'https:' + clean;
    }

    clean = clean.replace(/\?.*$/, '');

    if(clean.indexOf('cdn.shopify.com') !== -1) {
      clean = clean.replace(/_(\d+x\d+|\d+x|x\d+|master|large|grande|medium|small|compact|thumb)(\.[^.]+)$/i, '$2');
    }

    return clean + '?width=' + (width || 900);
  }

  function baseImage(src){
    if(!src) return '';
    let clean = String(src).replace(/&amp;/g, '&');

    if(clean.startsWith('//')) {
      clean = 'https:' + clean;
    }

    clean = clean.replace(/\?.*$/, '');
    clean = clean.replace(/_(\d+x\d+|\d+x|x\d+|master|large|grande|medium|small|compact|thumb)(\.[^.]+)$/i, '$2');

    return clean;
  }

  function preloadImage(src){
    if(!src) return;
    const image = new Image();
    image.decoding = 'async';
    image.src = src;
  }

  function showToast(message, isError){
    if(!toast) return;

    toast.textContent = message || '';
    toast.classList.toggle('error', !!isError);
    toast.classList.add('show');

    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => {
      toast.classList.remove('show');
      toast.classList.remove('error');
    }, isError ? 2600 : 1900);
  }

  function initSelectedOptions(){
    const firstAvailable = VARIANTS.find(v => v && v.available);
    const selectedVariant =
      VARIANTS.find(v => Number(v.id) === Number({{ fv.id | json }})) ||
      firstAvailable ||
      VARIANTS[0] ||
      null;

    if(selectedVariant && selectedVariant.options) {
      selectedVariant.options.forEach((opt, index) => {
        selectedOpts[index] = opt;
      });
    }

    syncSelectedLabels();
    syncActiveButtons();
  }

  function findExactVariant(){
    return VARIANTS.find(v => {
      if(!v || !Array.isArray(v.options)) return false;
      return v.options.every((opt, index) => selectedOpts[index] === opt);
    }) || null;
  }

  function findBestVariant(changedIndex, changedValue){
    const exact = findExactVariant();
    if(exact) return exact;

    let match = VARIANTS.find(v => {
      if(!v || !v.available || !Array.isArray(v.options)) return false;

      return v.options.every((opt, index) => {
        if(index === changedIndex) return opt === changedValue;
        return !selectedOpts[index] || opt === selectedOpts[index];
      });
    });

    if(match) return match;

    match = VARIANTS.find(v => {
      return v && Array.isArray(v.options) && v.options[changedIndex] === changedValue;
    });

    return match || null;
  }

  function getSelectedVariant(){
    return findExactVariant() || VARIANTS.find(v => v && Number(v.id) === Number({{ fv.id | json }})) || VARIANTS[0] || null;
  }

function syncSelectedLabels(){
  Object.keys(selectedOpts).forEach(index => {
    const label = $('{{ g }}-sel-' + index);
    if(label) {
      label.textContent = '';
    }
  });
}

  function syncActiveButtons(){
    $$('.tin-vopt, .tin-swatch').forEach(btn => {
      const idx = parseInt(btn.dataset.opt, 10);
      const val = btn.dataset.val;
      btn.classList.toggle('active', selectedOpts[idx] === val);
      btn.setAttribute('aria-selected', selectedOpts[idx] === val ? 'true' : 'false');
    });
  }

  function markUnavailableOptions(){
    $$('.tin-vopt, .tin-swatch').forEach(btn => {
      const idx = parseInt(btn.dataset.opt, 10);
      const val = btn.dataset.val;
      const testOpts = Object.assign({}, selectedOpts);
      testOpts[idx] = val;

      const ok = VARIANTS.some(v => {
        if(!v || !v.available || !Array.isArray(v.options)) return false;

        return v.options.every((opt, index) => {
          return !testOpts[index] || opt === testOpts[index];
        });
      });

      btn.classList.toggle('unavail', !ok);
      btn.setAttribute('aria-disabled', 'false');
      btn.disabled = false;
    });
  }

  function buildDots(){
    if(!dots || !hasMultipleImages) return;

    dots.innerHTML = '';

    imgList.forEach((_, index) => {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.className = '{{ g }}-dot' + (index === currentImgIdx ? ' active' : '');
      dot.setAttribute('aria-label', 'Imagen ' + (index + 1));
      dot.addEventListener('click', () => goImg(index));
      dots.appendChild(dot);
    });
  }

  function updateImageUI(){
    $$('.{{ g }}-dot').forEach((dot, index) => {
      dot.classList.toggle('active', index === currentImgIdx);
    });

    $$('.{{ g }}-thumb').forEach((thumb, index) => {
      thumb.classList.toggle('active', index === currentImgIdx);
    });
  }

  function setMainImageByUrl(src, imgId){
    if(!src || !mainImg) return;

    const url480 = normalizeImageUrl(src, 480);
    const url900 = normalizeImageUrl(src, 900);
    const url1400 = normalizeImageUrl(src, 1400);

    mainImg.classList.add('tin-loading');

    preloadImage(url900);

    mainImg.removeAttribute('srcset');
    mainImg.setAttribute('src', url900);
    mainImg.setAttribute('srcset', url480 + ' 480w, ' + url900 + ' 900w, ' + url1400 + ' 1400w');
    mainImg.setAttribute('sizes', '(max-width:768px) 100vw, 55vw');

    const preloader = new Image();

    preloader.onload = () => {
      mainImg.classList.remove('tin-loading');
    };

    preloader.onerror = () => {
      mainImg.classList.remove('tin-loading');
    };

    preloader.src = url900;

    let index = -1;

    if(imgId !== undefined && imgId !== null) {
      index = imgList.findIndex(img => String(img.id) === String(imgId));
    }

    if(index < 0) {
      index = imgList.findIndex(img => baseImage(img.src) === baseImage(src));
    }

    if(index >= 0) {
      currentImgIdx = index;
    }

    updateImageUI();
  }

  function goImg(index){
    if(!imgList[index] || !imgList[index].src) return;
    currentImgIdx = index;
    setMainImageByUrl(imgList[index].src, imgList[index].id);
  }

  function findVariantImage(variant){
    if(!variant) return { src: '', id: null };

    let src = variant.image_src || '';
    let id = variant.image_id || null;

    if(src) return { src: src, id: id };

    const colorOptionIndexes = [];

    {%- for option in product.options_with_values -%}
      {%- assign oname = option.name | downcase -%}
      {%- if oname == 'color' or oname == 'colour' or oname contains 'colores' or oname contains 'tono' -%}
        colorOptionIndexes.push({{ forloop.index0 }});
      {%- endif -%}
    {%- endfor -%}

    const selectedWords = colorOptionIndexes
      .map(index => selectedOpts[index])
      .filter(Boolean)
      .map(value => normalizeText(value));

    if(selectedWords.length && imgList.length) {
      const match = imgList.find(img => {
        const imgSrc = normalizeText(img.src || '');
        const imgAlt = normalizeText(img.alt || '');
        return selectedWords.some(word => imgSrc.includes(word) || imgAlt.includes(word));
      });

      if(match && match.src) {
        return { src: match.src, id: match.id || null };
      }
    }

    if(colorOptionIndexes.length && imgList.length) {
      const colorIndex = colorOptionIndexes[0];
      const variantColorValue = selectedOpts[colorIndex];

const colorValues = [
  {%- for option in product.options_with_values -%}
    {%- assign oname = option.name | downcase -%}
    {%- if oname == 'color' or oname == 'colour' or oname contains 'colores' or oname contains 'tono' -%}
      {%- for value in option.values -%}
        {{ value | json }}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
];

      const mappedIndex = colorValues.indexOf(variantColorValue);

      if(mappedIndex >= 0 && imgList[mappedIndex] && imgList[mappedIndex].src) {
        return { src: imgList[mappedIndex].src, id: imgList[mappedIndex].id || null };
      }
    }

    return { src: '', id: null };
  }

function updateStock(variant){
  const stock = $('{{ g }}-stock');
  const stockText = $('{{ g }}-stock-text');

  if(!stock || !stockText || !variant) return;

  stock.classList.remove('low', 'out');

  if(!variant.available) {
    stock.classList.add('out');
    stockText.textContent = 'Agotado';
    return;
  }

  stockText.textContent = 'Disponible';
}

  function updateBadge(variant){
    const badge = $('{{ g }}-badge');
    if(!badge || !variant) return;

    if(variant.available) {
      badge.textContent = TXT_BADGE_AVAILABLE;
      badge.className = '{{ g }}-badge {{ g }}-bavail';
    } else {
      badge.textContent = TXT_BADGE_SOLD;
      badge.className = '{{ g }}-badge {{ g }}-bsold';
    }
  }

  function syncButtons(variant){
    const atc = $('{{ g }}-atc');
    const buy = $('{{ g }}-buynow');
    const ok = !!(variant && variant.available);

    if(atc) {
      atc.disabled = !ok;
      atc.textContent = ok ? TXT_ATC : 'Agotado';
    }

    if(buy) {
      buy.disabled = !ok;
      buy.textContent = ok ? TXT_BUY : 'Agotado';
    }
  }

  function updateVariant(){
    const variant = getSelectedVariant();
    if(!variant) return;

    const priceEl = $('{{ g }}-price');

    if(priceEl) {
      priceEl.dataset.raw = variant.price;
      priceEl.textContent = fmtPY(variant.price);
    }


    updateStock(variant);
    syncButtons(variant);

    const imgData = findVariantImage(variant);

    if(imgData.src) {
      setMainImageByUrl(imgData.src, imgData.id);
    }

    if(UPDATE_URL) {
      try {
        const url = new URL(window.location.href);
        url.searchParams.set('variant', variant.id);
        window.history.replaceState({}, '', url.toString());
      } catch(e) {}
    }

    window.dispatchEvent(new CustomEvent('TinCart:variantChange', {
      detail: {
        variantId: variant.id,
        price: variant.price,
        title: {{ product.title | json }},
        available: variant.available,
        productId: PRODUCT_ID,
        variantTitle: variant.title,
        featuredImage: imgData.src || FALLBACK_IMAGE
      }
    }));
  }

  function handleOptionClick(btn){
    const optIndex = parseInt(btn.dataset.opt, 10);
    const value = btn.dataset.val;

    selectedOpts[optIndex] = value;

    const match = findBestVariant(optIndex, value);

    if(match && Array.isArray(match.options)) {
      match.options.forEach((opt, index) => {
        selectedOpts[index] = opt;
      });
    }

    syncSelectedLabels();
    syncActiveButtons();
    markUnavailableOptions();
    updateVariant();
  }

  function parseJsonResponse(response){
    return response.text().then(text => {
      let data = {};

      try {
        data = text ? JSON.parse(text) : {};
      } catch(e) {
        data = {};
      }

      if(!response.ok) {
        const message = data && data.description ? data.description : 'No se pudo completar la acción.';
        throw new Error(message);
      }

      return data;
    });
  }

  function fetchCart(){
    return fetch('/cart.js', {
      headers: {
        'X-Requested-With': 'XMLHttpRequest'
      }
    }).then(parseJsonResponse);
  }

  function addVariantToCart(variantId){
    return fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({
        id: Number(variantId),
        quantity: 1
      })
    }).then(parseJsonResponse);
  }

  function dispatchCartEvents(cart, item, variant){
    window.dispatchEvent(new CustomEvent('TinCart:updated', {
      detail: { cart: cart }
    }));

    document.dispatchEvent(new CustomEvent('cart:updated', {
      bubbles: true,
      detail: { cart: cart }
    }));

    if(item && variant) {
      window.dispatchEvent(new CustomEvent('TinCart:itemAdded', {
        detail: {
          variantId: variant.id,
          productId: PRODUCT_ID,
          title: item.product_title || {{ product.title | json }},
          variantTitle: item.variant_title || variant.title,
          price: item.price || variant.price,
          image: item.image || findVariantImage(variant).src || FALLBACK_IMAGE,
          quantity: 1,
          lineKey: item.key
        }
      }));
    }
  }

  async function handleAddToCart(){
    const button = $('{{ g }}-atc');
    const variant = getSelectedVariant();

    if(!variant || !variant.available) {
      showToast('Esta variante está agotada.', true);
      syncButtons(variant);
      return;
    }

    const originalText = button ? button.textContent : '';

    if(button) {
      button.disabled = true;
      button.classList.add('is-loading');
      button.textContent = 'Agregando...';
    }

    try {
      const item = await addVariantToCart(variant.id);
      const cart = await fetchCart();

      dispatchCartEvents(cart, item, variant);

      if(button) {
        button.classList.remove('is-loading');
        button.classList.add('is-done');
        button.textContent = '¡Agregado! 💕';
      }

      showToast('Agregado al carrito', false);

      setTimeout(() => {
        if(button) {
          button.classList.remove('is-done');
          button.textContent = originalText || TXT_ATC;
          button.disabled = false;
        }
      }, 1800);
    } catch(error) {
      if(button) {
        button.classList.remove('is-loading');
        button.classList.remove('is-done');
        button.textContent = 'Error. Reintentá';
      }

      showToast(error && error.message ? error.message : 'No se pudo agregar al carrito', true);

      setTimeout(() => {
        if(button) {
          button.textContent = originalText || TXT_ATC;
          button.disabled = false;
        }
      }, 2200);
    }
  }

  async function handleBuyNow(){
    const button = $('{{ g }}-buynow');
    const variant = getSelectedVariant();

    if(!variant || !variant.available) {
      showToast('Esta variante está agotada.', true);
      syncButtons(variant);
      return;
    }

    const originalText = button ? button.textContent : '';

    if(button) {
      button.disabled = true;
      button.classList.add('is-loading');
      button.textContent = 'Redirigiendo...';
    }

    try {
      const item = await addVariantToCart(variant.id);
      const cart = await fetchCart();

      dispatchCartEvents(cart, item, variant);

      window.location.href = '/checkout';
    } catch(error) {
      if(button) {
        button.classList.remove('is-loading');
        button.textContent = 'Error. Reintentá';
      }

      showToast(error && error.message ? error.message : 'No se pudo continuar', true);

      setTimeout(() => {
        if(button) {
          button.textContent = originalText || TXT_BUY;
          button.disabled = false;
        }
      }, 2200);
    }
  }

function initGallery(){
  const prev = $('{{ g }}-prev');
  const next = $('{{ g }}-next');

  if(!hasMultipleImages) {
    if(prev) prev.style.display = 'none';
    if(next) next.style.display = 'none';
    if(dots) dots.style.display = 'none';
    if(thumbs) thumbs.style.display = 'none';
    return;
  }

  if(prev) prev.style.display = '';
  if(next) next.style.display = '';
  if(dots) dots.style.display = '';
  if(thumbs) thumbs.style.display = '';

  buildDots();
  updateImageUI();

  function goPrevious(event){
    if(event) {
      event.preventDefault();
      event.stopPropagation();
    }

    goImg((currentImgIdx - 1 + imgList.length) % imgList.length);
  }

  function goNext(event){
    if(event) {
      event.preventDefault();
      event.stopPropagation();
    }

    goImg((currentImgIdx + 1) % imgList.length);
  }

  $$('.{{ g }}-thumb').forEach(thumb => {
    thumb.addEventListener('click', event => {
      event.preventDefault();
      event.stopPropagation();
      goImg(parseInt(thumb.dataset.idx, 10));
    });

    thumb.addEventListener('keydown', event => {
      if(event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        event.stopPropagation();
        goImg(parseInt(thumb.dataset.idx, 10));
      }
    });
  });

  if(prev) {
    prev.addEventListener('click', goPrevious);
  }

  if(next) {
    next.addEventListener('click', goNext);
  }

  let touchStartX = 0;
  let touchStartY = 0;

  if(imgbox) {
    imgbox.addEventListener('touchstart', event => {
      touchStartX = event.touches[0].clientX;
      touchStartY = event.touches[0].clientY;
    }, { passive: true });

    imgbox.addEventListener('touchend', event => {
      const diffX = touchStartX - event.changedTouches[0].clientX;
      const diffY = touchStartY - event.changedTouches[0].clientY;

      if(Math.abs(diffX) > 42 && Math.abs(diffX) > Math.abs(diffY)) {
        if(diffX > 0) {
          goNext(event);
        } else {
          goPrevious(event);
        }
      }
    }, { passive: false });
  }

  document.addEventListener('keydown', event => {
    const activeTag = document.activeElement && document.activeElement.tagName
      ? document.activeElement.tagName.toLowerCase()
      : '';

    if(activeTag === 'input' || activeTag === 'textarea' || activeTag === 'select') return;

    if(event.key === 'ArrowLeft') {
      goPrevious(event);
    }

    if(event.key === 'ArrowRight') {
      goNext(event);
    }
  });
}

  function initLightbox(){
    if(!imgbox || !lb || !lbImg || !mainImg) return;

    imgbox.addEventListener('click', event => {
      if(event.target.closest('button')) return;

      const activeImg = imgList[currentImgIdx];
      const src = activeImg && activeImg.src ? normalizeImageUrl(activeImg.src, 1600) : normalizeImageUrl(mainImg.src, 1600);

      lbImg.src = src;
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
    });

    const close = $('{{ g }}-lb-close');

    if(close) {
      close.addEventListener('click', () => {
        lb.classList.remove('open');
        document.body.style.overflow = '';
      });
    }

    lb.addEventListener('click', event => {
      if(event.target === lb) {
        lb.classList.remove('open');
        document.body.style.overflow = '';
      }
    });

    document.addEventListener('keydown', event => {
      if(event.key === 'Escape') {
        lb.classList.remove('open');
        document.body.style.overflow = '';
      }
    });
  }

  $$('.tin-vopt, .tin-swatch').forEach(btn => {
    btn.addEventListener('click', () => handleOptionClick(btn));
  });

  const atcButton = $('{{ g }}-atc');
  const buyButton = $('{{ g }}-buynow');

  if(atcButton) {
    atcButton.addEventListener('click', handleAddToCart);
  }

  if(buyButton) {
    buyButton.addEventListener('click', handleBuyNow);
  }

  window.addEventListener('TinCart:requestVariantInfo', () => updateVariant());

  initSelectedOptions();
  markUnavailableOptions();
  updateVariant();
  initGallery();
  initLightbox();
})();
</script>

