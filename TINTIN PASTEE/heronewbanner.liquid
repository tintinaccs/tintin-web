{% liquid
  assign sid = section.id | replace: '_', '-' | downcase
  assign image_position = section.settings.image_position
  assign image_alt = section.settings.title | strip_html | escape
%}

{% style %}

#tintin-about-{{ sid }} {
  --bg: {{ section.settings.bg_color }};
  --text: {{ section.settings.text_color }};
  --muted: {{ section.settings.muted_color }};
  --accent: {{ section.settings.accent_color }};
  --soft: {{ section.settings.soft_color }};
  --radius: {{ section.settings.radius }}px;
  --padding-y: {{ section.settings.padding_y }}px;
  --title-size: {{ section.settings.title_size }}px;

  display: block;
  width: 100%;
  overflow: hidden;
  background: var(--bg) !important;
  color: var(--text);
  font-family: "DM Sans", system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
}

html, body {
  background: {{ section.settings.bg_color }};
}

#tintin-about-{{ sid }} *,
#tintin-about-{{ sid }} *::before,
#tintin-about-{{ sid }} *::after {
  box-sizing: border-box;
}

#tintin-about-{{ sid }} .ta-container {
  position: relative;
  width: 100%;
  min-height: var(--hh);
  display: flex;
  align-items: center;
  overflow: hidden;
}

/* Imagen de fondo — capa absoluta */
#tintin-about-{{ sid }} .ta-image-shell {
  position: absolute;
  inset: 0;
  z-index: 0;
  opacity: 0;
  transition:
    opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}

#tintin-about-{{ sid }}.ta-visible .ta-image-shell {
  opacity: 1;
  transition-delay: 0s;
}

#tintin-about-{{ sid }}.ta-ready:not(.ta-visible) .ta-image-shell {
  opacity: 0;
  transition:
    opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  transition-delay: 0s;
}

#tintin-about-{{ sid }} .ta-image-wrap {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  background: var(--soft) !important;
}

#tintin-about-{{ sid }} .ta-image-shell {
  background: var(--soft);
}

#tintin-about-{{ sid }} .ta-container {
  background: var(--soft);
}

#tintin-about-{{ sid }} .ta-img,
#tintin-about-{{ sid }} .ta-placeholder {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

#tintin-about-{{ sid }} .ta-img {
  display: block;
  object-fit: cover;
  object-position: {{ section.settings.image_focal_x }} center;
  transform: scale(1.12);
  transition: transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform;
}

#tintin-about-{{ sid }}.ta-visible .ta-img {
  transform: scale(1);
}

#tintin-about-{{ sid }}.ta-ready:not(.ta-visible) .ta-img {
  transform: scale(1.12);
  transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}

/* Imagen desktop: visible solo en ≥991px */
#tintin-about-{{ sid }} .ta-img-desktop {
  display: block;
}
#tintin-about-{{ sid }} .ta-img-tablet {
  display: none;
}
#tintin-about-{{ sid }} .ta-img-mobile {
  display: none;
}

#tintin-about-{{ sid }} .ta-placeholder {
  background:
    radial-gradient(circle at 25% 20%, rgba(255,255,255,0.75), transparent 28%),
    linear-gradient(135deg, #fff7fa 0%, #f6dce6 45%, #edb6c8 100%);
}

/* Overlay sobre la imagen */
#tintin-about-{{ sid }} .ta-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: {{ section.settings.overlay_color }};
  opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  pointer-events: none;
}

/* Contenido encima — posicionamiento libre desktop */
#tintin-about-{{ sid }} .ta-grid {
  position: absolute;
  inset: 0;
  z-index: 2;
}

#tintin-about-{{ sid }} .ta-image-col {
  display: none;
}

#tintin-about-{{ sid }} .ta-content-col {
  position: absolute;
  z-index: 2;
  display: flex;
  flex-direction: column;
  width: min(calc(100% - 48px), var(--cw));
  top: var(--py);
  left: var(--px);
  transform: translateY(calc(var(--py) * -1));
  padding: 0;
  text-align: var(--ta);
  align-items: {% if section.settings.text_align == 'center' %}center{% elsif section.settings.text_align == 'right' %}flex-end{% else %}flex-start{% endif %};
}

#tintin-about-{{ sid }} .ta-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin: 0 0 16px;
  color: var(--accent);
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: 12px;
  line-height: 1.2;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  font-weight: 700;
}

#tintin-about-{{ sid }} .ta-eyebrow::before {
  content: "";
  width: 28px;
  height: 1.5px;
  background: currentColor;
  flex-shrink: 0;
}

#tintin-about-{{ sid }} .ta-title {
  margin: 0;
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(28px, 4.5vw, var(--title-size));
  line-height: 1.05;
  letter-spacing: 0.04em;
  font-style: normal;
  font-weight: 800;
  color: var(--text);
  text-transform: uppercase;
}

#tintin-about-{{ sid }} .ta-line {
  width: 48px;
  height: 2px;
  margin: 22px 0;
  background: var(--accent);
  opacity: 0.9;
  {% if section.settings.text_align == 'center' %}
    margin-left: auto;
    margin-right: auto;
  {% endif %}
}

#tintin-about-{{ sid }} .ta-desc {
  margin: 0;
  color: var(--muted);
  font-family: "DM Sans", system-ui, sans-serif;
  font-size: clamp(10px, 1vw, 14px);
  line-height: 1.7;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

#tintin-about-{{ sid }} .ta-points {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0;
  margin-top: 42px;
  padding: 26px 0;
}

#tintin-about-{{ sid }} .ta-point {
  padding-right: 20px;
}

#tintin-about-{{ sid }} .ta-point:last-child {
  padding-right: 0;
}

#tintin-about-{{ sid }} .ta-point-title {
  display: block;
  margin-bottom: 7px;
  font-family: var(--font-heading-family);
  font-size: clamp(24px, 2.6vw, 36px);
  line-height: 1;
  font-style: italic;
  font-weight: 300;
  color: var(--text);
}

#tintin-about-{{ sid }} .ta-point-text {
  display: block;
  color: var(--muted);
  font-size: 11px;
  line-height: 1.45;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

@keyframes ta-btn-breathe {
  0%, 100% {
    transform: translateY(0) scale(1);
  }
  50% {
    transform: translateY(-2px) scale(1.015);
  }
}

#tintin-about-{{ sid }} .ta-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: clamp(6px, 0.6vw, 10px);
  width: fit-content;
  max-width: 90%;
  margin-top: clamp(12px, 1.4vw, 18px);
  padding: clamp(10px, 1vw, 14px) clamp(22px, 2.2vw, 34px);
  border-radius: 999px;
  background: #EA7EA3;
  color: #ffffff;
  text-decoration: none;
  font-size: clamp(10px, 0.85vw, 12px);
  font-weight: 700;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  animation: ta-btn-breathe 2.8s cubic-bezier(0.45, 0, 0.55, 1) infinite;
  transition:
    transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
    background 0.35s ease,
    letter-spacing 0.4s ease,
    padding 0.4s ease;
}

#tintin-about-{{ sid }} .ta-button:hover {
  animation-play-state: paused;
  transform: translateY(-5px) scale(1.05);
  background: var(--accent);
  letter-spacing: 0.2em;
  padding: clamp(10px, 1vw, 14px) clamp(28px, 2.8vw, 42px);
}

#tintin-about-{{ sid }} .ta-arrow {
  display: inline-block;
  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
              opacity 0.3s ease;
  opacity: 0.75;
}

#tintin-about-{{ sid }} .ta-button:hover .ta-arrow {
  transform: translateX(10px) scale(1.25);
  opacity: 1;
}

/* Reveal reversible */
{% if section.settings.enable_animation %}
#tintin-about-{{ sid }}.ta-ready .ta-reveal {
  opacity: 0;
  filter: blur(5px);
  transform: translate3d(0, 40px, 0) scale(0.96);
  transition:
    opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
    filter 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform, filter;
  backface-visibility: hidden;
  pointer-events: none;
}

#tintin-about-{{ sid }}.ta-ready.ta-from-top:not(.ta-visible) .ta-reveal {
  transform: translate3d(0, -72px, 0) scale(0.98);
}

#tintin-about-{{ sid }}.ta-ready .ta-image-col.ta-reveal {
  transform: translate3d({% if image_position == 'right' %}96px{% else %}-96px{% endif %}, 0, 0) scale(0.96);
}

#tintin-about-{{ sid }}.ta-ready.ta-from-top:not(.ta-visible) .ta-image-col.ta-reveal {
  transform: translate3d({% if image_position == 'right' %}96px{% else %}-96px{% endif %}, -40px, 0) scale(0.96);
}

#tintin-about-{{ sid }}.ta-ready .ta-frame.ta-reveal {
  transform: translate3d({% if image_position == 'right' %}56px{% else %}-56px{% endif %}, 0, 0) scale(0.96);
}

#tintin-about-{{ sid }}.ta-ready.ta-visible .ta-reveal {
  opacity: 1;
  filter: blur(0);
  transform: translate3d(0, 0, 0) scale(1);
  pointer-events: auto;
  transition:
    opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
    filter 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}

/* Primera aparición — delays largos y escalonados (esperan al splash screen) */
#tintin-about-{{ sid }}.ta-ready.ta-visible:not(.ta-seen) .ta-eyebrow { transition-delay: 0.1s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible:not(.ta-seen) .ta-title { transition-delay: 0.2s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible:not(.ta-seen) .ta-line { transition-delay: 0.3s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible:not(.ta-seen) .ta-desc { transition-delay: 0.38s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible:not(.ta-seen) .ta-points { transition-delay: 0.46s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible:not(.ta-seen) .ta-button { transition-delay: 0.54s; }

/* Apariciones siguientes — rápido, parejo, sin esperar al splash */
#tintin-about-{{ sid }}.ta-ready.ta-visible.ta-seen .ta-eyebrow { transition-delay: 0.05s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible.ta-seen .ta-title { transition-delay: 0.12s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible.ta-seen .ta-line { transition-delay: 0.18s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible.ta-seen .ta-desc { transition-delay: 0.24s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible.ta-seen .ta-points { transition-delay: 0.30s; }
#tintin-about-{{ sid }}.ta-ready.ta-visible.ta-seen .ta-button { transition-delay: 0.36s; }

#tintin-about-{{ sid }}.ta-ready:not(.ta-visible) .ta-reveal {
  transition-delay: 0s;
}
{% endif %}

@media (max-width: 990px) {
  #tintin-about-{{ sid }} .ta-container {
    min-height: var(--hh-t);
  }

  /* Swap imagen tablet */
  #tintin-about-{{ sid }} .ta-img-desktop {
    display: none;
  }
  #tintin-about-{{ sid }} .ta-img-tablet {
    display: block;
  }
  #tintin-about-{{ sid }} .ta-img-mobile {
    display: none;
  }

  #tintin-about-{{ sid }} .ta-content-col {
    top: unset !important;
    left: 50% !important;
    right: unset !important;
    transform: translateX(-50%) !important;
    bottom: 60px;
    width: min(calc(100% - 48px), 500px);
    max-width: calc(100% - 48px);
    margin: 0;
    text-align: center !important;
    align-items: center !important;
  }

  #tintin-about-{{ sid }} .ta-eyebrow {
    justify-content: center !important;
  }

  #tintin-about-{{ sid }} .ta-line {
    margin-left: auto !important;
    margin-right: auto !important;
  }

  #tintin-about-{{ sid }} .ta-button {
    width: fit-content;
    min-width: 200px;
    max-width: 90%;
    margin-top: 16px;
    justify-content: center !important;
  }

  #tintin-about-{{ sid }} .ta-title {
    font-size: clamp(28px, 3vw, var(--title-size));
  }

  #tintin-about-{{ sid }} .ta-points {
    grid-template-columns: 1fr;
    gap: 18px;
    padding: 24px 0;
  }

  #tintin-about-{{ sid }} .ta-point {
    padding-right: 0;
    padding-bottom: 18px;
  }

  #tintin-about-{{ sid }} .ta-point:last-child {
    padding-bottom: 0;
  }
}

@media (max-width: 767px) {
  /* Swap imagen móvil */
  #tintin-about-{{ sid }} .ta-img-desktop {
    display: none;
  }
  #tintin-about-{{ sid }} .ta-img-tablet {
    display: none;
  }
  #tintin-about-{{ sid }} .ta-img-mobile {
    display: block;
  }

  #tintin-about-{{ sid }} .ta-container {
    min-height: var(--hh-m);
  }

  #tintin-about-{{ sid }} .ta-content-col {
    left: 50%;
    transform: translateX(-50%);
    width: min(calc(100% - 32px), var(--cw-m));
    text-align: center;
    top: unset;
    {% if section.settings.valign_mobile == 'top' %}
      top: 40px;
      bottom: unset;
    {% elsif section.settings.valign_mobile == 'center' %}
      top: 50%;
      transform: translateX(-50%) translateY(-50%);
      bottom: unset;
    {% else %}
      bottom: 90px;
      top: unset;
    {% endif %}
    align-items: center;
  }

  #tintin-about-{{ sid }} .ta-eyebrow {
    justify-content: center;
  }

  #tintin-about-{{ sid }} .ta-eyebrow::before {
    order: -1;
  }

  #tintin-about-{{ sid }} .ta-title {
    font-size: clamp(32px, 9vw, 52px);
  }

  #tintin-about-{{ sid }} .ta-desc {
    font-size: 13px;
  }

  #tintin-about-{{ sid }} .ta-button {
    width: fit-content;
    min-width: 180px;
    max-width: 90%;
    justify-content: center;
  }

  #tintin-about-{{ sid }} .ta-line {
    margin-left: auto;
    margin-right: auto;
  }
}
{% endstyle %}

<section
  id="tintin-about-{{ sid }}"
  aria-label="{{ section.settings.eyebrow | default: 'HeroBanner' | escape }}"
  style="
    --hh: {{ section.settings.hero_height }}px;
    --hh-t: {{ section.settings.hero_height_tablet }}px;
    --hh-m: {{ section.settings.hero_height_mobile }}px;
    --cw: {{ section.settings.content_width }}px;
    --px: {{ section.settings.pos_x }}px;
--py: {{ section.settings.pos_y }}%;
    --ta: {{ section.settings.text_align }};
    --px-t: {{ section.settings.pos_x_tablet }}px;
    --py-t: {{ section.settings.pos_y_tablet }}%;
    --ta-t: {{ section.settings.text_align_tablet }};
    --cw-m: {{ section.settings.content_width_mobile }}px;
    --px-m: {{ section.settings.pos_x_mobile }}px;
    --py-m: {{ section.settings.pos_y_mobile }}%;
  "
>
  <div class="ta-container ta-reveal">

    <div class="ta-image-shell">
      <div class="ta-image-wrap">
            {% if section.settings.image_desktop != blank %}
              {{
                section.settings.image_desktop
                | image_url: width: 3840
                | image_tag:
                  class: 'ta-img ta-img-desktop',
                  loading: 'lazy',
                  alt: image_alt,
                  width: section.settings.image_desktop.width,
                  height: section.settings.image_desktop.height,
                  widths: '1280, 1920, 2560, 3840',
                  sizes: '100vw'
              }}
            {% elsif section.settings.image_tablet != blank or section.settings.image_mobile != blank %}
            {% else %}
              <div class="ta-placeholder ta-img-desktop" aria-hidden="true"></div>
            {% endif %}

            {% if section.settings.image_tablet != blank %}
              {{
                section.settings.image_tablet
                | image_url: width: 2800
                | image_tag:
                  class: 'ta-img ta-img-tablet',
                  loading: 'lazy',
                  alt: image_alt,
                  width: section.settings.image_tablet.width,
                  height: section.settings.image_tablet.height,
                  widths: '768, 1024, 1400, 2000, 2800',
                  sizes: '100vw'
              }}
            {% elsif section.settings.image_desktop != blank %}
              {{
                section.settings.image_desktop
                | image_url: width: 2800
                | image_tag:
                  class: 'ta-img ta-img-tablet',
                  loading: 'lazy',
                  alt: image_alt,
                  width: section.settings.image_desktop.width,
                  height: section.settings.image_desktop.height,
                  widths: '768, 1024, 1400, 2000, 2800',
                  sizes: '100vw'
              }}
            {% else %}
              <div class="ta-placeholder ta-img-tablet" aria-hidden="true"></div>
            {% endif %}

            {% if section.settings.image_mobile != blank %}
              {{
                section.settings.image_mobile
                | image_url: width: 1600
                | image_tag:
                  class: 'ta-img ta-img-mobile',
                  loading: 'lazy',
                  alt: image_alt,
                  width: section.settings.image_mobile.width,
                  height: section.settings.image_mobile.height,
                  widths: '375, 430, 768, 1080, 1600',
                  sizes: '100vw'
              }}
            {% elsif section.settings.image_desktop != blank %}
              {{
                section.settings.image_desktop
                | image_url: width: 1600
                | image_tag:
                  class: 'ta-img ta-img-mobile',
                  loading: 'lazy',
                  alt: image_alt,
                  width: section.settings.image_desktop.width,
                  height: section.settings.image_desktop.height,
                  widths: '375, 430, 768, 1080, 1600',
                  sizes: '100vw'
              }}
            {% else %}
              <div class="ta-placeholder ta-img-mobile" aria-hidden="true"></div>
            {% endif %}
          </div>
    </div>

    <div class="ta-overlay" aria-hidden="true"></div>

    <div class="ta-grid">
      <div class="ta-content-col">
        {% if section.settings.eyebrow != blank %}
          <p class="ta-eyebrow ta-reveal">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="ta-title ta-reveal">{{ section.settings.title | escape | newline_to_br }}</h2>
        {% endif %}

        <div class="ta-line ta-reveal" aria-hidden="true"></div>

        {% if section.settings.description != blank %}
          <p class="ta-desc ta-reveal">{{ section.settings.description | escape | newline_to_br }}</p>
        {% endif %}

        {% if section.settings.show_points %}
          <div class="ta-points ta-reveal">
            {% if section.settings.point_1_title != blank %}
              <div class="ta-point">
                <span class="ta-point-title">{{ section.settings.point_1_title | escape }}</span>
                <span class="ta-point-text">{{ section.settings.point_1_text | escape }}</span>
              </div>
            {% endif %}

            {% if section.settings.point_2_title != blank %}
              <div class="ta-point">
                <span class="ta-point-title">{{ section.settings.point_2_title | escape }}</span>
                <span class="ta-point-text">{{ section.settings.point_2_text | escape }}</span>
              </div>
            {% endif %}

            {% if section.settings.point_3_title != blank %}
              <div class="ta-point">
                <span class="ta-point-title">{{ section.settings.point_3_title | escape }}</span>
                <span class="ta-point-text">{{ section.settings.point_3_text | escape }}</span>
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          {% liquid
            assign is_external = false
            if section.settings.button_link contains 'http'
              assign is_external = true
            endif
          %}
          <a
            class="ta-button ta-reveal"
            href="{{ section.settings.button_link | default: '#' }}"
            {% if is_external %}target="_blank" rel="noopener noreferrer"{% endif %}
          >
            {{ section.settings.button_label | escape }}
            <span class="ta-arrow" aria-hidden="true">→</span>
          </a>
        {% endif %}
      </div>
    </div>

  </div>
</section>

{% if section.settings.enable_animation %}
<script>
(function () {
  var el = document.getElementById('tintin-about-{{ sid }}');
  if (!el) return;

  el.classList.add('ta-ready');

  var prevY = window.scrollY || 0;
  var splashDone = !document.getElementById('tsp');

  function show() {
    el.classList.add('ta-visible');
    el.classList.remove('ta-from-top', 'ta-from-bottom');
    el.classList.add('ta-seen');
  }

  if (!splashDone) {
    document.addEventListener('tintin:splash:done', function () {
      splashDone = true;
    });
  }

  function hide() {
    var y = window.scrollY || 0;
    var goingDown = y >= prevY;
    prevY = y;
    el.classList.remove('ta-visible');
    if (goingDown) {
      el.classList.add('ta-from-top');
      el.classList.remove('ta-from-bottom');
    } else {
      el.classList.add('ta-from-bottom');
      el.classList.remove('ta-from-top');
    }
  }

  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      prevY = window.scrollY || 0;
      requestAnimationFrame(function () {
        if (entries[0].isIntersecting) {
          if (splashDone || el.classList.contains('ta-seen')) {
            show();
          } else {
            document.addEventListener('tintin:splash:done', function onSplashDone() {
              document.removeEventListener('tintin:splash:done', onSplashDone);
              show();
            });
          }
        } else {
          hide();
        }
      });
    }, {
      threshold: 0.12,
      rootMargin: '0px 0px 0px 0px'
    });
    io.observe(el);
  } else {
    show();
  }

  /* Editor de Shopify */
  document.addEventListener('shopify:section:select', function (e) {
    if (e.detail && e.detail.sectionId && el.closest('[id*="' + e.detail.sectionId + '"]')) show();
  });
  document.addEventListener('shopify:section:load', function () {
    setTimeout(function () { prevY = window.scrollY || 0; }, 80);
  });
}());
</script>
{% endif %}

