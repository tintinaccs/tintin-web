{% assign g = block.id | replace: '_', '' | downcase %}

{% style %}
/* ══════════════════════════════════════════════════════
   TINTIN — CARRUSEL PREMIUM REWORK
   Responsive, accesible, animaciones fluidas, optimizado
══════════════════════════════════════════════════════ */
.tcc-{{ g }} {
  --acc:      {{ block.settings.accent_color }};
  --acc2:     {{ block.settings.accent2_color }};
  --bg:       {{ block.settings.section_bg }};
  --card-bg:  {{ block.settings.card_bg }};
  --txt:      {{ block.settings.text_color }};
  --txt2:     {{ block.settings.text_color2 }};
  --btn-bg:   {{ block.settings.btn_bg }};
  --btn-txt:  {{ block.settings.btn_txt }};
  --nav-bg:   {{ block.settings.nav_bg }};
  --nav-txt:  {{ block.settings.nav_txt }};
  --dot:      {{ block.settings.dot_color }};
  --r:        {{ block.settings.card_radius }}px;
  --gap:      {{ block.settings.card_gap }}px;
  --ease:     cubic-bezier(.4,0,.2,1);

  --section-pad-y: {{ block.settings.section_padding }}px;
  --section-pad-x: {{ block.settings.side_padding }}px;
  --card-pad: {{ block.settings.card_padding }}px;
  --title-size: {{ block.settings.title_size }}px;
  --subtitle-size: {{ block.settings.subtitle_size }}px;
  --card-title-size: {{ block.settings.card_title_size }}px;
  --card-desc-size: {{ block.settings.card_desc_size }}px;
  --nav-size: {{ block.settings.nav_size_desktop }}px;
  --nav-icon-size: {{ block.settings.nav_icon_size_desktop }}px;
  --nav-offset: clamp(6px, 1vw, 14px);
  --hover-lift: {{ block.settings.hover_lift }}px;
  --shadow-soft: {{ block.settings.shadow_strength | times: 2 }}px;
  --shadow-strong: {{ block.settings.shadow_strength | times: 3 }}px;

  display: block;
  width: 100vw;
  max-width: 100vw;
  margin-inline: calc(50% - 50vw);
  background: var(--bg);
  padding: var(--section-pad-y) 0;
  overflow: visible;
  font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* Contenedor interior */
.tcc-inner-{{ g }}{ width:100%; padding-inline:var(--section-pad-x); margin:0 auto; max-width:1440px; box-sizing:border-box; }

/* Responsive adjustments */
@media (max-width:749px){
  .tcc-{{ g }}{ --gap: {{ block.settings.card_gap_mobile }}px; --section-pad-y: {{ block.settings.section_padding_mobile }}px; --section-pad-x: {{ block.settings.side_padding_mobile }}px; --card-pad: {{ block.settings.card_padding_mobile }}px; --title-size: {{ block.settings.title_size_mobile }}px; --subtitle-size: {{ block.settings.subtitle_size_mobile }}px; --card-title-size: {{ block.settings.card_title_size_mobile }}px; --card-desc-size: {{ block.settings.card_desc_size_mobile }}px; --nav-size: {{ block.settings.nav_size_mobile }}px; --nav-icon-size: {{ block.settings.nav_icon_size_mobile }}px; }
  .tcc-hide-mobile-{{ g }}{ display:none !important; }
}
@media (min-width:750px){ .tcc-hide-desktop-{{ g }}{ display:none !important; } }

/* Header */
.tcc-head-{{ g }}{ text-align: {{ block.settings.heading_align }}; margin-bottom: clamp(16px,3vw,{{ block.settings.head_margin | plus: 10 }}px); gap:12px; display:flex; flex-direction:column; }
.tcc-title-{{ g }}{ font-size: clamp(22px, 2.8vw, var(--title-size)); font-weight:700; color:var(--acc); margin:0; line-height:1.06; }
.tcc-subtitle-{{ g }}{ font-size: clamp(13px,1.2vw,var(--subtitle-size)); color:var(--txt2); margin:0; }

/* Wrapper y track */
.tcc-wrap-{{ g }}{ position:relative; padding-inline: calc(var(--nav-size) + clamp(8px,1vw,16px)); padding-block:6px; overflow:visible; }
.tcc-track-outer-{{ g }}{ overflow:hidden; border-radius: max(6px, calc(var(--r) * 0.6)); touch-action: pan-y; -webkit-overflow-scrolling: touch; cursor: grab; user-select:none; }
.tcc-track-outer-{{ g }}.is-dragging{ cursor:grabbing; }
.tcc-track-{{ g }}{ display:flex; gap:var(--gap); transition:transform .38s var(--ease); will-change:transform; align-items:stretch; }

/* Slide sizing using calc and CSS variables (keeps layout stable) */
.tcc-slide-{{ g }}{ flex:0 0 calc((100% - var(--gap) * ({{ block.settings.slides_mobile }} - 1)) / {{ block.settings.slides_mobile }}); min-width:0; display:flex; }
@media (min-width:750px){ .tcc-slide-{{ g }}{ flex:0 0 calc((100% - var(--gap) * ({{ block.settings.slides_tablet }} - 1)) / {{ block.settings.slides_tablet }}); } }
@media (min-width:990px){ .tcc-slide-{{ g }}{ flex:0 0 calc((100% - var(--gap) * ({{ block.settings.slides_desktop }} - 1)) / {{ block.settings.slides_desktop }}); } }

/* Card base */
.tcc-card-{{ g }}{ display:flex; flex-direction:column; background:var(--card-bg); border-radius:var(--r); overflow:hidden; box-shadow: 0 8px var(--shadow-soft) rgba(15,23,42,.06); border:1px solid rgba(255,255,255,.6); transition:transform .28s var(--ease), box-shadow .28s var(--ease); text-decoration:none; color:inherit; min-height:220px; }
@media (hover:hover) and (pointer:fine){ .tcc-card-{{ g }}:hover{ transform: translateY(calc(-1 * var(--hover-lift))); box-shadow: 0 16px var(--shadow-strong) rgba(15,23,42,.09); } }

/* Image wrapper */
.tcc-img-wrap-{{ g }}{ position:relative; width:100%; padding-bottom: {{ block.settings.img_ratio }}%; background:#f7f2f4; overflow:hidden; flex-shrink:0; }
.tcc-img-{{ g }}{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transform:translateZ(0); transition:transform .45s var(--ease); pointer-events:none; user-select:none; -webkit-user-drag:none; }
@media (hover:hover) and (pointer:fine){ .tcc-card-{{ g }}:hover .tcc-img-{{ g }}{ transform:scale(1.06); } }

/* Shimmer */
.tcc-img-wrap-{{ g }}::after{ content:''; position:absolute; inset:0; background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,.32) 50%, transparent 70%); transform: translateX(-120%); transition:none; pointer-events:none; }
@media (hover:hover) and (pointer:fine){ .tcc-card-{{ g }}:hover .tcc-img-wrap-{{ g }}::after{ transform: translateX(120%); transition: transform .6s ease; } }

/* Placeholder */
.tcc-placeholder-{{ g }}{ display:flex; align-items:center; justify-content:center; inset:0; position:absolute; background:#f4ecf0; }

/* Card body variants (classic, overlay, horizontal, float) */
.tcc-body-{{ g }}{ padding: clamp(12px,1.4vw,var(--card-pad)); display:flex; flex-direction:column; gap:8px; justify-content:center; text-align: {{ block.settings.card_text_align }}; }
{% if block.settings.card_style == 'overlay' %}
.tcc-img-wrap-{{ g }}{ padding-bottom: {{ block.settings.img_ratio | plus: 20 }}%; }
.tcc-img-wrap-{{ g }}::before{ content:''; position:absolute; inset:0; background: linear-gradient(to top, rgba(0,0,0,.72) 0%, rgba(0,0,0,.22) 55%, transparent 100%); z-index:1; transition:opacity .28s ease; }
.tcc-body-{{ g }}{ position:absolute; bottom:0; left:0; right:0; z-index:2; padding: clamp(12px,1.4vw,{{ block.settings.card_padding }}px); color:#fff; transform:translateY(6px); transition:transform .32s var(--ease); }
@media (hover:hover) and (pointer:fine){ .tcc-card-{{ g }}:hover .tcc-body-{{ g }}{ transform:none; } }
.tcc-card-name-{{ g }}, .tcc-card-desc-{{ g }}{ color:#fff !important; text-shadow: 0 2px 6px rgba(0,0,0,.36); }
{% elsif block.settings.card_style == 'horizontal' %}
.tcc-card-{{ g }}{ flex-direction:row; align-items:stretch; }
.tcc-img-wrap-{{ g }}{ width:42%; padding-bottom:0; position:relative; height:auto; min-height:200px; }
.tcc-img-{{ g }}{ position:absolute; height:100%; left:0; right:0; top:0; bottom:0; }
.tcc-body-{{ g }}{ padding: clamp(12px,1.4vw,{{ block.settings.card_padding }}px); }
@media (max-width:749px){ .tcc-card-{{ g }}{ flex-direction:column; } .tcc-img-wrap-{{ g }}{ width:100%; padding-bottom:{{ block.settings.img_ratio }}%; } }
{% elsif block.settings.card_style == 'float' %}
.tcc-img-wrap-{{ g }}{ padding-bottom: {{ block.settings.img_ratio | plus: 20 }}%; }
.tcc-body-{{ g }}{ position:absolute; left:12px; right:12px; bottom:12px; z-index:2; background: rgba(255,255,255,.9); padding:10px 14px; border-radius: calc(var(--r) - 4px); backdrop-filter: blur(6px); }
.tcc-card-desc-{{ g }}, .tcc-card-btn-{{ g }}{ display:none !important; }
{% endif %}

/* Card text */
.tcc-card-name-{{ g }}{ font-size: clamp(15px,1vw,var(--card-title-size)); font-weight:600; color:var(--acc); margin:0; line-height:1.25; overflow-wrap:anywhere; }
.tcc-card-desc-{{ g }}{ font-size: clamp(12px,.9vw,var(--card-desc-size)); color:var(--txt2); margin:0; line-height:1.5; flex:1; overflow-wrap:anywhere; }

/* Button */
.tcc-card-btn-{{ g }}{ display:inline-flex; align-items:center; justify-content:center; padding:9px 18px; background:var(--btn-bg); color:var(--btn-txt); border-radius: {{ block.settings.btn_radius }}px; font-weight:600; font-size:13px; text-decoration:none; box-shadow: 0 6px 16px rgba(15,23,42,.08); align-self: flex-start; max-width:100%; }
@media (hover:hover) and (pointer:fine){ .tcc-card-btn-{{ g }}:hover{ background:var(--acc2); transform:scale(1.03); } }

/* Tilt baseline class */
.tcc-tilt-{{ g }}{ transform-style:preserve-3d; perspective:800px; }

/* Navigation arrows */
{% if block.settings.show_arrows %}
.tcc-arrow-{{ g }}{ position:absolute; top:50%; transform:translateY(-50%); width:var(--nav-size); height:var(--nav-size); border-radius:999px; background:var(--nav-bg); color:var(--nav-txt); display:flex; align-items:center; justify-content:center; z-index:5; border:1px solid rgba(255,255,255,.58); box-shadow: 0 10px 28px rgba(15,23,42,.12); transition:transform .22s var(--ease), box-shadow .22s var(--ease); cursor:pointer; }
@media (hover:hover) and (pointer:fine){ .tcc-arrow-{{ g }}:hover{ transform:translateY(calc(-50% - 2px)); box-shadow: 0 14px 32px rgba(15,23,42,.18); } }
.tcc-arrow-prev-{{ g }}{ left:var(--nav-offset); }
.tcc-arrow-next-{{ g }}{ right:var(--nav-offset); }
.tcc-arrow-{{ g }} svg{ width:var(--nav-icon-size); height:var(--nav-icon-size); }
{% endif %}

/* Dots / progress / counter */
.tcc-nav-{{ g }}{ display:flex; gap:12px; align-items:center; justify-content:center; margin-top: clamp(12px,2vw,{{ block.settings.nav_margin }}px); flex-wrap:wrap; }
{% if block.settings.show_dots %}
.tcc-dots-{{ g }}{ display:flex; gap:8px; align-items:center; padding:2px; overflow:auto; scrollbar-width:none; -ms-overflow-style:none; }
.tcc-dots-{{ g }}::-webkit-scrollbar{ display:none; }
.tcc-dot-{{ g }}{ width:8px; height:8px; border-radius:50%; background:var(--dot); opacity:.35; transition:all .25s ease; border:none; }
.tcc-dot-{{ g }}.active{ opacity:1; width:24px; border-radius:6px; background:var(--acc); }
{% endif %}

{% if block.settings.show_progress %}
.tcc-progress-wrap-{{ g }}{ width:clamp(110px,14vw,160px); height:3px; background:{{ block.settings.dot_color }}33; border-radius:2px; overflow:hidden; }
.tcc-progress-bar-{{ g }}{ height:100%; background:var(--acc); width:0%; transition:width .52s var(--ease); }
{% endif %}

{% if block.settings.show_counter %}
.tcc-counter-{{ g }}{ font-size:13px; color:var(--txt2); min-width:48px; text-align:center; font-weight:500; }
.tcc-counter-{{ g }} span{ color:var(--acc); font-weight:700; }
{% endif %}

/* Autoplay bar */
{% if block.settings.enable_autoplay and block.settings.show_autoplay_bar %}
.tcc-autoplay-bar-wrap-{{ g }}{ width:100%; height:3px; background:{{ block.settings.dot_color }}33; border-radius:2px; overflow:hidden; margin-top:12px; }
.tcc-autoplay-bar-{{ g }}{ height:100%; background:var(--acc); width:0%; transition:width linear; }
{% endif %}

/* Reduced motion */
@media (prefers-reduced-motion: reduce){
  .tcc-track-{{ g }}, .tcc-slide-{{ g }}, .tcc-card-{{ g }}, .tcc-img-{{ g }}, .tcc-body-{{ g }}, .tcc-progress-bar-{{ g }}, .tcc-autoplay-bar-{{ g }} { transition:none !important; animation:none !important; }
}

/* Small screens safety */
@media (max-width:359px){
  .tcc-inner-{{ g }}{ padding-inline:10px; }
  .tcc-card-btn-{{ g }}{ width:100%; }
}
{% endstyle %}

{%- liquid
  assign tcc_render = block.settings.show_on_other_pages
  if request.page_type == 'index'
    assign tcc_render = block.settings.show_on_home
  elsif request.page_type == 'product'
    assign tcc_render = block.settings.show_on_product
  elsif request.page_type == 'collection'
    assign tcc_render = block.settings.show_on_collection
  endif
-%}
{% if tcc_render %}
<div class="tcc-{{ g }}{% unless block.settings.show_on_mobile %} tcc-hide-mobile-{{ g }}{% endunless %}{% unless block.settings.show_on_desktop %} tcc-hide-desktop-{{ g }}{% endunless %}" id="tcc-root-{{ g }}" {{ block.shopify_attributes }}>
  <div class="tcc-inner-{{ g }}">

    {% if block.settings.title != blank or block.settings.subtitle != blank %}
    <div class="tcc-head-{{ g }}">
      {% if block.settings.title != blank %}<h2 class="tcc-title-{{ g }}">{{ block.settings.title }}</h2>{% endif %}
      {% if block.settings.subtitle != blank %}<p class="tcc-subtitle-{{ g }}">{{ block.settings.subtitle }}</p>{% endif %}
    </div>
    {% endif %}

    <div class="tcc-wrap-{{ g }}">
      {% if block.settings.show_arrows %}
      <button class="tcc-arrow-{{ g }} tcc-arrow-prev-{{ g }}" aria-label="Anterior" id="tcc-prev-{{ g }}" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="tcc-arrow-{{ g }} tcc-arrow-next-{{ g }}" aria-label="Siguiente" id="tcc-next-{{ g }}" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
      {% endif %}

      <div class="tcc-track-outer-{{ g }}" tabindex="0" role="region" aria-roledescription="carrusel" aria-label="Carrusel de colecciones">
        <div class="tcc-track-{{ g }}" id="tcc-track-{{ g }}">
          {%- assign src_cols = block.settings.collections -%}
          {%- if src_cols != blank -%}
            {%- for col in src_cols -%}
              <div class="tcc-slide-{{ g }}" data-index="{{ forloop.index0 }}">
                <a href="{{ col.url }}" class="tcc-card-{{ g }}" aria-label="{{ col.title | escape }}">
                  <div class="tcc-img-wrap-{{ g }}">
                    {%- if col.featured_image -%}
                      <img
                        class="tcc-img-{{ g }}"
                        src="{{ col.featured_image | image_url: width: 720 }}"
                        srcset="{{ col.featured_image | image_url: width: 360 }} 360w, {{ col.featured_image | image_url: width: 720 }} 720w, {{ col.featured_image | image_url: width: 1200 }} 1200w"
                        sizes="(max-width:749px) calc(100vw - 110px), (max-width:989px) calc((100vw - 150px) / {{ block.settings.slides_tablet }}), calc((100vw - 220px) / {{ block.settings.slides_desktop }})"
                        alt="{{ col.featured_image.alt | default: col.title | escape }}"
                        loading="lazy"
                        decoding="async"
                        width="720"
                        height="{{ 720 | times: block.settings.img_ratio | divided_by: 100 | round }}"
                      />
                    {%- else -%}
                      <div class="tcc-placeholder-{{ g }}">{{ 'collection-1' | placeholder_svg_tag }}</div>
                    {%- endif -%}
                  </div>

                  <div class="tcc-body-{{ g }}">
                    <h3 class="tcc-card-name-{{ g }}">{{ col.title }}</h3>
                    {% if block.settings.show_desc and col.description != blank %}
                      <p class="tcc-card-desc-{{ g }}">{{ col.description | strip_html | truncate: 90 }}</p>
                    {% endif %}
                    {% if block.settings.show_btn %}
                      <span class="tcc-card-btn-{{ g }}">{{ block.settings.btn_text }}</span>
                    {% endif %}
                  </div>
                </a>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <div class="tcc-slide-{{ g }}" data-index="{{ forloop.index0 }}">
                <a href="#" class="tcc-card-{{ g }}">
                  <div class="tcc-img-wrap-{{ g }}">
                    <div class="tcc-placeholder-{{ g }}">{{ 'collection-1' | placeholder_svg_tag }}</div>
                  </div>
                  <div class="tcc-body-{{ g }}">
                    <h3 class="tcc-card-name-{{ g }}">Colección {{ i }}</h3>
                    {% if block.settings.show_desc %}<p class="tcc-card-desc-{{ g }}">Descripción de ejemplo de la colección</p>{% endif %}
                    {% if block.settings.show_btn %}<span class="tcc-card-btn-{{ g }}">{{ block.settings.btn_text }}</span>{% endif %}
                  </div>
                </a>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>

    <div class="tcc-nav-{{ g }}">
      {% if block.settings.show_counter %}<div class="tcc-counter-{{ g }}" id="tcc-counter-{{ g }}"><span>1</span> / <span id="tcc-total-{{ g }}">1</span></div>{% endif %}
      {% if block.settings.show_dots %}<div class="tcc-dots-{{ g }}" id="tcc-dots-{{ g }}" aria-hidden="false"></div>{% endif %}
      {% if block.settings.show_progress %}<div class="tcc-progress-wrap-{{ g }}"><div class="tcc-progress-bar-{{ g }}" id="tcc-progress-{{ g }}"></div></div>{% endif %}
    </div>

    {% if block.settings.enable_autoplay and block.settings.show_autoplay_bar %}
      <div class="tcc-autoplay-bar-wrap-{{ g }}"><div class="tcc-autoplay-bar-{{ g }}" id="tcc-abar-{{ g }}"></div></div>
    {% endif %}

  </div>
</div>

<script>
(function(){
  'use strict';
  const ID = {{ g | json }};
  const root = document.getElementById('tcc-root-' + ID);
  if (!root) return;

  // Config
  const AUTOPLAY = {{ block.settings.enable_autoplay | json }};
  const AUTOPLAY_S = {{ block.settings.autoplay_speed | times:1000 }};
  const SHOW_DOTS = {{ block.settings.show_dots | json }};
  const SHOW_PROGRESS = {{ block.settings.show_progress | json }};
  const SHOW_COUNTER = {{ block.settings.show_counter | json }};
  const SHOW_ABAR = {{ block.settings.show_autoplay_bar | json }};
  const ENABLE_TILT = {{ block.settings.enable_tilt | json }};
  const SLIDES_M = Number({{ block.settings.slides_mobile | json }});
  const SLIDES_T = Number({{ block.settings.slides_tablet | json }});
  const SLIDES_D = Number({{ block.settings.slides_desktop | json }});

  // Elements (cache)
  const viewport = root.querySelector('.tcc-track-outer-' + ID);
  const track = root.querySelector('#tcc-track-' + ID);
  const prevBtn = root.querySelector('#tcc-prev-' + ID);
  const nextBtn = root.querySelector('#tcc-next-' + ID);
  const dotsEl = root.querySelector('#tcc-dots-' + ID);
  const progEl = root.querySelector('#tcc-progress-' + ID);
  const ctrEl = root.querySelector('#tcc-counter-' + ID);
  const totEl = root.querySelector('#tcc-total-' + ID);
  const abarEl = root.querySelector('#tcc-abar-' + ID);

  if (!viewport || !track) return;

  let slides = Array.from(track.children);
  if (slides.length === 0) return;
  let originalCount = slides.length;

  // State
  let perView = 1;
  let gap = 16;
  let itemW = 0;
  let clones = 0;
  let current = 0;
  let autoId = null;
  let dragging = false;
  let startX = 0, startTranslate = 0, raf = null;
  let lastPointerId = null;
  let reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Helpers
  const clamp = (v, a, b) => Math.min(Math.max(v, a), b);
  const debounce = (fn, t=120) => { let id; return (...a)=>{ clearTimeout(id); id=setTimeout(()=>fn(...a), t); }; };

  function getPerView(){
    const w = window.innerWidth;
    if (w >= 990) return Math.max(1, SLIDES_D);
    if (w >= 750) return Math.max(1, SLIDES_T);
    return Math.max(1, SLIDES_M);
  }

  function computeGap(){
    const cs = window.getComputedStyle(track);
    const g = parseFloat(cs.gap || cs.columnGap || '{{ block.settings.card_gap }}') || {{ block.settings.card_gap }};
    return g;
  }

  function measure(){
    perView = getPerView();
    gap = computeGap();
    // measure item width using the first non-clone slide
    const first = track.querySelector('.tcc-slide-{{ g }}');
    if (first){
      itemW = Math.round(first.getBoundingClientRect().width + gap);
    } else {
      itemW = Math.round(track.clientWidth / perView);
    }
  }

  function xFor(i){
    return -(i * itemW);
  }

  function setTransform(x, animate=true){
    track.style.transition = animate ? '' : 'none';
    track.style.transform = 'translate3d(' + x + 'px,0,0)';
  }

  function realIndex(i){
    const total = originalCount;
    let idx = (i - clones) % total;
    if (idx < 0) idx += total;
    return idx;
  }

  function buildClones(){
    // remove old clones
    Array.from(track.querySelectorAll('[data-clone="true"]')).forEach(n => n.remove());
    slides = Array.from(track.children).filter(n => !n.dataset.clone);
    originalCount = slides.length;
    if (originalCount <= 1) { clones = 0; return; }

    perView = getPerView();
    clones = Math.min(originalCount, Math.max(perView + 1, 2));
    const fragBefore = document.createDocumentFragment();
    const fragAfter = document.createDocumentFragment();

    for (let i = originalCount - clones; i < originalCount; i++){
      const node = slides[(i+originalCount)%originalCount].cloneNode(true);
      node.setAttribute('data-clone','true');
      fragBefore.appendChild(node);
    }
    for (let i = 0; i < clones; i++){
      const node = slides[i%originalCount].cloneNode(true);
      node.setAttribute('data-clone','true');
      fragAfter.appendChild(node);
    }
    track.insertBefore(fragBefore, track.firstChild);
    track.appendChild(fragAfter);
    slides = Array.from(track.children);
  }

  function goTo(index, instant=false){
    current = index;
    setTransform(xFor(current), !instant && !reducedMotion);
    updateUI();
    resetAutoplay();
  }

  function goBy(step){
    if (originalCount <= 1) return;
    current += step;
    setTransform(xFor(current), !reducedMotion);
    updateUI();
    resetAutoplay();
    // schedule infinite-loop jump after transition ends
    setTimeout(jumpIfNeeded, 400);
  }

  function jumpIfNeeded(){
    if (originalCount <= 1) return;
    if (current >= clones + originalCount || current < clones){
      current = clones + realIndex(current);
      setTransform(xFor(current), false);
    }
  }

  function updateUI(){
    const total = originalCount;
    const real = realIndex(current);

    // Counter
    if (SHOW_COUNTER && ctrEl){
      const spans = ctrEl.querySelectorAll('span');
      if (spans[0]) spans[0].textContent = (real + 1);
      if (totEl) totEl.textContent = total;
    }

    // Progress
    if (SHOW_PROGRESS && progEl){
      progEl.style.width = (((real + 1)/total)*100) + '%';
    }

    // Dots
    if (SHOW_DOTS && dotsEl){
      const btns = Array.from(dotsEl.children);
      btns.forEach((b,i)=> b.classList.toggle('active', i === real));
      // set aria-current
      btns.forEach((b,i)=> b.setAttribute('aria-current', i===real ? 'true' : 'false'));
    }
  }

  function buildDots(){
    if (!SHOW_DOTS || !dotsEl) return;
    dotsEl.innerHTML = '';
    for (let i=0;i<originalCount;i++){
      const btn = document.createElement('button');
      btn.type='button';
      btn.className = 'tcc-dot-{{ g }}' + (i===0 ? ' active' : '');
      btn.setAttribute('aria-label','Ir a la colección ' + (i+1));
      btn.setAttribute('aria-current', i===0 ? 'true' : 'false');
      btn.addEventListener('click', ()=> goTo(clones + i));
      dotsEl.appendChild(btn);
    }
  }

  // Autoplay
  function startAutoplay(){
    if (!AUTOPLAY || originalCount <= 1) return;
    stopAutoplay();
    autoId = setInterval(()=> goBy(1), AUTOPLAY_S);
    if (abarEl && SHOW_ABAR){
      abarEl.style.transition = 'none';
      abarEl.style.width = '0%';
      requestAnimationFrame(()=> { abarEl.style.transition = 'width ' + (AUTOPLAY_S/1000) + 's linear'; abarEl.style.width = '100%'; });
    }
  }
  function stopAutoplay(){
    if (autoId){ clearInterval(autoId); autoId = null; }
    if (abarEl){ abarEl.style.transition = 'none'; abarEl.style.width = '0%'; }
  }
  function resetAutoplay(){ if (AUTOPLAY) { stopAutoplay(); startAutoplay(); } }

  // Dragging with pointer events & rAF for smoothness
  function onPointerDown(e){
    if (e.pointerType === 'mouse' && e.button !== 0) return;
    if (originalCount <= 1) return;
    dragging = true;
    lastPointerId = e.pointerId;
    startX = e.clientX;
    startTranslate = xFor(current);
    viewport.classList.add('is-dragging');
    track.style.transition = 'none';
    stopAutoplay();
    if (viewport.setPointerCapture) viewport.setPointerCapture(e.pointerId);
  }

  function onPointerMove(e){
    if (!dragging || e.pointerId !== lastPointerId) return;
    const dx = e.clientX - startX;
    const newX = startTranslate + dx;
    if (raf) cancelAnimationFrame(raf);
    raf = requestAnimationFrame(()=> setTransform(newX, false));
  }

  function onPointerUp(e){
    if (!dragging || e.pointerId !== lastPointerId) return;
    dragging = false;
    viewport.classList.remove('is-dragging');
    const dx = e.clientX - startX;
    const threshold = Math.max(20, itemW * 0.18);
    const movedSlides = Math.floor(Math.abs(dx) / (itemW || 1));
    let step = 0;
    if (Math.abs(dx) > threshold) step = Math.max(1, movedSlides);
    if (step > 0){ current += (dx < 0 ? step : -step); }
    setTransform(xFor(current), true);
    updateUI();
    resetAutoplay();
    try { if (viewport.releasePointerCapture) viewport.releasePointerCapture(e.pointerId); } catch(e){}
    lastPointerId = null;
  }

  // Wheel to slide (desktop)
  let wheelAccum = 0, wheelTimeout = null;
  function onWheel(e){
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
    const delta = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
    if (Math.abs(delta) < 12) return;
    e.preventDefault();
    wheelAccum += delta;
    clearTimeout(wheelTimeout);
    wheelTimeout = setTimeout(()=>{
      const step = Math.max(1, Math.round(Math.abs(wheelAccum)/140));
      goBy(wheelAccum > 0 ? step : -step);
      wheelAccum = 0;
    }, 80);
  }

  // Keyboard
  function onKey(e){
    if (['ArrowLeft','ArrowRight'].includes(e.key)){
      e.preventDefault();
      if (e.key === 'ArrowLeft') goBy(-1);
      else goBy(1);
    }
  }

  // Reveal (IntersectionObserver) for nice staggered reveal
  function initReveal(){
    const targets = track.querySelectorAll('.tcc-slide-{{ g }}');
    if (!('IntersectionObserver' in window)){
      targets.forEach(t => t.classList.add('tcc-visible-{{ g }}'));
      return;
    }
    const io = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry=>{
        if (entry.isIntersecting){
          entry.target.classList.add('tcc-visible-{{ g }}');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    targets.forEach(t => io.observe(t));
  }

  // Optional tilt effect (lightweight)
  function initTilt(){
    if (!ENABLE_TILT || window.matchMedia('(hover: none)').matches || reducedMotion) return;
    track.querySelectorAll('.tcc-card-{{ g }}').forEach(card=>{
      let rafId = null;
      card.addEventListener('mousemove', (e)=>{
        if (rafId) cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(()=>{
          const r = card.getBoundingClientRect();
          const dx = (e.clientX - r.left)/r.width - 0.5;
          const dy = (e.clientY - r.top)/r.height - 0.5;
          const rx = dy * -4;
          const ry = dx * 6;
          card.style.transform = `translateY(-4px) rotateX(${rx}deg) rotateY(${ry}deg)`;
        });
      }, { passive:true });
      card.addEventListener('mouseleave', ()=>{ if (rafId) cancelAnimationFrame(rafId); card.style.transform = ''; });
    });
  }

  // Initialize all
  function init(){
    buildClones();
    measure();
    // set initial current to clones
    current = clones;
    setTransform(xFor(current), false);
    // set sizes again after layout
    setTimeout(()=> { measure(); setTransform(xFor(current), false); }, 60);
    // UI
    if (SHOW_DOTS) buildDots();
    updateUI();
    initReveal();
    initTilt();
    if (prevBtn) prevBtn.addEventListener('click', ()=> goBy(-1));
    if (nextBtn) nextBtn.addEventListener('click', ()=> goBy(1));
    viewport.addEventListener('pointerdown', onPointerDown, { passive:false });
    viewport.addEventListener('pointermove', onPointerMove, { passive:true });
    viewport.addEventListener('pointerup', onPointerUp);
    viewport.addEventListener('pointercancel', onPointerUp);
    viewport.addEventListener('dragstart', e => e.preventDefault());
    viewport.addEventListener('keydown', onKey);
    viewport.addEventListener('wheel', onWheel, { passive:false });
    // accessibility focus outline
    viewport.addEventListener('focusin', stopAutoplay);
    viewport.addEventListener('focusout', resetAutoplay);
    document.addEventListener('visibilitychange', ()=> document.hidden ? stopAutoplay() : startAutoplay());
    window.addEventListener('blur', ()=> { if (document.activeElement === viewport) stopAutoplay(); });
    // resize: use ResizeObserver if available for better performance
    const roHandler = debounce(()=>{ buildClones(); measure(); setTransform(xFor(current), false); updateUI(); resetAutoplay(); }, 120);
    if ('ResizeObserver' in window){
      const ro = new ResizeObserver(roHandler);
      ro.observe(root);
    } else {
      window.addEventListener('resize', roHandler);
    }
    // start autoplay if enabled
    startAutoplay();
  }

  // Accessibility: allow focusing the viewport
  viewport.setAttribute('tabindex', '0');

  // Start
  init();

  // cleanup on section unload (Shopify editor)
  root.addEventListener('shopify:section:unload', ()=>{ stopAutoplay(); try{ viewport.removeEventListener('pointerdown', onPointerDown); }catch(e){} });
})();
</script>
