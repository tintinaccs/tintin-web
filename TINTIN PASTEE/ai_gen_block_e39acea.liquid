    {
      "type": "header",
      "content": "Espaciado (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Espaciado (móvil)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding superior",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding inferior",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Ancho máximo del contenido",
      "min": 500,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radio de esquinas (botón)",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Título"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "GAFAS"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño del título (desktop)",
      "min": 24,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Tamaño del título (móvil)",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "title_weight",
      "label": "Grosor del título",
      "min": 300,
      "max": 700,
      "step": 100,
      "default": 600
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "label": "Espaciado de letras",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "header",
      "content": "Línea decorativa"
    },
    {
