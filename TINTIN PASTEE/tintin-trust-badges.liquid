{% liquid
  assign sid = section.id | replace: '_', '-' | downcase
%}

<style>
#ttb-{{ sid }} {
  width: 100%;
  background: {{ section.settings.bg_color }};
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
}

#ttb-{{ sid }} .ttb-inner {
  max-width: var(--page-width, 1200px);
  margin: 0 auto;
  padding: 0 clamp(16px, 4vw, 48px);
}

#ttb-{{ sid }} .ttb-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}

#ttb-{{ sid }} .ttb-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  text-align: center;
  padding: clamp(16px, 2vw, 28px) clamp(12px, 1.5vw, 24px);
  position: relative;
  opacity: 0;
  transform: translateY(20px);
  transition:
    opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
}

#ttb-{{ sid }} .ttb-item.ttb-visible {
  opacity: 1;
  transform: translateY(0);
}

#ttb-{{ sid }} .ttb-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 1px;
  background: rgba(234, 126, 163, 0.2);
}

#ttb-{{ sid }} .ttb-icon-wrap {
  width: clamp(48px, 5vw, 64px);
  height: clamp(48px, 5vw, 64px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14px;
  color: {{ section.settings.icon_color }};
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

#ttb-{{ sid }} .ttb-item:hover .ttb-icon-wrap {
  transform: translateY(-4px) scale(1.1);
}

#ttb-{{ sid }} .ttb-icon-wrap svg {
  width: 100%;
  height: 100%;
  stroke: currentColor;
  fill: none;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

#ttb-{{ sid }} .ttb-title {
  font-size: clamp(11px, 1vw, 13px);
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: {{ section.settings.title_color }};
  margin: 0 0 6px;
  line-height: 1.2;
}

#ttb-{{ sid }} .ttb-desc {
  font-size: clamp(10px, 0.85vw, 12px);
  font-weight: 500;
  letter-spacing: 0.04em;
  color: {{ section.settings.desc_color }};
  margin: 0;
  line-height: 1.5;
}

/* Delays escalonados */
#ttb-{{ sid }} .ttb-item:nth-child(1) { transition-delay: 0.05s; }
#ttb-{{ sid }} .ttb-item:nth-child(2) { transition-delay: 0.12s; }
#ttb-{{ sid }} .ttb-item:nth-child(3) { transition-delay: 0.19s; }
#ttb-{{ sid }} .ttb-item:nth-child(4) { transition-delay: 0.26s; }

/* Tablet */
@media (max-width: 768px) {
  #ttb-{{ sid }} .ttb-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }

  #ttb-{{ sid }} .ttb-item:nth-child(2)::after {
    display: none;
  }

  #ttb-{{ sid }} .ttb-item:nth-child(odd):not(:nth-child(4))::after {
    display: block;
  }

  #ttb-{{ sid }} .ttb-item:nth-child(even)::after {
    display: none;
  }

  #ttb-{{ sid }} .ttb-item:nth-child(1),
  #ttb-{{ sid }} .ttb-item:nth-child(2) {
    border-bottom: 1px solid rgba(234, 126, 163, 0.15);
  }
}

@media (max-width: 479px) {
  #ttb-{{ sid }} .ttb-item {
    padding: 20px 8px;
  }
}

@media (prefers-reduced-motion: reduce) {
  #ttb-{{ sid }} .ttb-item {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }
}
</style>

<section id="ttb-{{ sid }}">
  <div class="ttb-inner">
    <div class="ttb-grid">

      {%- comment -%} Badge 1 {%- endcomment -%}
      <div class="ttb-item">
        <div class="ttb-icon-wrap">
          <svg viewBox="0 0 24 24">
            <rect x="1" y="3" width="15" height="13" rx="2"/>
            <path d="M16 8h4l3 5v3h-7V8z"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
        </div>
        <p class="ttb-title">{{ section.settings.badge1_title }}</p>
        <p class="ttb-desc">{{ section.settings.badge1_desc }}</p>
      </div>

      {%- comment -%} Badge 2 {%- endcomment -%}
      <div class="ttb-item">
        <div class="ttb-icon-wrap">
          <svg viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <p class="ttb-title">{{ section.settings.badge2_title }}</p>
        <p class="ttb-desc">{{ section.settings.badge2_desc }}</p>
      </div>

      {%- comment -%} Badge 3 {%- endcomment -%}
      <div class="ttb-item">
        <div class="ttb-icon-wrap">
          <svg viewBox="0 0 24 24">
            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
            <line x1="1" y1="10" x2="23" y2="10"/>
          </svg>
        </div>
        <p class="ttb-title">{{ section.settings.badge3_title }}</p>
        <p class="ttb-desc">{{ section.settings.badge3_desc }}</p>
      </div>

      {%- comment -%} Badge 4 {%- endcomment -%}
      <div class="ttb-item">
        <div class="ttb-icon-wrap">
          <svg viewBox="0 0 24 24">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <p class="ttb-title">{{ section.settings.badge4_title }}</p>
        <p class="ttb-desc">{{ section.settings.badge4_desc }}</p>
      </div>

    </div>
  </div>
</section>

<script>
(function(){
  var section = document.getElementById('ttb-{{ sid }}');
  if (!section) return;

  var items = section.querySelectorAll('.ttb-item');

  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries, obs) {
      if (entries[0].isIntersecting) {
        items.forEach(function(item) {
          item.classList.add('ttb-visible');
        });
        obs.disconnect();
      }
    }, { threshold: 0.15 });
    io.observe(section);
  } else {
    items.forEach(function(item) {
      item.classList.add('ttb-visible');
    });
  }
})();
</script>

