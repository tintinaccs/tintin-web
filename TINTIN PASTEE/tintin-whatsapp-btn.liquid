{% comment %} ── WhatsApp Button – Tintin Accesorios ── {% endcomment %}

{%- assign wa_number = '595981299331' -%}
{%- assign wa_message = 'Hola! Me interesa saber más sobre sus productos 🌸' -%}

<a
  id="ttn-wa-btn"
  href="https://wa.me/{{ wa_number }}?text={{ wa_message | url_encode }}"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<style>
  #ttn-wa-btn {
    position: fixed;
    bottom: 28px;
    right: 24px;
    z-index: 997;
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: #25D366;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
    text-decoration: none;
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.35s ease,
      bottom 0.32s cubic-bezier(0.22, 1, 0.36, 1),
      width 0.32s cubic-bezier(0.22, 1, 0.36, 1),
      height 0.32s cubic-bezier(0.22, 1, 0.36, 1);
    animation: ttn-wa-breathe 2.6s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    will-change: transform;
  }

  #ttn-wa-btn:hover {
    animation-play-state: paused;
    transform: translateY(-4px) scale(1.08);
    box-shadow: 0 10px 32px rgba(37, 211, 102, 0.55);
  }

  @keyframes ttn-wa-breathe {
    0%, 100% {
      transform: translateY(0) scale(1);
      box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
    }
    50% {
      transform: translateY(-3px) scale(1.04);
      box-shadow: 0 8px 28px rgba(37, 211, 102, 0.6),
                  0 0 0 6px rgba(37, 211, 102, 0.1);
    }
  }

  /* ── Mobile: encima del nav ── */
  @media (max-width: 768px) {
    #ttn-wa-btn {
      bottom: 100px;
      right: 18px;
      width: 48px;
      height: 48px;
    }

    /* Cuando el nav se achica (clase .compact), el botón sube menos */
    body.ttn-wa-compact #ttn-wa-btn {
      bottom: 78px;
      width: 42px;
      height: 42px;
    }

    body.ttn-wa-compact #ttn-wa-btn svg {
      width: 22px;
      height: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #ttn-wa-btn {
      animation: none !important;
    }
  }
</style>

<script>
(function () {
  /* Sincroniza tamaño con el nav compact del header mobile */
  var nav = document.querySelector('[class*="ai-mobile-header-bottom-nav-"]');
  if (!nav) return;

  var observer = new MutationObserver(function () {
    if (nav.classList.contains('compact')) {
      document.body.classList.add('ttn-wa-compact');
    } else {
      document.body.classList.remove('ttn-wa-compact');
    }
  });

  observer.observe(nav, { attributes: true, attributeFilter: ['class'] });
})();
</script>