{% comment %}
  ╔══════════════════════════════════════════════════════╗
  ║  TINTIN — Sticky Bar Detalle Producto               ║
  ║  Archivo: tintin-sticky-bar-detalle.liquid           ║
  ║  Uso: Sección independiente para plantilla producto  ║
  ║  Sincroniza con: TinCart:variantChange / TinCart:updated
  ╚══════════════════════════════════════════════════════╝
{% endcomment %}

{%- assign g = section.id | replace: '_', '' | replace: '-', '' | downcase -%}
{%- assign fv = product.selected_or_first_available_variant -%}
{%- assign initial_img = fv.featured_image | default: product.featured_image -%}

{% style %}
.tin-sticky-{{ g }}{
  --tin-acc: {{ section.settings.accent_color }};
  --tin-bg: {{ section.settings.background_color }};
  --tin-card: {{ section.settings.card_color }};
  --tin-fg: {{ section.settings.text_color }};
  --tin-muted: {{ section.settings.text_color }}99;
  --tin-btn: {{ section.settings.primary_button_color }};
  --tin-btn-t: {{ section.settings.primary_button_text_color }};
  --tin-border: rgba(212,120,154,.20);
  --tin-shadow: 0 14px 44px rgba(0,0,0,.12), 0 4px 16px rgba(0,0,0,.06);
  position:fixed;
  left:0;
  right:0;
  bottom:calc(env(safe-area-inset-bottom,0px) + {{ section.settings.bottom_offset_desktop }}px);
  z-index:{{ section.settings.z_index }};
  padding:0 clamp(12px,3vw,36px);
  pointer-events:none;
  color:var(--tin-fg);
  font-family:inherit;
}
.tin-sticky-{{ g }} *{ box-sizing:border-box; }
.tin-sticky-{{ g }}[data-hidden="true"] .tin-sticky__bar-{{ g }}{
  transform:translateY(calc(100% + 24px));
  opacity:0;
  pointer-events:none;
}
.tin-sticky__bar-{{ g }}{
  width:100%;
  max-width:{{ section.settings.max_width }}px;
  margin:0 auto;
  min-height:72px;
  display:grid;
  grid-template-columns:minmax(0,1fr) auto auto;
  align-items:center;
  gap:14px;
  background:color-mix(in srgb, var(--tin-card) 94%, transparent);
  border:1px solid var(--tin-border);
  border-radius:{{ section.settings.border_radius }}px;
  box-shadow:var(--tin-shadow);
  padding:10px 10px 10px 14px;
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
  pointer-events:all;
  transition:transform .24s cubic-bezier(.4,0,.2,1), opacity .22s ease, box-shadow .22s ease;
}
.tin-sticky__product-{{ g }}{
  display:grid;
  grid-template-columns:52px minmax(0,1fr);
  align-items:center;
  gap:12px;
  min-width:0;
}
.tin-sticky__img-{{ g }}{
  width:52px;
  height:52px;
  border-radius:16px;
  overflow:hidden;
  background:#fff;
  border:1px solid rgba(212,120,154,.14);
  flex-shrink:0;
}
.tin-sticky__img-{{ g }} img{
  width:100%;
  height:100%;
  display:block;
  object-fit:cover;
}
.tin-sticky__meta-{{ g }}{
  min-width:0;
  display:flex;
  flex-direction:column;
  gap:3px;
}
.tin-sticky__label-{{ g }}{
  font-size:10px;
  text-transform:uppercase;
  letter-spacing:.10em;
  color:var(--tin-muted);
  font-weight:700;
  line-height:1;
}
.tin-sticky__title-{{ g }}{
  margin:0;
  font-size:14px;
  line-height:1.22;
  color:var(--tin-fg);
  font-weight:700;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
.tin-sticky__variant-{{ g }}{
  font-size:12px;
  color:var(--tin-muted);
  line-height:1.2;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
.tin-sticky__pricebox-{{ g }}{
  display:flex;
  flex-direction:column;
  align-items:flex-end;
  justify-content:center;
  min-width:112px;
  gap:3px;
}
.tin-sticky__stock-{{ g }}{
  display:flex;
  align-items:center;
  gap:6px;
  font-size:11px;
  color:var(--tin-muted);
  white-space:nowrap;
  font-weight:650;
}
.tin-sticky__dot-{{ g }}{
  width:7px;
  height:7px;
  border-radius:50%;
  display:inline-block;
  background:var(--tin-acc);
}
.tin-sticky__stock-{{ g }}.is-low .tin-sticky__dot-{{ g }}{ background:#ed8936; }
.tin-sticky__stock-{{ g }}.is-out .tin-sticky__dot-{{ g }}{ background:#e53e3e; }
.tin-sticky__price-{{ g }}{
  font-size:18px;
  line-height:1;
  font-weight:800;
  letter-spacing:-.02em;
  color:var(--tin-acc);
  white-space:nowrap;
}
.tin-sticky__cart-{{ g }}{
  display:flex;
  align-items:center;
  gap:8px;
  padding:9px 12px;
  border-radius:999px;
  border:1px solid rgba(212,120,154,.16);
  background:rgba(255,255,255,.58);
  min-width:max-content;
}
.tin-sticky__carticon-{{ g }}{
  width:30px;
  height:30px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  background:rgba(212,120,154,.12);
  color:var(--tin-acc);
  flex-shrink:0;
}
.tin-sticky__carttext-{{ g }}{
  display:flex;
  flex-direction:column;
  gap:1px;
  line-height:1.1;
}
.tin-sticky__cartlabel-{{ g }}{
  font-size:9px;
  text-transform:uppercase;
  letter-spacing:.09em;
  color:var(--tin-muted);
  font-weight:700;
}
.tin-sticky__carttotal-{{ g }}{
  font-size:13px;
  font-weight:800;
  color:var(--tin-fg);
  white-space:nowrap;
}
.tin-sticky__actions-{{ g }}{
  display:flex;
  align-items:center;
  gap:8px;
}
.tin-sticky__btn-{{ g }}{
  min-height:46px;
  border:none;
  border-radius:999px;
  padding:12px 18px;
  font-family:inherit;
  font-size:13px;
  font-weight:800;
  cursor:pointer;
  white-space:nowrap;
  transition:transform .18s ease, opacity .18s ease, box-shadow .18s ease, background .18s ease;
}
.tin-sticky__btn-{{ g }}:disabled{
  cursor:not-allowed;
  opacity:.50;
  transform:none!important;
  box-shadow:none!important;
}
.tin-sticky__btn--add-{{ g }}{
  background:var(--tin-btn);
  color:var(--tin-btn-t);
  box-shadow:0 8px 22px rgba(212,120,154,.28);
}
.tin-sticky__btn--add-{{ g }}:not(:disabled):hover{
  transform:translateY(-2px);
  box-shadow:0 12px 28px rgba(212,120,154,.36);
}
.tin-sticky__btn--go-{{ g }}{
  background:#fff;
  color:var(--tin-acc);
  border:1.5px solid rgba(212,120,154,.24);
}
.tin-sticky__btn--go-{{ g }}:not(:disabled):hover{
  transform:translateY(-2px);
}
.tin-sticky__toast-{{ g }}{
  position:absolute;
  left:50%;
  bottom:calc(100% + 10px);
  transform:translateX(-50%) translateY(10px);
  opacity:0;
  pointer-events:none;
  background:#fff;
  color:var(--tin-acc);
  border:1px solid rgba(212,120,154,.16);
  box-shadow:0 10px 32px rgba(0,0,0,.12);
  border-radius:999px;
  padding:10px 18px;
  font-size:12px;
  font-weight:800;
  white-space:nowrap;
  transition:opacity .2s ease, transform .2s ease;
}
.tin-sticky__toast-{{ g }}.show{
  opacity:1;
  transform:translateX(-50%) translateY(0);
}
{% if section.settings.hide_until_scroll %}
.tin-sticky-{{ g }}[data-ready="false"] .tin-sticky__bar-{{ g }}{
  transform:translateY(calc(100% + 24px));
  opacity:0;
}
{% endif %}

@media(max-width:980px){
  .tin-sticky-{{ g }}{
    bottom:calc(env(safe-area-inset-bottom,0px) + {{ section.settings.bottom_offset_mobile }}px);
    padding:0 10px;
  }
  .tin-sticky__bar-{{ g }}{
    grid-template-columns:minmax(0,1fr) auto;
    grid-template-areas:
      "product price"
      "actions actions";
    gap:8px 10px;
    padding:10px;
    border-radius:{{ section.settings.mobile_border_radius }}px;
  }
  .tin-sticky__product-{{ g }}{ grid-area:product; grid-template-columns:46px minmax(0,1fr); gap:9px; }
  .tin-sticky__img-{{ g }}{ width:46px; height:46px; border-radius:14px; }
  .tin-sticky__label-{{ g }}{ display:none; }
  .tin-sticky__title-{{ g }}{ font-size:13px; }
  .tin-sticky__variant-{{ g }}{ font-size:11px; }
  .tin-sticky__pricebox-{{ g }}{ grid-area:price; min-width:92px; }
  .tin-sticky__price-{{ g }}{ font-size:15px; }
  .tin-sticky__stock-{{ g }}{ font-size:10px; justify-content:flex-end; }
  .tin-sticky__cart-{{ g }}{ display:none; }
  .tin-sticky__actions-{{ g }}{ grid-area:actions; width:100%; display:grid; grid-template-columns:1fr 1fr; gap:8px; }
  .tin-sticky__btn-{{ g }}{ width:100%; min-height:44px; padding:11px 10px; font-size:12.5px; }
}

@media(max-width:420px){
  .tin-sticky__bar-{{ g }}{ gap:7px; }
  .tin-sticky__actions-{{ g }}{ grid-template-columns:1fr; }
  {% unless section.settings.show_secondary_mobile %}
  .tin-sticky__btn--go-{{ g }}{ display:none; }
  {% endunless %}
}
{% endstyle %}

<div
  class="tin-sticky-{{ g }}"
  id="tin-sticky-{{ g }}"
  data-ready="{% if section.settings.hide_until_scroll %}false{% else %}true{% endif %}"
  data-hidden="false"
  data-product-id="{{ product.id }}"
  data-current-variant-id="{{ fv.id }}"
  data-destination="{{ section.settings.destination }}"
  aria-live="polite">

  <div class="tin-sticky__toast-{{ g }}" id="tin-sticky-toast-{{ g }}">Agregado a tu selección 💕</div>

  <div class="tin-sticky__bar-{{ g }}">
    <div class="tin-sticky__product-{{ g }}">
      <div class="tin-sticky__img-{{ g }}">
        {%- if initial_img -%}
          <img
            id="tin-sticky-img-{{ g }}"
            src="{{ initial_img | image_url: width: 140 }}"
            alt="{{ initial_img.alt | default: product.title | escape }}"
            width="140"
            height="140"
            loading="eager">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>
      <div class="tin-sticky__meta-{{ g }}">
        <span class="tin-sticky__label-{{ g }}">{{ section.settings.micro_label }}</span>
        <p class="tin-sticky__title-{{ g }}" id="tin-sticky-title-{{ g }}">{{ product.title }}</p>
        <span class="tin-sticky__variant-{{ g }}" id="tin-sticky-variant-{{ g }}">
          {%- if fv.title != 'Default Title' -%}{{ fv.title }}{%- else -%}{{ section.settings.default_variant_text }}{%- endif -%}
        </span>
      </div>
    </div>

    <div class="tin-sticky__pricebox-{{ g }}">
      <div class="tin-sticky__stock-{{ g }}{% unless fv.available %} is-out{% endunless %}" id="tin-sticky-stock-{{ g }}">
        <span class="tin-sticky__dot-{{ g }}"></span>
        <span id="tin-sticky-stock-text-{{ g }}">
          {%- if fv.available -%}
            {%- if fv.inventory_management == 'shopify' and fv.inventory_quantity > 0 and fv.inventory_quantity <= 5 -%}
              {{ fv.inventory_quantity }} disponible{%- if fv.inventory_quantity > 1 -%}s{%- endif -%}
            {%- else -%}Disponible{%- endif -%}
          {%- else -%}Agotado{%- endif -%}
        </span>
      </div>
      <div class="tin-sticky__price-{{ g }}" id="tin-sticky-price-{{ g }}" data-price="{{ fv.price }}">
        {{ fv.price | money_without_trailing_zeros }}
      </div>
    </div>

    <button type="button" class="tin-sticky__cart-{{ g }}" id="tin-sticky-cart-{{ g }}" aria-label="Ver carrito">
      <span class="tin-sticky__carticon-{{ g }}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h8.9a2 2 0 0 0 2-1.6L23 6H6"></path>
        </svg>
      </span>
      <span class="tin-sticky__carttext-{{ g }}">
        <span class="tin-sticky__cartlabel-{{ g }}"><span id="tin-sticky-count-{{ g }}">0</span> en selección</span>
        <span class="tin-sticky__carttotal-{{ g }}" id="tin-sticky-total-{{ g }}">₲ 0</span>
      </span>
    </button>

    <div class="tin-sticky__actions-{{ g }}">
      <button type="button" class="tin-sticky__btn-{{ g }} tin-sticky__btn--add-{{ g }}" id="tin-sticky-add-{{ g }}" {% unless fv.available %}disabled{% endunless %}>
        {%- if fv.available -%}{{ section.settings.add_text }}{%- else -%}{{ section.settings.sold_text }}{%- endif -%}
      </button>
      <button type="button" class="tin-sticky__btn-{{ g }} tin-sticky__btn--go-{{ g }}" id="tin-sticky-go-{{ g }}">
        {{ section.settings.go_text }}
      </button>
    </div>
  </div>
</div>

<script>
(function(){
  'use strict';

  const root = document.getElementById('tin-sticky-{{ g }}');
  if(!root || root.dataset.loaded === 'true') return;
  root.dataset.loaded = 'true';

  const PRODUCT_ID = {{ product.id | json }};
  const PRODUCT_TITLE = {{ product.title | json }};
  const INITIAL_VARIANT = {
    variantId: {{ fv.id | json }},
    price: {{ fv.price | json }},
    available: {{ fv.available | json }},
    productId: PRODUCT_ID,
    title: PRODUCT_TITLE,
    variantTitle: {{ fv.title | json }},
    inventoryManagement: {{ fv.inventory_management | json }},
    inventoryQuantity: {{ fv.inventory_quantity | json }},
    featuredImage: {% if initial_img %}{{ initial_img | image_url: width: 300 | json }}{% else %}null{% endif %}
  };

  let current = Object.assign({}, INITIAL_VARIANT);
  let cartState = null;
  let lastScroll = window.scrollY || 0;
  let toastTimer = null;
  let syncing = false;

  const $ = id => document.getElementById(id);
  const elImg = $('tin-sticky-img-{{ g }}');
  const elTitle = $('tin-sticky-title-{{ g }}');
  const elVariant = $('tin-sticky-variant-{{ g }}');
  const elPrice = $('tin-sticky-price-{{ g }}');
  const elStock = $('tin-sticky-stock-{{ g }}');
  const elStockText = $('tin-sticky-stock-text-{{ g }}');
  const elAdd = $('tin-sticky-add-{{ g }}');
  const elGo = $('tin-sticky-go-{{ g }}');
  const elCart = $('tin-sticky-cart-{{ g }}');
  const elCount = $('tin-sticky-count-{{ g }}');
  const elTotal = $('tin-sticky-total-{{ g }}');
  const elToast = $('tin-sticky-toast-{{ g }}');

  const formatMoney = cents => {
    const n = Number(cents || 0) / 100;
    return '₲ ' + n.toLocaleString('es-PY', { maximumFractionDigits: 0 });
  };

  const imageUrl = src => {
    if(!src) return '';
    src = String(src);
    if(src.startsWith('//')) src = 'https:' + src;
    if(src.includes('cdn.shopify.com')){
      const q = src.indexOf('?');
      const base = q >= 0 ? src.slice(0, q) : src;
      const clean = base.replace(/_(\d+x\d+|master|large|grande|medium|small|compact|thumb)(\.[^.]+)$/i, '$2');
      return clean.replace(/(\.[^.]+)$/i, '_300x300$1');
    }
    return src;
  };

  const normalizeCart = cart => {
    if(!cart) return { item_count:0, total_price:0, items:[] };
    return {
      item_count: Number(cart.item_count || 0),
      total_price: Number(cart.total_price || 0),
      items: Array.isArray(cart.items) ? cart.items : []
    };
  };

  const showToast = msg => {
    if(!elToast) return;
    elToast.textContent = msg;
    elToast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(()=> elToast.classList.remove('show'), 1800);
  };

  const broadcastCart = cart => {
    const normalized = normalizeCart(cart);
    cartState = normalized;

    document.querySelectorAll('[data-cart-count],[data-cart-item-count],.cart-count,.cart__count,.cart-count-bubble,#cart-icon-bubble span,.header__cart-count')
      .forEach(node => { node.textContent = normalized.item_count; });
    document.querySelectorAll('.cart-count-bubble,[data-cart-count-bubble]')
      .forEach(node => { node.hidden = normalized.item_count === 0; });

    window.dispatchEvent(new CustomEvent('TinCart:updated', { detail:{ cart: normalized } }));
    document.dispatchEvent(new CustomEvent('cart:updated', { detail: normalized, bubbles:true }));
    document.dispatchEvent(new CustomEvent('cart-update', { detail: normalized, bubbles:true }));
    document.dispatchEvent(new CustomEvent('theme:cart:add', { detail: normalized, bubbles:true }));
  };

  const renderCart = cart => {
    const c = normalizeCart(cart);
    cartState = c;
    if(elCount) elCount.textContent = c.item_count;
    if(elTotal) elTotal.textContent = formatMoney(c.total_price);
  };

  const renderVariant = data => {
    current = Object.assign({}, current, data || {});
    root.dataset.currentVariantId = current.variantId || '';

    if(elTitle) elTitle.textContent = current.title || PRODUCT_TITLE;

    if(elVariant){
      const vt = current.variantTitle && current.variantTitle !== 'Default Title' ? current.variantTitle : {{ section.settings.default_variant_text | json }};
      elVariant.textContent = vt;
    }

    if(elPrice){
      elPrice.dataset.price = current.price || 0;
      elPrice.textContent = formatMoney(current.price || 0);
    }

    if(elImg && current.featuredImage){
      elImg.src = imageUrl(current.featuredImage);
    }

    const available = !!current.available;
    if(elStock && elStockText){
      elStock.classList.remove('is-low','is-out');
      if(!available){
        elStock.classList.add('is-out');
        elStockText.textContent = {{ section.settings.stock_sold_text | json }};
      }else{
        const q = Number(current.inventoryQuantity || 0);
        if(current.inventoryManagement === 'shopify' && q > 0 && q <= {{ section.settings.low_stock_limit }}){
          elStock.classList.add('is-low');
          elStockText.textContent = q + ' disponible' + (q > 1 ? 's' : '');
        }else{
          elStockText.textContent = {{ section.settings.stock_available_text | json }};
        }
      }
    }

    if(elAdd){
      elAdd.disabled = !available;
      elAdd.textContent = available ? {{ section.settings.add_text | json }} : {{ section.settings.sold_text | json }};
    }
  };

  const syncCart = async () => {
    if(syncing) return cartState;
    syncing = true;
    try{
      const cart = await fetch('/cart.js', { cache:'no-store', headers:{ 'Accept':'application/json' } }).then(r => r.json());
      renderCart(cart);
      return cart;
    }catch(err){
      console.warn('[Tintin Sticky] No se pudo sincronizar carrito', err);
      renderCart(cartState);
      return cartState;
    }finally{
      syncing = false;
    }
  };

  const addCurrent = async () => {
    if(!current || !current.variantId || !current.available){
      showToast({{ section.settings.sold_text | json }});
      renderVariant(current);
      return;
    }

    const original = elAdd ? elAdd.textContent : '';
    if(elAdd){
      elAdd.disabled = true;
      elAdd.textContent = {{ section.settings.adding_text | json }};
    }

    try{
      const added = await fetch('/cart/add.js', {
        method:'POST',
        headers:{ 'Content-Type':'application/json', 'Accept':'application/json', 'X-Requested-With':'XMLHttpRequest' },
        body:JSON.stringify({ id: Number(current.variantId), quantity: 1 })
      }).then(async r => {
        const data = await r.json().catch(()=>({}));
        if(!r.ok) throw data;
        return data;
      });

      const cart = await syncCart();
      broadcastCart(cart);

      window.dispatchEvent(new CustomEvent('TinCart:itemAdded', {
        detail:{
          variantId: current.variantId,
          productId: current.productId || PRODUCT_ID,
          title: added.product_title || current.title || PRODUCT_TITLE,
          variantTitle: added.variant_title || current.variantTitle,
          price: added.price || current.price,
          image: added.image || current.featuredImage,
          quantity: 1,
          lineKey: added.key
        }
      }));

      showToast({{ section.settings.added_text | json }});
      if(elAdd) elAdd.textContent = {{ section.settings.added_button_text | json }};
      setTimeout(()=>{
        if(elAdd){
          elAdd.disabled = !current.available;
          elAdd.textContent = current.available ? {{ section.settings.add_text | json }} : {{ section.settings.sold_text | json }};
        }
      }, 1200);
    }catch(err){
      console.error('[Tintin Sticky] Error agregando', err);
      showToast({{ section.settings.error_text | json }});
      if(elAdd){
        elAdd.disabled = !current.available;
        elAdd.textContent = original || {{ section.settings.add_text | json }};
      }
    }
  };

  const goDestination = () => {
    const dest = root.dataset.destination || 'cart';
    if(dest === 'checkout') window.location.href = '/checkout';
    else window.location.href = '/cart';
  };

  if(elAdd) elAdd.addEventListener('click', addCurrent);
  if(elGo) elGo.addEventListener('click', goDestination);
  if(elCart) elCart.addEventListener('click', () => { window.location.href = '/cart'; });

  window.addEventListener('TinCart:variantChange', event => {
    const d = event.detail || {};
    renderVariant({
      variantId: d.variantId,
      price: d.price,
      title: d.title,
      available: d.available,
      productId: d.productId,
      variantTitle: d.variantTitle,
      featuredImage: d.featuredImage,
      inventoryManagement: d.inventoryManagement,
      inventoryQuantity: d.inventoryQuantity
    });
  });

  window.addEventListener('TinCart:updated', event => {
    renderCart(event.detail && event.detail.cart ? event.detail.cart : event.detail);
  });

  ['cart:updated','cart-update','theme:cart:add','cart:refresh'].forEach(name => {
    document.addEventListener(name, event => {
      const detail = event.detail && event.detail.cart ? event.detail.cart : event.detail;
      if(detail && (detail.items || detail.item_count !== undefined)) renderCart(detail);
      else syncCart();
    });
  });

  {% if section.settings.hide_on_scroll %}
  let ticking = false;
  window.addEventListener('scroll', () => {
    if(ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y = window.scrollY || 0;
      root.dataset.ready = (!{{ section.settings.hide_until_scroll | json }} || y > {{ section.settings.show_after_scroll }}) ? 'true' : 'false';
      if(y > lastScroll + 44 && y > {{ section.settings.show_after_scroll }}) root.dataset.hidden = 'true';
      else if(y < lastScroll - 12) root.dataset.hidden = 'false';
      lastScroll = y;
      ticking = false;
    });
  }, { passive:true });
  {% else %}
  window.addEventListener('scroll', () => {
    const y = window.scrollY || 0;
    root.dataset.ready = (!{{ section.settings.hide_until_scroll | json }} || y > {{ section.settings.show_after_scroll }}) ? 'true' : 'false';
  }, { passive:true });
  {% endif %}

  renderVariant(INITIAL_VARIANT);
  syncCart();

  window.dispatchEvent(new CustomEvent('TinCart:requestVariantInfo'));
})();
</script>

