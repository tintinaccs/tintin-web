{% comment %}
  ╔══════════════════════════════════════════════════════╗
  ║  TINTIN — 05 TU SELECCIÓN (LISTA RÁPIDA)            ║
  ║  Archivo: 05-tintin-seleccion.liquid                 ║
  ║  Posición: 5° en la plantilla de producto            ║
  ║  SINCRONIZA: escucha TinCart:updated                 ║
  ║              escucha TinCart:itemAdded               ║
  ║              escucha TinCart:itemRemoved             ║
  ║              emite  TinCart:updated (tras cambios)   ║
  ╚══════════════════════════════════════════════════════╝
{% endcomment %}

{%- assign g = 'tinsel' -%}

{% style %}
.{{ g }}{
  --acc: {{ section.settings.accent_color }};
  --bg:  {{ section.settings.background_color }};
  --fg:  {{ section.settings.text_color }};
  --pbtn:  {{ section.settings.primary_button_color }};
  --pbtnT: {{ section.settings.primary_button_text_color }};
  --r:     {{ section.settings.border_radius }}px;
  background: var(--bg);
  width: 100%;
}
.{{ g }}-wrap{
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: clamp(24px,3vw,{{ section.settings.section_padding }}px) clamp(16px,4vw,72px);
  box-sizing: border-box;
}
.{{ g }}-box{
  background:#fff;
  border:1px solid rgba(212,120,154,.15);
  border-radius:calc(var(--r)*2);
  padding:clamp(18px,2vw,28px);
  position:relative;
  overflow:hidden;
}
.{{ g }}-box::before{
  content:'';
  position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg,var(--acc),rgba(212,120,154,.4),var(--acc));
}
/* Header */
.{{ g }}-head{
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:18px; flex-wrap:wrap; gap:10px;
}
.{{ g }}-head-left{ display:flex; align-items:center; gap:12px; }
.{{ g }}-title{
  font-size:clamp(17px,1.4vw,22px);
  font-weight:500; color:var(--fg); margin:0;
  letter-spacing:-.02em;
}
.{{ g }}-badge{
  font-size:11px; font-weight:700;
  padding:3px 11px;
  background:var(--acc); color:#fff;
  border-radius:20px;
  min-width:24px; text-align:center;
}
.{{ g }}-total-row{
  display:flex; align-items:baseline; gap:8px;
}
.{{ g }}-total-label{
  font-size:11px; color:rgba(45,45,45,.5);
  text-transform:uppercase; letter-spacing:.08em;
}
.{{ g }}-total{
  font-size:clamp(16px,1.4vw,20px);
  font-weight:700; color:var(--acc);
  letter-spacing:-.02em;
}
/* Items */
.{{ g }}-items{ display:flex; flex-direction:column; gap:10px; }
.{{ g }}-empty{
  text-align:center; padding:28px 0;
  color:rgba(45,45,45,.45); font-size:14px;
}
.{{ g }}-empty-icon{ font-size:32px; margin-bottom:8px; }
.{{ g }}-item{
  display:grid;
  grid-template-columns:clamp(56px,18vw,76px) minmax(0,1fr) auto auto;
  gap:clamp(6px,1.5vw,12px);
  align-items:center;
  padding:clamp(8px,1.5vw,12px);
  border-radius:calc(var(--r)*1.2);
  background:rgba(253,240,245,.6);
  border:1px solid rgba(212,120,154,.1);
  transition:background .2s;
  width:100%;
  box-sizing:border-box;
}
.{{ g }}-item:hover{ background:rgba(253,240,245,.9); }
.{{ g }}-item-img{
  display:block;
  width:100%;
  aspect-ratio:1/1;
  border-radius:calc(var(--r)*1);
  overflow:hidden; flex-shrink:0;
  background:rgba(212,120,154,.08);
  border:1px solid rgba(212,120,154,.1);
  text-decoration:none;
}
.{{ g }}-item-img img{ width:100%; height:100%; object-fit:cover; display:block; }
.{{ g }}-item-info{ min-width:0; }
.{{ g }}-item-name{
  display:block;
  font-size:13px; font-weight:700; color:var(--fg);
  margin:0 0 3px;
  overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
  text-decoration:none;
}

.{{ g }}-item-name:hover{
  color:var(--acc);
}
.{{ g }}-item-variant{
  font-size:11px; color:rgba(45,45,45,.52); margin:0 0 4px;
}
.{{ g }}-item-price{
  font-size:14px; font-weight:700; color:var(--acc); margin:0;
}
/* Cantidad */
.{{ g }}-qty{
  display:flex; align-items:center; gap:clamp(3px,1vw,6px);
  background:rgba(212,120,154,.07);
  border:1px solid rgba(212,120,154,.1);
  padding:clamp(3px,1vw,5px) clamp(6px,2vw,10px);
  border-radius:30px;
  flex-shrink:0;
  white-space:nowrap;
}
.{{ g }}-qbtn{
  background:none; border:none;
  color:var(--acc); font-size:18px; font-weight:700;
  cursor:pointer; padding:0 2px; line-height:1;
  transition:transform .15s;
}
.{{ g }}-qbtn:hover{ transform:scale(1.3); }
.{{ g }}-qnum{
  font-size:13px; font-weight:700; color:var(--fg);
  min-width:20px; text-align:center;
}
/* Eliminar */
.{{ g }}-del{
  background:none; border:none; padding:8px;
  color:rgba(45,45,45,.35); cursor:pointer;
  border-radius:50%;
  transition:color .18s, background .18s;
  flex-shrink:0;
}
.{{ g }}-del:hover{ color:#e53e3e; background:rgba(229,62,62,.08); }
/* Footer */
.{{ g }}-footer{
  margin-top:18px; padding-top:18px;
  border-top:1px solid rgba(212,120,154,.12);
  display:flex; align-items:center; justify-content:space-between;
  flex-wrap:wrap; gap:12px;
}
.{{ g }}-footer-total{ display:flex; flex-direction:column; gap:2px; }
.{{ g }}-footer-label{ font-size:10px; text-transform:uppercase; letter-spacing:.1em; color:rgba(45,45,45,.45); }
.{{ g }}-footer-amount{
  font-size:clamp(20px,1.8vw,26px);
  font-weight:700; color:var(--acc); letter-spacing:-.02em;
}
.{{ g }}-footer-btns{ display:flex; gap:10px; flex-wrap:wrap; }
.{{ g }}-btn{
  padding:13px clamp(18px,2vw,28px);
  border-radius:50px; border:none; cursor:pointer;
  font-size:14px; font-weight:700;
  transition:all .22s ease;
}
.{{ g }}-btn-primary{
  background:var(--pbtn); color:var(--pbtnT);
  box-shadow:0 8px 22px rgba(212,120,154,.3);
}
.{{ g }}-btn-primary:hover{ transform:translateY(-2px); box-shadow:0 12px 28px rgba(212,120,154,.42); }
.{{ g }}-btn-secondary{
  background:#fff; color:var(--acc);
  border:1.5px solid rgba(212,120,154,.28);
}
.{{ g }}-btn-secondary:hover{ background:rgba(212,120,154,.06); }

/* Toast */
.{{ g }}-toast{
  position:fixed;
  bottom:clamp(80px,10vw,110px); left:50%;
  transform:translateX(-50%) translateY(14px);
  opacity:0;
  background:#fff; color:#d4789a;
  border:1px solid rgba(212,120,154,.2);
  box-shadow:0 12px 40px rgba(0,0,0,.12);
  padding:11px 22px; border-radius:50px;
  font-size:13px; font-weight:700;
  z-index:10001; white-space:nowrap;
  pointer-events:none;
  transition:opacity .28s, transform .28s;
}
.{{ g }}-toast.show{
  opacity:1; transform:translateX(-50%) translateY(0);
}

/* Loading skeleton */
.{{ g }}-skeleton{
  display:flex; flex-direction:column; gap:10px;
}
.{{ g }}-skel-item{
  height:100px; border-radius:calc(var(--r)*1.2);
  background:linear-gradient(110deg,rgba(212,120,154,.06) 30%,rgba(212,120,154,.1) 50%,rgba(212,120,154,.06) 70%);
  background-size:200% 100%;
  animation:tinsel-sk 1.4s ease-in-out infinite;
}
@keyframes tinsel-sk{
  0%{ background-position:200% 0; }
  100%{ background-position:-200% 0; }
}

@media(max-width:768px){
  .{{ g }}-wrap{ padding:clamp(20px,3vw,32px) 14px; }
  .{{ g }}-item-name{ font-size:12px; }
  .{{ g }}-item-price{ font-size:13px; }
  .{{ g }}-footer{ flex-direction:column; align-items:stretch; }
  .{{ g }}-footer-btns{ flex-direction:column; }
  .{{ g }}-btn{ text-align:center; }
}

@media(max-width:380px){
  .{{ g }}-item{
    grid-template-columns:48px minmax(0,1fr) auto auto;
  }
  .{{ g }}-item-name{ font-size:11.5px; }
  .{{ g }}-qbtn{ font-size:16px; }
}
{% endstyle %}

{%- if section.settings.show_section -%}
<section class="{{ g }}" id="{{ g }}-root">
  <div class="{{ g }}-wrap">
    <div class="{{ g }}-box">

      <div class="{{ g }}-head">
        <div class="{{ g }}-head-left">
          <h2 class="{{ g }}-title">{{ section.settings.title }}</h2>
          <span class="{{ g }}-badge" id="{{ g }}-count">0</span>
        </div>
        <div class="{{ g }}-total-row">
          <span class="{{ g }}-total-label">Total:</span>
          <span class="{{ g }}-total" id="{{ g }}-total-head">Gs. 0</span>
        </div>
      </div>

      <!-- Loading -->
      <div class="{{ g }}-skeleton" id="{{ g }}-skeleton">
        <div class="{{ g }}-skel-item"></div>
        <div class="{{ g }}-skel-item"></div>
      </div>

      <!-- Items -->
      <div class="{{ g }}-items" id="{{ g }}-items" style="display:none"></div>

      <!-- Footer -->
      <div class="{{ g }}-footer" id="{{ g }}-footer" style="display:none">
        <div class="{{ g }}-footer-total">
          <span class="{{ g }}-footer-label">Total de tu selección</span>
          <span class="{{ g }}-footer-amount" id="{{ g }}-total-footer">Gs. 0</span>
        </div>
        <div class="{{ g }}-footer-btns">
          {%- if section.settings.show_cart_btn -%}
            <button class="{{ g }}-btn {{ g }}-btn-secondary" id="{{ g }}-cart-btn">
              {{ section.settings.cart_btn_text }}
            </button>
          {%- endif -%}
          {%- if section.settings.show_checkout_btn -%}
            <button class="{{ g }}-btn {{ g }}-btn-primary" id="{{ g }}-checkout-btn">
              {{ section.settings.checkout_btn_text }}
            </button>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
  <div class="{{ g }}-toast" id="{{ g }}-toast"></div>
</section>
{%- endif -%}

<script>
(function(){
  'use strict';

  /* ══════════════════════════════════════════
     TINTIN — SELECCIÓN: módulo de lista rápida
     Lee /cart.js y escucha eventos TinCart
  ══════════════════════════════════════════ */

  const CURRENCY_PREFIX = '{{ section.settings.currency_prefix }}';

  function fmt(cents){
    return CURRENCY_PREFIX + ' ' + Math.round(cents/100).toLocaleString('es-PY').replace(/,/g,'.');
  }

  const selSkeleton  = document.getElementById('{{ g }}-skeleton');
  const selItems     = document.getElementById('{{ g }}-items');
  const selFooter    = document.getElementById('{{ g }}-footer');
  const selCount     = document.getElementById('{{ g }}-count');
  const selTotalHead = document.getElementById('{{ g }}-total-head');
  const selTotalFoot = document.getElementById('{{ g }}-total-footer');
  const selToast     = document.getElementById('{{ g }}-toast');

  /* ── Toast ── */
  let toastTimer;
  function showToast(msg){
    if(!selToast) return;
    selToast.textContent = msg;
    selToast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(()=> selToast.classList.remove('show'), 2800);
  }

  /* ── Renderizar lista ── */
  function renderCart(cart){
    if(!selItems) return;

    const items = cart.items || [];
    const total = cart.total_price || 0;
    const count = items.reduce((s,i)=> s + i.quantity, 0);

    /* Contadores */
    if(selCount) selCount.textContent = count;
    const totalStr = fmt(total);
    if(selTotalHead) selTotalHead.textContent = totalStr;
    if(selTotalFoot) selTotalFoot.textContent = totalStr;

    /* Ocultar skeleton */
    if(selSkeleton) selSkeleton.style.display = 'none';

    if(items.length === 0){
      selItems.style.display = 'flex';
      selItems.innerHTML = `
        <div class="{{ g }}-empty">
          <div class="{{ g }}-empty-icon">🛍️</div>
          <p>{{ section.settings.empty_text }}</p>
        </div>`;
      if(selFooter) selFooter.style.display = 'none';
      return;
    }

    selItems.style.display = 'flex';
    selItems.innerHTML = items.map(item=>{
      const img = item.image
        ? item.image.replace(/\.(jpg|jpeg|png|gif|webp)(\?.*)?$/i, '_120x120.$1')
        : '';
      const varTitle = item.variant_title && item.variant_title !== 'Default Title'
        ? item.variant_title : '';
      return `
        <div class="{{ g }}-item" data-key="${item.key}">
          <a class="{{ g }}-item-img" href="${item.url}">
            ${img ? `<img src="${img}" alt="${item.product_title}" loading="lazy" width="76" height="76">` : ''}
          </a>
          <div class="{{ g }}-item-info">
            <a class="{{ g }}-item-name" href="${item.url}">${item.product_title}</a>
            ${varTitle ? `<p class="{{ g }}-item-variant">${varTitle}</p>` : ''}
            <p class="{{ g }}-item-price">${fmt(item.final_line_price)}</p>
          </div>
          <div class="{{ g }}-qty">
            <button class="{{ g }}-qbtn" data-action="dec" data-key="${item.key}" data-qty="${item.quantity}" aria-label="Restar">−</button>
            <span class="{{ g }}-qnum">${item.quantity}</span>
            <button class="{{ g }}-qbtn" data-action="inc" data-key="${item.key}" data-qty="${item.quantity}" aria-label="Sumar">+</button>
          </div>
          <button class="{{ g }}-del" data-key="${item.key}" aria-label="Eliminar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
          </button>
        </div>`;
    }).join('');

    if(selFooter) selFooter.style.display = 'flex';

    /* Listeners qty y del */
    selItems.querySelectorAll('.{{ g }}-qbtn').forEach(btn=>{
      btn.addEventListener('click', async ()=>{
        const key = btn.dataset.key;
        const qty = parseInt(btn.dataset.qty);
        const newQty = btn.dataset.action === 'inc' ? qty + 1 : Math.max(0, qty - 1);
        await changeQty(key, newQty);
      });
    });
    selItems.querySelectorAll('.{{ g }}-del').forEach(btn=>{
      btn.addEventListener('click', async ()=>{
        await changeQty(btn.dataset.key, 0);
        showToast('Eliminado de tu selección');
      });
    });
  }

  /* ── Cambiar cantidad ── */
  async function changeQty(key, qty){
    try {
      const res = await fetch('/cart/change.js', {
        method:'POST',
        headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
        body: JSON.stringify({ id: key, quantity: qty })
      });
      const cart = await res.json();
      renderCart(cart);
      window.dispatchEvent(new CustomEvent('TinCart:updated', { detail: { cart } }));
    } catch(err){
      console.error('[TinSel] Error changeQty:', err);
    }
  }

  /* ── Cargar carrito inicial ── */
  async function loadCart(){
    try {
      const res  = await fetch('/cart.js');
      const cart = await res.json();
      renderCart(cart);
    } catch(err){
      console.error('[TinSel] Error cargando carrito:', err);
      if(selSkeleton) selSkeleton.style.display = 'none';
      if(selItems){
        selItems.style.display = 'flex';
        selItems.innerHTML = '<div class="{{ g }}-empty"><p>Error cargando tu selección.</p></div>';
      }
    }
  }
  loadCart();

  /* ── Escuchar eventos de otras secciones (ampliado, cubre todo el sitio) ── */
  function handleCartEvent(e){
    if(e.detail?.cart){
      renderCart(e.detail.cart);
    } else {
      loadCart();
    }
  }

  ['TinCart:updated','TinCartPage:updated','cart:updated','cart-update','theme:cart:add','cart:refresh','cart:change','cart:build','cart:reload','theme:cart:change'].forEach(evt=>{
    window.addEventListener(evt, handleCartEvent);
    document.addEventListener(evt, handleCartEvent);
  });

  window.addEventListener('TinCart:itemAdded', ()=>{
    showToast('{{ section.settings.added_toast }}');
    loadCart();
  });

  /* ── Respaldo: detecta cualquier fetch/XHR hacia endpoints de carrito, sin importar quién lo dispare ── */
  if(!window.__tinSelHooksInstalled__){
    window.__tinSelHooksInstalled__ = true;

    const CART_ENDPOINTS = ['/cart/add', '/cart/change', '/cart/update', '/cart/clear'];
    const origFetch = window.fetch;
    window.fetch = function(...args){
      const urlArg = args[0];
      const url = typeof urlArg === 'string' ? urlArg : (urlArg && urlArg.url) || '';
      const isCartCall = CART_ENDPOINTS.some(ep => url.indexOf(ep) !== -1);
      const result = origFetch.apply(this, args);
      if(isCartCall){
        result.then(()=> loadCart()).catch(()=>{});
      }
      return result;
    };

    const origXHROpen = XMLHttpRequest.prototype.open;
    const origXHRSend = XMLHttpRequest.prototype.send;
    XMLHttpRequest.prototype.open = function(method, url, ...rest){
      this._tinSelIsCartCall = CART_ENDPOINTS.some(ep => String(url).indexOf(ep) !== -1);
      return origXHROpen.call(this, method, url, ...rest);
    };
    XMLHttpRequest.prototype.send = function(...args){
      if(this._tinSelIsCartCall){
        this.addEventListener('loadend', loadCart);
      }
      return origXHRSend.apply(this, args);
    };
  }

  /* ── Respaldo: sincroniza al volver a la pestaña ── */
  document.addEventListener('visibilitychange', ()=>{
    if(!document.hidden) loadCart();
  });

  /* ── Botones de footer ── */
  const cartBtn = document.getElementById('{{ g }}-cart-btn');
  if(cartBtn) cartBtn.addEventListener('click', ()=>{ window.location.href = '/cart'; });

  const checkBtn = document.getElementById('{{ g }}-checkout-btn');
  if(checkBtn) checkBtn.addEventListener('click', ()=>{ window.location.href = '/checkout'; });

})();
</script>

{% schema %}
{
  "name": "05 — Tu Selección",
  "settings": [
    { "type": "header", "content": "━━━ Visibilidad ━━━" },
    { "type": "checkbox", "id": "show_section", "label": "Mostrar sección", "default": true },
    { "type": "header", "content": "━━━ Diseño ━━━" },
    { "type": "range", "id": "max_width", "label": "Ancho máximo (px)", "min": 800, "max": 2560, "step": 40, "default": 1600 },
    { "type": "range", "id": "section_padding", "label": "Espaciado vertical (px)", "min": 16, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "border_radius", "label": "Radio de bordes (px)", "min": 0, "max": 40, "step": 2, "default": 16 },
    { "type": "header", "content": "━━━ Colores ━━━" },
    { "type": "color", "id": "background_color", "label": "Fondo sección", "default": "#fdf0f5" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#2d2d2d" },
    { "type": "color", "id": "accent_color", "label": "Acento", "default": "#d4789a" },
    { "type": "color", "id": "primary_button_color", "label": "Botón primario", "default": "#d4789a" },
    { "type": "color", "id": "primary_button_text_color", "label": "Texto botón primario", "default": "#ffffff" },
    { "type": "header", "content": "━━━ Textos ━━━" },
    { "type": "text", "id": "title", "label": "Título", "default": "Tu selección Tintin 💕" },
    { "type": "text", "id": "empty_text", "label": "Texto lista vacía", "default": "Todavía no agregaste accesorios. ¡Empezá eligiendo!" },
    { "type": "text", "id": "added_toast", "label": "Toast al agregar", "default": "¡Agregado a tu selección! 💕" },
    { "type": "text", "id": "currency_prefix", "label": "Prefijo moneda", "default": "Gs." },
    { "type": "header", "content": "━━━ Botones ━━━" },
    { "type": "checkbox", "id": "show_cart_btn", "label": "Mostrar botón carrito", "default": true },
    { "type": "text", "id": "cart_btn_text", "label": "Texto botón carrito", "default": "Ver mi carrito" },
    { "type": "checkbox", "id": "show_checkout_btn", "label": "Mostrar botón checkout", "default": true },
    { "type": "text", "id": "checkout_btn_text", "label": "Texto botón checkout", "default": "Finalizar pedido 💕" }
  ],
  "presets": [{ "name": "05 — Tu Selección" }]
}
{% endschema %}