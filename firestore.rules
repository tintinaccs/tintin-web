rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Fase E: una cuenta bloqueada pierde todo poder de admin/agent/superadmin
    // en las reglas mismas (no solo en la UI) apenas Super Admin la bloquea.
    // tintinaccs@gmail.com queda excluida a propósito, aunque en la práctica
    // nunca puede llegar a tener blocked==true (ver más abajo).
    function isBlockedUser() {
      return isSignedIn() &&
        request.auth.token.email != "tintinaccs@gmail.com" &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.blocked == true;
    }

    function isAdmin() {
      return isSignedIn() && !isBlockedUser() && (
        request.auth.token.email == "tintinaccs@gmail.com" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "superadmin"]
        )
      );
    }

    // Modder (rol "agent" en el código, "Modder" de cara a la tienda): permisos
    // operativos acotados — NUNCA se combina con isAdmin() en un solo helper
    // a propósito, para que cada match deje explícito qué le toca a cada uno
    // y nunca herede por accidente algo pensado solo para admin/superadmin.
    function isAgent() {
      return isSignedIn() && !isBlockedUser() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "agent";
    }

    // Super Admin real — únicamente tintinaccs@gmail.com. "admin" (el gerente
    // operativo, Fase D) NO cuenta acá aunque isAdmin() sí lo incluya: esto es
    // a propósito, para que Usuarios/Configuración queden 100% exclusivos del
    // Super Admin y nunca un "admin" tenga el mismo poder por error.
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "tintinaccs@gmail.com" ||
        (
          !isBlockedUser() &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "superadmin"
        )
      );
    }

    // ¿El documento de usuario que se está tocando es el del Super Admin?
    // Se usa para blindarlo: nadie, ni siquiera otro superadmin/admin, puede
    // bloquearlo, eliminarlo, ni cambiarle el rol — solo su propio token puede
    // tocar su propio documento.
    function isSuperAdminAccount(data) {
      return data.email == "tintinaccs@gmail.com";
    }

    // IMPORTANTE:
    // La web pública necesita leer estas imágenes para mostrar hero, categorías, editoriales, etc.
    match /settings/images {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Config general de la tienda (nombre, WhatsApp, envíos/ciudades, redes, pagos).
    // El checkout público necesita leerla sin estar logueado para calcular el costo de envío.
    // No contiene datos sensibles (ninguna credencial/secreto vive acá).
    // Escritura: solo Super Admin — es la sección "Configuración", fuera del
    // alcance de "admin" (gerente operativo) y del Modder (Fase D).
    match /settings/general {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Otros documentos de settings quedan protegidos — exclusivo Super Admin.
    match /settings/{doc} {
      allow read, write: if isSuperAdmin();
    }

    match /users/{userId} {
      // El dueño del doc puede leer el suyo; ver cualquier otra cuenta (panel
      // Usuarios) es exclusivo del Super Admin — ni "admin" ni el Modder
      // tienen acceso a la lista de usuarios (Fase D).
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());

      // Alta de cuenta: solo el propio usuario. No puede autoasignarse un rol
      // distinto de 'client', y el rol "superadmin" NUNCA se puede asignar
      // salvo que quien escribe sea literalmente tintinaccs@gmail.com — así
      // se cumple "solo tintinaccs@gmail.com puede ser Super Admin" incluso
      // si alguien lo intenta a mano desde la consola del navegador.
      allow create: if isSignedIn() && request.auth.uid == userId &&
        (
          !('role' in request.resource.data) ||
          request.resource.data.role == 'client' ||
          isSuperAdmin()
        ) &&
        (
          !('role' in request.resource.data) ||
          request.resource.data.role != 'superadmin' ||
          request.auth.token.email == "tintinaccs@gmail.com"
        );

      // El dueño puede editar su propio perfil pero NO su rol ni su estado de
      // bloqueo (evita auto-escalación de privilegios). Tocar el documento de
      // OTRO usuario (incluido cambiar rol/bloqueo) es exclusivo del Super
      // Admin. Blindaje extra, sin excepciones:
      //   - nadie puede tocar el rol/bloqueo del documento de tintinaccs@gmail.com,
      //     salvo ella misma (ni siquiera otro superadmin/admin puede degradarla);
      //   - nadie puede asignarle el rol "superadmin" a NINGUNA cuenta salvo
      //     que quien escribe sea tintinaccs@gmail.com.
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !isBlockedUser() &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'blocked'])) ||
        (
          isSuperAdmin() &&
          (request.auth.token.email == "tintinaccs@gmail.com" || !isSuperAdminAccount(resource.data)) &&
          (
            !('role' in request.resource.data) ||
            request.resource.data.role != 'superadmin' ||
            request.auth.token.email == "tintinaccs@gmail.com"
          )
        )
      );

      // Eliminar una cuenta es exclusivo del Super Admin, y el documento de
      // tintinaccs@gmail.com no se puede eliminar bajo ninguna circunstancia.
      allow delete: if isSuperAdmin() && !isSuperAdminAccount(resource.data);

      // Carrito sincronizado del usuario (js/cart-sync.js)
      match /cart/{itemId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Productos: Modder puede cargar/editar (agregar, cambiar stock, precio,
    // datos del producto) — pero eliminar un producto de la tienda queda
    // reservado a admin/superadmin, es una acción más irreversible.
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() || isAgent();
      allow delete: if isAdmin();
    }

    // Colecciones — panel Super Admin → Colecciones, y catálogo/home/menú públicos.
    // Mismo criterio que Productos: Modder edita, no elimina.
    match /collections/{collectionId} {
      allow read: if true;
      allow create, update: if isAdmin() || isAgent();
      allow delete: if isAdmin();
    }

    // Textos editables del Hero/Home/Nosotros/Catálogo (Super Admin → Contenido).
    // Mismo criterio: Modder edita, no elimina una sección entera.
    match /site_content/{pageId} {
      allow read: if true;
      allow create, update: if isAdmin() || isAgent();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Fase F: no hay más compra como invitada. El pedido debe quedar
      // asignado a quien realmente lo crea (nunca a nombre de otro uid), con
      // un correo real y verificado — no alcanza con que la UI oculte el
      // botón de invitada, esto lo hace imposible aunque alguien llame a
      // Firestore directamente desde la consola:
      //   - la cuenta no puede estar bloqueada (Fase E);
      //   - el token tiene que traer un email (los usuarios anónimos NO
      //     tienen email en el token, así que esto ya los excluye solo);
      //   - ese email tiene que estar verificado;
      //   - el pedido tiene que guardar el UID y el email de esa MISMA
      //     cuenta (nunca el uid/email de otra persona, ni un campo vacío).
      allow create: if isSignedIn() && !isBlockedUser() &&
        request.auth.token.email != null &&
        request.auth.token.email_verified == true &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.userEmail is string &&
        request.resource.data.userEmail.lower() == request.auth.token.email.lower();

      // El dueño puede leer sus propios pedidos (para "Mis pedidos" en perfil.html);
      // admin y Modder pueden leer cualquiera (el Modder necesita ver los datos
      // del pedido para prepararlo: productos, dirección, teléfono).
      allow read: if isAdmin() || isAgent() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // El Modder solo puede tocar el seguimiento operativo del pedido (estado,
      // estado de pago, reenvío de correo) — nunca los datos del pedido en sí
      // (productos, montos, dirección, datos del cliente). Esos campos completos
      // solo los puede reescribir un admin/superadmin desde "Editar pedido".
      //
      // La dueña del pedido puede tocar ÚNICAMENTE `notificationStatus` del
      // suyo — nada más (ni total, ni productos, ni datos personales). Existe
      // para que checkout.html pueda registrar si el correo de confirmación
      // salió bien o falló, en vez de quedar pegado en "pending" para
      // siempre (antes no tenía ningún permiso de update sobre su propio
      // pedido, así que ese resultado nunca se podía guardar).
      allow update: if isAdmin() || (
        isAgent() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['status', 'payment', 'paymentStatus', 'resendCount', 'lastResendAt', 'notificationStatus', 'updatedAt']
        )
      ) || (
        isSignedIn() && !isBlockedUser() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notificationStatus', 'updatedAt'])
      );

      allow delete: if isAdmin();
    }

    // Registro de auditoría (Fase 2): quién editó un pedido, cambió su estado,
    // editó un producto/stock, cambió un rol, o bloqueó/restauró una cuenta.
    // Cualquier admin/agente puede CREAR una entrada (así queda registrada su
    // propia acción), pero solo Super Admin puede LEER el historial — el
    // Modder no ve la auditoría, aunque sus propias acciones sí queden
    // anotadas ahí. Es un registro inmutable: nadie edita ni borra entradas.
    match /auditLog/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin() || isAgent();
      allow update, delete: if false;
    }

    // ======== MÓDULO CORREOS (Super Admin → Correos) ========
    // Todo el módulo (configuración, plantillas, historial, campañas de
    // promociones) es 100% exclusivo de Super Admin — ni "admin" ni el
    // Modder tienen ningún acceso de lectura ni escritura acá, igual que
    // Usuarios/Configuración/Auditoría (Fase D).

    // Configuración de correos (switches, remitente, límites diarios, etc.)
    match /emailSettings/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // Plantillas editables (asunto, saludo, cierre, firma, etc.) — CRUD
    // completo, incluido eliminar una plantilla propia (nunca las variables
    // protegidas, esas viven hardcodeadas en el propio Apps Script/frontend).
    match /emailTemplates/{templateId} {
      allow read, write: if isSuperAdmin();
    }

    // Historial de envíos: registro inmutable, mismo criterio que auditLog.
    // La lectura del historial es exclusiva de Super Admin (vive dentro del
    // módulo Correos, que la UI ya oculta por completo a cualquier otro
    // rol) — pero la ESCRITURA de una entrada la puede hacer cualquier rol
    // operativo (admin/agent), porque cambiar el estado de un pedido desde
    // Pedidos puede disparar un correo automático configurado en Correos
    // (Fase Correos), y esa entrada tiene que poder registrarse sin
    // importar quién cambió el estado. Nunca se edita ni se borra una
    // entrada ya creada.
    match /emailLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin() || isAgent();
      allow update, delete: if false;
    }

    // Campañas de promociones (destinatarios, progreso, resultados por
    // destinatario) — Super Admin puede crearlas y actualizarlas mientras
    // se van enviando las tandas, pero no eliminar el registro de una
    // campaña ya iniciada.
    match /emailCampaigns/{campaignId} {
      allow read, create, update: if isSuperAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
