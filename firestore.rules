rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ============================================================
       TINTIN — HELPERS BASE
       ============================================================ */

    function isSignedIn() {
      return request.auth != null;
    }

    // Super Admin real: solo la cuenta oficial de Tintin.
    // No se confía en role:"superadmin" guardado en Firestore.
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "tintinaccs@gmail.com";
    }

    function userDocExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return userDocExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : "visitor";
    }

    function hasRole(role) {
      return isSignedIn() && !isBlockedUser() && userDocExists() && currentRole() == role;
    }

    function isBlockedUser() {
      return isSignedIn() &&
        request.auth.token.email != "tintinaccs@gmail.com" &&
        userDocExists() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.blocked == true;
    }

    function isAdmin() {
      return isSignedIn() && !isBlockedUser() && (
        isSuperAdmin() || hasRole("admin")
      );
    }

    function isAgent() {
      return hasRole("agent");
    }

    function isViewer() {
      return hasRole("viewer");
    }

    function isModerator() {
      return hasRole("moderator");
    }

    function isSupport() {
      return hasRole("support");
    }

    function isSuperAdminAccount(data) {
      return data.email == "tintinaccs@gmail.com";
    }

    /* ============================================================
       TINTIN — TIENDA ACTIVA / CERRADA
       ============================================================ */

    function isStoreOpenOrAllowed() {
      return isSuperAdmin() ||
        !exists(/databases/$(database)/documents/settings/general) ||
        get(/databases/$(database)/documents/settings/general).data.storeOpen != false ||
        (
          !isBlockedUser() &&
          get(/databases/$(database)/documents/settings/general).data.maintenanceAccess is map &&
          get(/databases/$(database)/documents/settings/general).data.maintenanceAccess
            .get(isSignedIn() ? currentRole() : 'guest', false) == true
        );
    }

    /* ============================================================
       TINTIN — ROLES Y PERMISOS DINÁMICOS
       ============================================================ */

    // Permitido por defecto: si Super Admin no tocó nada en
    // rolePermissions/main, el rol conserva el comportamiento original
    // (sin restricción extra) hasta que se configure explícitamente.
    function rolePermAllows(role, moduleKey, actionKey) {
      return !exists(/databases/$(database)/documents/rolePermissions/main) || (
        get(/databases/$(database)/documents/rolePermissions/main).data
          .get(role, {}).get(moduleKey, {}).get(actionKey, true) == true
      );
    }

    function currentRolePermAllows(moduleKey, actionKey) {
      return isSignedIn() && !isBlockedUser() && userDocExists() &&
        rolePermAllows(currentRole(), moduleKey, actionKey);
    }

    /* ============================================================
       TINTIN — PEDIDOS / PERFIL
       ============================================================ */

    function isOwnOrderByUidOrEmail() {
      return isSignedIn() && !isBlockedUser() && (
        resource.data.userId == request.auth.uid ||
        (
          resource.data.userEmail is string &&
          request.auth.token.email != null &&
          resource.data.userEmail.lower() == request.auth.token.email.lower()
        )
      );
    }

    function orderStatsOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'purchaseCount', 'orderCount', 'totalOrders', 'totalSpent',
        'completedOrders', 'pendingOrders', 'cancelledOrders',
        'lastOrderAt', 'lastOrderId', 'lastPurchaseAt', 'lastPurchaseOrderId',
        'profileStatsUpdatedAt', 'orderStats', 'updatedAt'
      ]);
    }

    function orderStatsNonNegative() {
      return
        (!('purchaseCount' in request.resource.data) || request.resource.data.purchaseCount >= 0) &&
        (!('orderCount' in request.resource.data) || request.resource.data.orderCount >= 0) &&
        (!('totalOrders' in request.resource.data) || request.resource.data.totalOrders >= 0) &&
        (!('totalSpent' in request.resource.data) || request.resource.data.totalSpent >= 0) &&
        (!('completedOrders' in request.resource.data) || request.resource.data.completedOrders >= 0) &&
        (!('pendingOrders' in request.resource.data) || request.resource.data.pendingOrders >= 0) &&
        (!('cancelledOrders' in request.resource.data) || request.resource.data.cancelledOrders >= 0);
    }
    // NOTA: settings/general público para lectura (checkout/envios necesitan
    // costos/ciudades de envío) ya está resuelto más abajo, con la distinción
    // admin/superadmin más reciente — ver "SETTINGS — SOLO SUPER ADMIN EDITA".

    function protectedUserFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role', 'blocked', 'blockedAt', 'blockedBy', 'blockReason', 'roleBeforeBlock',
        'purchaseCount', 'orderCount', 'totalOrders', 'totalSpent',
        'completedOrders', 'pendingOrders', 'cancelledOrders',
        'lastOrderAt', 'lastOrderId', 'lastPurchaseAt', 'lastPurchaseOrderId',
        'profileStatsUpdatedAt', 'orderStats'
      ]);
    }

    /* ============================================================
       SETTINGS — SOLO SUPER ADMIN EDITA
       ============================================================ */

    match /settings/general {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /settings/images {
      allow read: if isStoreOpenOrAllowed();
      allow write: if isSuperAdmin();
    }

    match /settings/welcomeTutorial {
      allow read: if isSignedIn() && isStoreOpenOrAllowed();
      allow write: if isSuperAdmin();
    }

    match /settings/{doc} {
      allow read, write: if isSuperAdmin();
    }

    /* ============================================================
       USERS — ROLES/BLOQUEOS SOLO SUPER ADMIN
       ============================================================ */

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());

      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        isStoreOpenOrAllowed() &&
        (
          !('email' in request.resource.data) ||
          (
            request.resource.data.email is string &&
            request.auth.token.email != null &&
            request.resource.data.email.lower() == request.auth.token.email.lower()
          )
        ) &&
        (
          !('blocked' in request.resource.data) ||
          request.resource.data.blocked == false ||
          isSuperAdmin()
        ) &&
        (
          !('role' in request.resource.data) ||
          request.resource.data.role == 'client' ||
          (
            request.resource.data.role == 'superadmin' &&
            request.auth.token.email == "tintinaccs@gmail.com"
          )
        );

      allow update: if isSignedIn() && (
        (
          request.auth.uid == userId &&
          !isBlockedUser() &&
          isStoreOpenOrAllowed() &&
          !protectedUserFieldsChanged()
        ) ||
        (
          isStoreOpenOrAllowed() &&
          hasRole("admin") &&
          orderStatsOnlyUpdate() &&
          orderStatsNonNegative()
        ) ||
        (
          isSuperAdmin() &&
          (
            request.auth.token.email == "tintinaccs@gmail.com" ||
            !isSuperAdminAccount(resource.data)
          ) &&
          (
            !('role' in request.resource.data) ||
            request.resource.data.role != 'superadmin' ||
            request.auth.token.email == "tintinaccs@gmail.com"
          )
        )
      );

      allow delete: if isSuperAdmin() && !isSuperAdminAccount(resource.data);

      match /cart/{itemId} {
        allow read, write: if isSignedIn() &&
          !isBlockedUser() &&
          request.auth.uid == userId &&
          isStoreOpenOrAllowed();
      }
    }

    /* ============================================================
       PRODUCTS / COLLECTIONS / CONTENT
       ============================================================ */

    // currentRolePermAllows() por sí sola NO alcanza como gate: si
    // rolePermissions/main no existe, o si el rol/acción todavía no se tocó
    // ahí, rolePermAllows() permite por defecto (a propósito — ver esa
    // función) para cualquier ROL, incluido "client". Por eso cada uso de
    // currentRolePermAllows() de acá abajo va SIEMPRE atrás de un
    // isAdmin()/isAgent()/isViewer() explícito que ya limita a cuentas de
    // staff reales — sin ese filtro, cualquier clienta logueada podía crear/
    // editar productos, colecciones y contenido, y leer TODOS los pedidos
    // ajenos con solo tener sesión iniciada.
    // Catálogo público: cualquiera puede LEER productos y colecciones —
    // visitante anónimo, cliente logueado o incluso una cuenta bloqueada —
    // sin importar storeOpen/maintenanceAccess (eso solo debe frenar
    // checkout/pedidos, nunca la posibilidad de ver la vidriera). Escribir
    // sigue exigiendo Super Admin o un rol de staff con el permiso puntual
    // habilitado, exactamente como antes.
    match /products/{productId} {
      allow read: if true;
      allow create: if isSuperAdmin() ||
        (isStoreOpenOrAllowed() && (isAdmin() || isAgent() || isViewer()) && currentRolePermAllows('productos', 'crear'));
      allow update: if isSuperAdmin() ||
        (isStoreOpenOrAllowed() && (isAdmin() || isAgent()) && currentRolePermAllows('productos', 'editar'));
      allow delete: if isSuperAdmin();
    }

    match /collections/{collectionId} {
      allow read: if true;
      allow create: if isSuperAdmin() ||
        (isStoreOpenOrAllowed() && (isAdmin() || isAgent()) && currentRolePermAllows('colecciones', 'crear'));
      allow update: if isSuperAdmin() ||
        (isStoreOpenOrAllowed() && (isAdmin() || isAgent()) && currentRolePermAllows('colecciones', 'editar'));
      allow delete: if isSuperAdmin();
    }

    // El panel (admin.html) nunca llama a currentRolePermAllows('contenido',
    // 'crear'/'editar') — esas claves no existen en el catálogo de
    // js/role-permissions.js. Las claves reales son 'editarTextos' y
    // 'activarDesactivarSecciones'; con las claves viejas, rolePermAllows()
    // nunca encontraba nada configurado y quedaba abierto para cualquier
    // cuenta logueada, sin forma de cerrarlo desde Roles y Permisos.
    match /site_content/{pageId} {
      allow read: if isStoreOpenOrAllowed();
      allow create: if isSuperAdmin() ||
        (isStoreOpenOrAllowed() && (isAdmin() || isAgent()) &&
          (currentRolePermAllows('contenido', 'editarTextos') || currentRolePermAllows('contenido', 'activarDesactivarSecciones')));
      allow update: if isSuperAdmin() ||
        (isStoreOpenOrAllowed() && (isAdmin() || isAgent()) &&
          (currentRolePermAllows('contenido', 'editarTextos') || currentRolePermAllows('contenido', 'activarDesactivarSecciones')));
      allow delete: if isSuperAdmin();
    }

    /* ============================================================
       ORDERS
       ============================================================ */

    match /orders/{orderId} {
      allow create: if isStoreOpenOrAllowed() &&
        isSignedIn() &&
        !isBlockedUser() &&
        request.auth.token.email != null &&
        request.auth.token.email_verified == true &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.userEmail is string &&
        request.resource.data.userEmail.lower() == request.auth.token.email.lower();

      allow read: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (
            ((isAdmin() || isAgent() || isViewer()) && currentRolePermAllows('pedidos', 'ver')) ||
            isOwnOrderByUidOrEmail()
          )
        );

      // Edición completa y eliminación quedan SOLO para Super Admin.
      // Otros roles pueden tener acciones puntuales si Super Admin las habilita.
      allow update: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (
            (
              (hasRole("admin") || hasRole("agent")) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status', 'payment', 'paymentStatus', 'resendCount',
                'lastResendAt', 'notificationStatus', 'updatedAt'
              ]) &&
              (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']) || currentRolePermAllows('pedidos', 'cambiarEstado')) &&
              (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['payment', 'paymentStatus']) || currentRolePermAllows('pedidos', 'cambiarPago')) &&
              (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['resendCount', 'lastResendAt', 'notificationStatus']) || currentRolePermAllows('pedidos', 'reenviarCorreo'))
            ) ||
            (
              isOwnOrderByUidOrEmail() &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notificationStatus', 'updatedAt'])
            )
          )
        );

      allow delete: if isSuperAdmin();
    }

    /* ============================================================
       AUDIT / PERMISSIONS
       ============================================================ */

    match /auditLog/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin() ||
        (isStoreOpenOrAllowed() && (hasRole("admin") || hasRole("agent")));
      allow update, delete: if false;
    }

    match /rolePermissions/{docId} {
      allow read: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (hasRole("admin") || hasRole("agent") || hasRole("viewer") || hasRole("moderator") || hasRole("support"))
        );
      allow write: if isSuperAdmin();
    }

    /* ============================================================
       EMAIL MODULE — CONFIGURACIÓN SOLO SUPER ADMIN
       ============================================================ */

    match /emailSettings/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /emailTemplates/{templateId} {
      allow read, write: if isSuperAdmin();
    }

    match /emailLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (
            ((hasRole("admin") || hasRole("agent")) && currentRolePermAllows('pedidos', 'reenviarCorreo')) ||
            (
              isSignedIn() &&
              !isBlockedUser() &&
              request.resource.data.category == 'pedido' &&
              request.resource.data.type == 'pedido_nuevo' &&
              request.resource.data.orderId is string &&
              request.resource.data.sentBy == request.auth.token.email &&
              get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId == request.auth.uid
            )
          )
        );
      allow update, delete: if false;
    }

    match /emailCampaigns/{campaignId} {
      allow read, create, update: if isSuperAdmin();
      allow delete: if false;
    }

    /* ============================================================
       DEFAULT DENY
       ============================================================ */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
