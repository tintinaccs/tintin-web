rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "tintinaccs@gmail.com" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "superadmin"]
        )
      );
    }

    // IMPORTANTE:
    // La web pública necesita leer estas imágenes para mostrar hero, categorías, editoriales, etc.
    match /settings/images {
      allow read: if true;
      allow write: if isAdmin();
    }

    // La web pública (checkout, envios.html) necesita leer costos/ciudades de envío,
    // nombre de tienda, redes, métodos de pago, etc.
    match /settings/general {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Otros documentos de settings quedan protegidos
    match /settings/{doc} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      // El dueño puede leer/crear su doc; el admin puede leer/listar cualquiera
      // (pestaña Usuarios, Dashboard, Onboarding en Super Admin).
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Al crear su propio doc (signup), el rol solo puede ser "client", o
      // "superadmin" si es el email dueño de la tienda — igual que hace login.html.
      // Evita que alguien se cree el doc con role:"admin" a mano.
      allow create: if isSignedIn() && request.auth.uid == userId && (
        !('role' in request.resource.data) ||
        request.resource.data.role == 'client' ||
        (request.resource.data.role == 'superadmin' && request.auth.token.email == "tintinaccs@gmail.com")
      );
      // El dueño puede actualizar su propio doc pero NO puede tocar su propio
      // campo "role" (evita que se auto-asigne admin/superadmin). El admin sí puede.
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == userId &&
        request.resource.data.role == resource.data.role
      );
      allow delete: if isAdmin();

      // Carrito sincronizado del usuario (js/cart-sync.js)
      match /cart/{itemId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Colecciones — panel Super Admin → Colecciones, y catálogo/home/menú públicos
    match /collections/{collectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Textos editables del Hero/Home/Nosotros/Catálogo (Super Admin → Contenido)
    match /site_content/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
