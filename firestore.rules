rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "tintinaccs@gmail.com";
    }

    function isBlockedUser() {
      return isSignedIn() &&
        request.auth.token.email != "tintinaccs@gmail.com" &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.blocked == true;
    }

    function isAdmin() {
      return isSignedIn() && !isBlockedUser() && (
        request.auth.token.email == "tintinaccs@gmail.com" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        )
      );
    }

    function isAgent() {
      return isSignedIn() && !isBlockedUser() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "agent";
    }

    function isViewer() {
      return isSignedIn() && !isBlockedUser() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "viewer";
    }

    // Estado global de tienda. Si el documento todavía no existe, abre por
    // compatibilidad. Si storeOpen=false, solo Super Admin conserva acceso.
    function isStoreOpen() {
      return isSuperAdmin() ||
        !exists(/databases/$(database)/documents/settings/general) ||
        get(/databases/$(database)/documents/settings/general).data.storeOpen != false;
    }

    function isSuperAdminAccount(data) {
      return data.email == "tintinaccs@gmail.com";
    }

    function rolePermAllows(role, moduleKey, actionKey) {
      return !exists(/databases/$(database)/documents/rolePermissions/main) || (
        get(/databases/$(database)/documents/rolePermissions/main).data
          .get(role, {}).get(moduleKey, {}).get(actionKey, true) == true
      );
    }

    match /settings/images {
      allow read: if isStoreOpen();
      allow write: if isAdmin();
    }

    // Se lee incluso con tienda cerrada porque el Store Gate necesita saber si
    // debe bloquear y qué mensaje mostrar. No guarda secretos.
    match /settings/general {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /settings/{doc} {
      allow read, write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());

      allow create: if isSignedIn() && request.auth.uid == userId &&
        (
          !('role' in request.resource.data) ||
          request.resource.data.role == 'client' ||
          isSuperAdmin()
        ) &&
        (
          !('role' in request.resource.data) ||
          request.resource.data.role != 'superadmin' ||
          request.auth.token.email == "tintinaccs@gmail.com"
        );

      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !isBlockedUser() && isStoreOpen() &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'blocked'])) ||
        (
          isSuperAdmin() &&
          (request.auth.token.email == "tintinaccs@gmail.com" || !isSuperAdminAccount(resource.data)) &&
          (
            !('role' in request.resource.data) ||
            request.resource.data.role != 'superadmin' ||
            request.auth.token.email == "tintinaccs@gmail.com"
          )
        )
      );

      allow delete: if isSuperAdmin() && !isSuperAdminAccount(resource.data);

      match /cart/{itemId} {
        allow read, write: if isSignedIn() && !isBlockedUser() && request.auth.uid == userId && isStoreOpen();
      }
    }

    match /products/{productId} {
      allow read: if isStoreOpen();
      allow create, update: if isStoreOpen() && (isAdmin() || isAgent());
      allow delete: if isSuperAdmin() || (isStoreOpen() && isAdmin() && rolePermAllows('admin', 'productos', 'eliminar'));
    }

    match /collections/{collectionId} {
      allow read: if isStoreOpen();
      allow create, update: if isStoreOpen() && (isAdmin() || isAgent());
      allow delete: if isSuperAdmin() || (isStoreOpen() && isAdmin() && rolePermAllows('admin', 'colecciones', 'eliminar'));
    }

    match /site_content/{pageId} {
      allow read: if isStoreOpen();
      allow create, update: if isStoreOpen() && (isAdmin() || isAgent());
      allow delete: if isSuperAdmin() || (isStoreOpen() && isAdmin());
    }

    match /orders/{orderId} {
      allow create: if isStoreOpen() && isSignedIn() && !isBlockedUser() &&
        request.auth.token.email != null &&
        request.auth.token.email_verified == true &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.userEmail is string &&
        request.resource.data.userEmail.lower() == request.auth.token.email.lower();

      allow read: if isSuperAdmin() || (isStoreOpen() && (
        isAdmin() || isAgent() ||
        (isSignedIn() && !isBlockedUser() && resource.data.userId == request.auth.uid)
      ));

      allow update: if isSuperAdmin() || (isStoreOpen() && (
        (isAdmin() && rolePermAllows('admin', 'pedidos', 'editarCompleto')) ||
        (
          isAgent() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['status', 'payment', 'paymentStatus', 'resendCount', 'lastResendAt', 'notificationStatus', 'updatedAt']
          ) &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']) || rolePermAllows('agent', 'pedidos', 'cambiarEstado')) &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['payment', 'paymentStatus']) || rolePermAllows('agent', 'pedidos', 'cambiarPago')) &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['resendCount', 'lastResendAt', 'notificationStatus']) || rolePermAllows('agent', 'pedidos', 'reenviarCorreo'))
        ) ||
        (
          isSignedIn() && !isBlockedUser() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notificationStatus', 'updatedAt'])
        )
      ));

      allow delete: if isSuperAdmin() || (isStoreOpen() && isAdmin() && rolePermAllows('admin', 'pedidos', 'eliminar'));
    }

    match /auditLog/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin() || (isStoreOpen() && (isAdmin() || isAgent()));
      allow update, delete: if false;
    }

    match /rolePermissions/{docId} {
      allow read: if isSuperAdmin() || (isStoreOpen() && (isAdmin() || isAgent() || isViewer()));
      allow write: if isSuperAdmin();
    }

    match /emailSettings/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /emailTemplates/{templateId} {
      allow read, write: if isSuperAdmin();
    }

    match /emailLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin() || (isStoreOpen() && (
        isAdmin() || isAgent() ||
        (
          isSignedIn() && !isBlockedUser() &&
          request.resource.data.category == 'pedido' &&
          request.resource.data.type == 'pedido_nuevo' &&
          request.resource.data.orderId is string &&
          request.resource.data.sentBy == request.auth.token.email &&
          get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId == request.auth.uid
        )
      ));
      allow update, delete: if false;
    }

    match /emailCampaigns/{campaignId} {
      allow read, create, update: if isSuperAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
