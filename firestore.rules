rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      // Hardcoded owner account — always has full access, no Firestore round-trip
      return isSignedIn() && request.auth.token.email == 'tintinaccs@gmail.com';
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isStaff() {
      // superadmin / admin / agent can manage the store; viewer is read-only staff
      return isSuperAdmin() ||
        (isSignedIn() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         userDoc().data.role in ['superadmin', 'admin', 'agent']);
    }

    function isAdmin() {
      // Full write access (products, collections, settings, content, orders, roles)
      return isSuperAdmin() ||
        (isSignedIn() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         userDoc().data.role in ['superadmin', 'admin']);
    }

    // ---- Public storefront data: readable by anyone, writable only by staff ----
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /collections/{collectionId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site_content/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Orders: guest checkout can create, only the owner or staff can read/manage ----
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isStaff() ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    // ---- Users: each user manages their own profile/cart; admins manage roles ----
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Only admins may change `role` on someone else's doc; users may edit their own non-role fields
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      match /cart/{itemId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
