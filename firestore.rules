rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "tintinaccs@gmail.com" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "superadmin"]
        )
      );
    }

    // IMPORTANTE:
    // La web pública necesita leer estas imágenes para mostrar hero, categorías, editoriales, etc.
    match /settings/images {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Otros documentos de settings quedan protegidos
    match /settings/{doc} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read, create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;

      // Carrito sincronizado del usuario (js/cart-sync.js)
      match /cart/{itemId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Colecciones — panel Super Admin → Colecciones, y catálogo/home/menú públicos
    match /collections/{collectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Textos editables del Hero/Home/Nosotros/Catálogo (Super Admin → Contenido)
    match /site_content/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
