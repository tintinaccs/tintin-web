rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ============================================================
       TINTIN — HELPERS BASE
       ============================================================ */

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        request.auth.token.email == "tintinaccs@gmail.com";
    }

    function userDocExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return userDocExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : "client";
    }

    function hasRole(role) {
      return isSignedIn() &&
        !isBlockedUser() &&
        userDocExists() &&
        currentRole() == role;
    }

    function isBlockedUser() {
      return isSignedIn() &&
        request.auth.token.email != "tintinaccs@gmail.com" &&
        userDocExists() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.blocked == true;
    }

    function isAdmin() {
      return isSignedIn() && !isBlockedUser() && (
        isSuperAdmin() || hasRole("admin")
      );
    }

    function isAgent() {
      return hasRole("agent");
    }

    function isViewer() {
      return hasRole("viewer");
    }

    function isSuperAdminAccount(data) {
      return data.email == "tintinaccs@gmail.com";
    }

    /* ============================================================
       TINTIN — TIENDA ACTIVA / CERRADA
       ============================================================ */

    function isStoreOpenOrAllowed() {
      // Si settings/storeGate todavía no existe (recién desplegado el
      // cierre y el Super Admin todavía no guardó Configuración una vez
      // para crear el documento), no hay nada que evaluar todavía: se
      // permite el acceso normal en vez de bloquear el sitio entero por un
      // documento que nunca llegó a crearse. Apenas el documento existe,
      // manda por completo su storeOpen/maintenanceAccess como antes.
      return isSuperAdmin() ||
        (
          !isBlockedUser() &&
          (
            !exists(/databases/$(database)/documents/settings/storeGate) ||
            get(/databases/$(database)/documents/settings/storeGate).data.storeOpen == true ||
            (
              get(/databases/$(database)/documents/settings/storeGate).data.maintenanceAccess is map &&
              get(/databases/$(database)/documents/settings/storeGate).data.maintenanceAccess
                .get(isSignedIn() ? currentRole() : 'guest', false) == true
            )
          )
        );
    }

    /* ============================================================
       TINTIN — ROLES Y PERMISOS DINÁMICOS
       ============================================================ */

    /* Actividad anónima: puede guardar ciudad/región/país aproximados, pero
       nunca IP, GPS, coordenadas, código postal, navegador, nombre ni correo.
       Solo Super Admin puede leer las sesiones y la presencia. */
    function activityUserIdIsValid(data) {
      return data.userId is string &&
        data.userId.size() <= 128 &&
        (
          data.userId == '' ||
          (isSignedIn() && data.userId == request.auth.uid)
        );
    }

    function activityGeoIsValid(data) {
      return data.get('city', '') is string && data.get('city', '').size() <= 80 &&
        data.get('region', '') is string && data.get('region', '').size() <= 80 &&
        data.get('country', '') is string && data.get('country', '').size() <= 80 &&
        data.get('countryCode', '') is string &&
        data.get('countryCode', '').matches('^$|^[A-Z]{2}$') &&
        data.get('geoSource', '') is string &&
        data.get('geoSource', '').matches('^$|^netlify$|^unavailable$');
    }

    function presenceIsValid(visitorId) {
      let data = request.resource.data;
      return data.keys().hasAll([
          'visitorId', 'sessionId', 'userId', 'page', 'lastSeen'
        ]) &&
        data.keys().hasOnly([
          'visitorId', 'sessionId', 'userId', 'page', 'lastSeen',
          'city', 'region', 'country', 'countryCode', 'geoSource'
        ]) &&
        data.visitorId == visitorId &&
        data.visitorId is string && data.visitorId.size() >= 8 && data.visitorId.size() <= 80 &&
        data.sessionId is string && data.sessionId.size() >= 8 && data.sessionId.size() <= 80 &&
        activityUserIdIsValid(data) &&
        activityGeoIsValid(data) &&
        data.page is string && data.page.size() >= 1 && data.page.size() <= 160 &&
        data.lastSeen == request.time;
    }

    function trafficSessionIsValid(dateKey, sessionId) {
      let data = request.resource.data;
      return data.keys().hasAll([
          'dayKey', 'sessionId', 'visitorId', 'userId', 'landingPage', 'startedAt'
        ]) &&
        data.keys().hasOnly([
          'dayKey', 'sessionId', 'visitorId', 'userId', 'landingPage', 'startedAt',
          'city', 'region', 'country', 'countryCode', 'geoSource'
        ]) &&
        data.dayKey == dateKey &&
        data.dayKey is string && data.dayKey.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
        data.sessionId == sessionId &&
        data.sessionId is string && data.sessionId.size() >= 8 && data.sessionId.size() <= 80 &&
        data.visitorId is string && data.visitorId.size() >= 8 && data.visitorId.size() <= 80 &&
        activityUserIdIsValid(data) &&
        activityGeoIsValid(data) &&
        data.landingPage is string && data.landingPage.size() >= 1 && data.landingPage.size() <= 160 &&
        data.startedAt == request.time;
    }

    match /sitePresence/{visitorId} {
      allow read, delete: if isSuperAdmin();
      allow create, update: if isStoreOpenOrAllowed() && presenceIsValid(visitorId);
    }

    match /siteTraffic/{dateKey}/sessions/{sessionId} {
      allow read, delete: if isSuperAdmin();
      allow create: if isStoreOpenOrAllowed() && trafficSessionIsValid(dateKey, sessionId);
      allow update: if false;
    }

    function rolePermAllows(role, moduleKey, actionKey) {
      return exists(/databases/$(database)/documents/rolePermissions/main) &&
        get(/databases/$(database)/documents/rolePermissions/main).data
          .get(role, {}).get(moduleKey, {}).get(actionKey, false) == true;
    }

    function currentRolePermAllows(moduleKey, actionKey) {
      return isSignedIn() &&
        !isBlockedUser() &&
        userDocExists() &&
        rolePermAllows(currentRole(), moduleKey, actionKey);
    }

    /* ============================================================
       TINTIN — PEDIDOS / PERFIL
       ============================================================ */

    function isOwnOrderByUidOrEmail() {
      return isSignedIn() && !isBlockedUser() && (
        resource.data.userId == request.auth.uid ||
        (
          resource.data.userEmail is string &&
          request.auth.token.email != null &&
          resource.data.userEmail.lower() == request.auth.token.email.lower()
        )
      );
    }

    function orderStatsOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'purchaseCount', 'orderCount', 'totalOrders', 'totalSpent',
        'completedOrders', 'pendingOrders', 'cancelledOrders',
        'lastOrderAt', 'lastOrderId', 'lastPurchaseAt', 'lastPurchaseOrderId',
        'profileStatsUpdatedAt', 'orderStats', 'updatedAt'
      ]);
    }

    function orderStatsNonNegative() {
      return
        (!('purchaseCount' in request.resource.data) || request.resource.data.purchaseCount >= 0) &&
        (!('orderCount' in request.resource.data) || request.resource.data.orderCount >= 0) &&
        (!('totalOrders' in request.resource.data) || request.resource.data.totalOrders >= 0) &&
        (!('totalSpent' in request.resource.data) || request.resource.data.totalSpent >= 0) &&
        (!('completedOrders' in request.resource.data) || request.resource.data.completedOrders >= 0) &&
        (!('pendingOrders' in request.resource.data) || request.resource.data.pendingOrders >= 0) &&
        (!('cancelledOrders' in request.resource.data) || request.resource.data.cancelledOrders >= 0);
    }

    function loginMetadataOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'lastLogin', 'updatedAt'
      ]);
    }

    function protectedUserFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'email', 'createdAt', 'provider', 'role', 'blocked', 'blockedAt', 'blockedBy', 'blockReason',
        'roleBeforeBlock', 'purchaseCount', 'orderCount', 'totalOrders',
        'totalSpent', 'completedOrders', 'pendingOrders', 'cancelledOrders',
        'lastOrderAt', 'lastOrderId', 'lastPurchaseAt', 'lastPurchaseOrderId',
        'profileStatsUpdatedAt', 'orderStats'
      ]);
    }

    function userCreateValid(userId) {
      let data = request.resource.data;
      return isSignedIn() &&
        request.auth.uid == userId &&
        request.auth.token.email != null &&
        data.keys().hasOnly([
          'name', 'email', 'phone', 'photoURL', 'role', 'provider',
          'onboardingCompleted', 'welcomeTutorialSeen',
          'welcomeTutorialPending', 'welcomeTutorialVersion', 'blocked',
          'purchaseCount', 'totalSpent', 'orderCount', 'totalOrders',
          'completedOrders', 'pendingOrders', 'cancelledOrders',
          'createdAt', 'updatedAt', 'lastLogin'
        ]) &&
        data.email is string &&
        data.email.lower() == request.auth.token.email.lower() &&
        data.get('blocked', false) == false &&
        (
          (request.auth.token.email == "tintinaccs@gmail.com" && data.get('role', 'superadmin') == 'superadmin') ||
          (request.auth.token.email != "tintinaccs@gmail.com" && data.get('role', 'client') == 'client')
        ) &&
        data.get('purchaseCount', 0) == 0 &&
        data.get('totalSpent', 0) == 0 &&
        data.get('orderCount', 0) == 0 &&
        data.get('totalOrders', 0) == 0 &&
        data.get('completedOrders', 0) == 0 &&
        data.get('pendingOrders', 0) == 0 &&
        data.get('cancelledOrders', 0) == 0 &&
        (!('createdAt' in data) || data.createdAt == request.time) &&
        (!('updatedAt' in data) || data.updatedAt == request.time) &&
        (!('lastLogin' in data) || data.lastLogin == request.time);
    }

    function cartItemValid(itemId) {
      let data = request.resource.data;
      let productPath = /databases/$(database)/documents/products/$(data.id);
      return data.keys().hasAll([
          'schemaVersion', 'lineId', 'id', 'variant', 'qty',
          'name', 'cat', 'price', 'imageUrl', 'updatedAt', 'updatedByDevice'
        ]) &&
        data.keys().hasOnly([
          'schemaVersion', 'lineId', 'id', 'variant', 'qty',
          'name', 'cat', 'price', 'imageUrl', 'updatedAt', 'updatedByDevice'
        ]) &&
        data.schemaVersion == 2 &&
        data.lineId == itemId &&
        data.id is string && data.id.size() >= 1 && data.id.size() <= 180 &&
        data.variant is string && data.variant.size() <= 120 &&
        data.qty is int && data.qty >= 1 && data.qty <= 99 &&
        data.name is string && data.name.size() <= 180 &&
        data.cat is string && data.cat.size() <= 120 &&
        data.price is number && data.price >= 0 &&
        data.imageUrl is string && data.imageUrl.size() <= 1200 &&
        data.updatedAt == request.time &&
        data.updatedByDevice is string && data.updatedByDevice.size() >= 8 && data.updatedByDevice.size() <= 180 &&
        exists(productPath) &&
        get(productPath).data.get('active', true) != false &&
        (
          !('stock' in get(productPath).data) ||
          get(productPath).data.stock == null ||
          (
            get(productPath).data.stock is number &&
            data.qty <= get(productPath).data.stock
          )
        );
    }

    /* ============================================================
       TINTIN — PEDIDOS SIN BLAZE (SPARK)

       Máximo 4 productos diferentes por pedido para permanecer dentro de los
       límites de lecturas de reglas. Precio y stock se validan contra products.
       ============================================================ */

    function sparkProductPath(productId) {
      return /databases/$(database)/documents/products/$(productId);
    }

    function sparkOrderPath(orderId) {
      return /databases/$(database)/documents/orders/$(orderId);
    }

    function sparkItemValid(item, orderId) {
      let productId = item.id;
      let product = get(sparkProductPath(productId)).data;
      return item is map &&
        item.keys().hasOnly([
          'id', 'name', 'cat', 'price', 'qty', 'variant', 'imageUrl'
        ]) &&
        item.id is string && item.id.size() > 0 && item.id.size() <= 180 &&
        item.name is string && item.name.size() > 0 && item.name.size() <= 180 &&
        item.cat is string && item.cat.size() <= 120 &&
        item.price is number && item.price >= 0 &&
        item.qty is int && item.qty >= 1 && item.qty <= 99 &&
        item.variant is string && item.variant.size() <= 120 &&
        item.imageUrl is string && item.imageUrl.size() <= 900 &&
        product.get('active', true) != false &&
        product.price == item.price &&
        item.name == product.get('name', product.get('title', product.get('Title', 'Producto'))) &&
        (
          !('stock' in product) ||
          product.stock == null ||
          (
            product.stock is number &&
            product.stock >= item.qty &&
            getAfter(sparkProductPath(productId)).data.stock == product.stock - item.qty &&
            getAfter(sparkProductPath(productId)).data.lastStockOrderId == orderId
          )
        );
    }

    function sparkItemAtValid(items, index, orderId) {
      return items.size() <= index || sparkItemValid(items[index], orderId);
    }

    function sparkLineTotal(items, index) {
      return items.size() > index
        ? items[index].price * items[index].qty
        : 0;
    }

    function sparkItemsUnique(items) {
      return
        (items.size() < 2 || items[0].id != items[1].id) &&
        (items.size() < 3 || (items[0].id != items[2].id && items[1].id != items[2].id)) &&
        (items.size() < 4 || (
          items[0].id != items[3].id &&
          items[1].id != items[3].id &&
          items[2].id != items[3].id
        ));
    }

    function sparkRateValueValid(entry, fallback, city, cost, pending) {
      return
        (
          entry is string &&
          city == entry &&
          fallback is number &&
          cost == fallback &&
          pending == false
        ) ||
        (
          entry is map &&
          city == entry.get('name', '') &&
          (
            (
              entry.get('price', fallback) == null &&
              cost == 0 &&
              pending == true
            ) ||
            (
              entry.get('price', fallback) is number &&
              cost == entry.get('price', fallback) &&
              pending == false
            )
          )
        );
    }

    function sparkDeliveryValid(data, settings) {
      let shipping = data.shipping;
      let index = shipping.rateIndex;
      return settings.get('deliveryCities', []) is list &&
        index is int && index >= 0 && index < settings.get('deliveryCities', []).size() &&
        sparkRateValueValid(
          settings.get('deliveryCities', [])[index],
          settings.get('deliveryCost', 0),
          shipping.city,
          data.shippingCost,
          data.shippingPending
        ) &&
        shipping.mapLocation is map &&
        shipping.mapLocation.keys().hasOnly(['lat', 'lng', 'name', 'address']) &&
        shipping.mapLocation.lat is number &&
        shipping.mapLocation.lat >= -90 && shipping.mapLocation.lat <= 90 &&
        shipping.mapLocation.lng is number &&
        shipping.mapLocation.lng >= -180 && shipping.mapLocation.lng <= 180 &&
        shipping.mapLocation.name is string && shipping.mapLocation.name.size() > 0;
    }

    function sparkEncomiendaValid(data, settings) {
      let shipping = data.shipping;
      let index = shipping.rateIndex;
      return settings.get('encomiendaCities', []) is list &&
        index is int && index >= 0 && index < settings.get('encomiendaCities', []).size() &&
        sparkRateValueValid(
          settings.get('encomiendaCities', [])[index],
          settings.get('encomiendaCost', 0),
          shipping.city,
          data.shippingCost,
          data.shippingPending
        ) &&
        shipping.address is string && shipping.address.size() >= 5 &&
        shipping.mapLocation == null;
    }

    function sparkShippingValid(data, settings) {
      let shipping = data.shipping;
      return shipping is map &&
        shipping.keys().hasOnly([
          'method', 'city', 'rateIndex', 'address', 'referencia',
          'zone', 'mapLocation'
        ]) &&
        shipping.method is string &&
        shipping.city is string && shipping.city.size() > 0 && shipping.city.size() <= 120 &&
        shipping.address is string && shipping.address.size() <= 300 &&
        shipping.referencia is string && shipping.referencia.size() <= 300 &&
        shipping.zone is string &&
        (
          (
            shipping.method == 'retiro' &&
            shipping.city == 'San Lorenzo (retiro)' &&
            shipping.rateIndex == -1 &&
            shipping.zone == 'central' &&
            shipping.mapLocation == null &&
            data.shippingCost == 0 &&
            data.shippingPending == false
          ) ||
          (
            shipping.method == 'delivery' &&
            shipping.zone == 'central' &&
            sparkDeliveryValid(data, settings)
          ) ||
          (
            shipping.method == 'encomienda' &&
            shipping.zone == 'interior' &&
            sparkEncomiendaValid(data, settings)
          )
        );
    }

    function sparkOrderCreateValid(orderId) {
      let data = request.resource.data;
      let settings = get(/databases/$(database)/documents/settings/general).data;
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let items = data.items;
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email_verified == true &&
        (
          isSuperAdmin() ||
          (
            settings.get('storeOpen', false) == true &&
            userData.get('blocked', false) != true
          )
        ) &&
        orderId == request.auth.uid + '_' + data.requestId &&
        data.keys().hasOnly([
          'requestId', 'source', 'shortId', 'userId', 'userEmail',
          'contactEmail', 'userName', 'userPhone', 'items', 'subtotal',
          'shippingCost', 'shippingPending', 'total', 'storeWhatsapp',
          'storeInstagram', 'shipping', 'payment', 'paymentStatus',
          'status', 'notes', 'notificationStatus', 'createdAt', 'updatedAt'
        ]) &&
        data.requestId is string && data.requestId.size() >= 12 && data.requestId.size() <= 100 &&
        data.source == 'spark-checkout-v1' &&
        data.shortId is string && data.shortId.size() > 0 && data.shortId.size() <= 20 &&
        data.userId == request.auth.uid &&
        data.userEmail is string &&
        data.userEmail.lower() == request.auth.token.email.lower() &&
        data.contactEmail is string && data.contactEmail.size() <= 254 &&
        data.userName is string && data.userName.size() >= 2 && data.userName.size() <= 120 &&
        data.userPhone is string && data.userPhone.size() >= 7 && data.userPhone.size() <= 40 &&
        items is list && items.size() >= 1 && items.size() <= 4 &&
        sparkItemsUnique(items) &&
        sparkItemAtValid(items, 0, orderId) &&
        sparkItemAtValid(items, 1, orderId) &&
        sparkItemAtValid(items, 2, orderId) &&
        sparkItemAtValid(items, 3, orderId) &&
        data.subtotal is number && data.subtotal >= 0 &&
        data.subtotal ==
          sparkLineTotal(items, 0) +
          sparkLineTotal(items, 1) +
          sparkLineTotal(items, 2) +
          sparkLineTotal(items, 3) &&
        data.shippingCost is number && data.shippingCost >= 0 &&
        data.shippingPending is bool &&
        data.total is number && data.total == data.subtotal + data.shippingCost &&
        data.storeWhatsapp is string && data.storeWhatsapp.size() <= 40 &&
        data.storeInstagram is string && data.storeInstagram.size() <= 120 &&
        sparkShippingValid(data, settings) &&
        data.payment is map &&
        data.payment.keys().hasOnly(['method', 'status']) &&
        data.payment.method is string &&
        (data.payment.method == 'efectivo' || data.payment.method == 'transferencia') &&
        settings.get('paymentMethods', {}).get(data.payment.method, true) != false &&
        data.payment.status == 'pendiente' &&
        data.paymentStatus == 'pendiente' &&
        data.status == 'pendiente' &&
        data.notes is string && data.notes.size() <= 1000 &&
        data.notificationStatus == 'pending' &&
        data.createdAt == request.time &&
        data.updatedAt == request.time;
    }

    function sparkOrderItemQty(items, productId) {
      return
        (items.size() > 0 && items[0].id == productId ? items[0].qty : 0) +
        (items.size() > 1 && items[1].id == productId ? items[1].qty : 0) +
        (items.size() > 2 && items[2].id == productId ? items[2].qty : 0) +
        (items.size() > 3 && items[3].id == productId ? items[3].qty : 0);
    }

    function sparkStockUpdateValid(productId) {
      let orderId = request.resource.data.lastStockOrderId;
      let orderPath = sparkOrderPath(orderId);
      let order = getAfter(orderPath).data;
      let qty = sparkOrderItemQty(order.items, productId);
      return isSignedIn() &&
        orderId is string &&
        !exists(orderPath) &&
        existsAfter(orderPath) &&
        order.source == 'spark-checkout-v1' &&
        order.userId == request.auth.uid &&
        qty > 0 &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'stock', 'lastStockOrderId', 'updatedAt'
        ]) &&
        resource.data.stock is number &&
        request.resource.data.stock is number &&
        request.resource.data.stock == resource.data.stock - qty &&
        request.resource.data.stock >= 0 &&
        request.resource.data.updatedAt == request.time;
    }

    /* ============================================================
       SETTINGS
       ============================================================ */

    match /settings/storeGate {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /settings/general {
      allow read: if isStoreOpenOrAllowed();
      allow write: if isSuperAdmin();
    }

    match /settings/images {
      allow read: if isStoreOpenOrAllowed();
      allow write: if isSuperAdmin();
    }

    match /settings/welcomeTutorial {
      allow read: if isSignedIn() && isStoreOpenOrAllowed();
      allow write: if isSuperAdmin();
    }

    match /settings/{docId} {
      allow read, write: if isSuperAdmin();
    }

    /* ============================================================
       USERS
       ============================================================ */

    match /users/{userId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == userId || isSuperAdmin());

      allow create: if userCreateValid(userId);

      allow update: if isSignedIn() && (
        (
          request.auth.uid == userId &&
          !isBlockedUser() &&
          (
            (
              isStoreOpenOrAllowed() &&
              !protectedUserFieldsChanged()
            ) ||
            loginMetadataOnlyUpdate()
          )
        ) ||
        (
          isStoreOpenOrAllowed() &&
          hasRole("admin") &&
          orderStatsOnlyUpdate() &&
          orderStatsNonNegative()
        ) ||
        (
          isSuperAdmin() &&
          (
            request.auth.token.email == "tintinaccs@gmail.com" ||
            !isSuperAdminAccount(resource.data)
          ) &&
          (
            !('role' in request.resource.data) ||
            request.resource.data.role != 'superadmin' ||
            request.auth.token.email == "tintinaccs@gmail.com"
          )
        )
      );

      allow delete: if isSuperAdmin() &&
        !isSuperAdminAccount(resource.data);

      match /cart/{itemId} {
        allow read: if isSignedIn() &&
          !isBlockedUser() &&
          request.auth.uid == userId &&
          isStoreOpenOrAllowed();
        allow create, update: if isSignedIn() &&
          !isBlockedUser() &&
          request.auth.uid == userId &&
          isStoreOpenOrAllowed() &&
          cartItemValid(itemId);
        allow delete: if isSignedIn() &&
          !isBlockedUser() &&
          request.auth.uid == userId &&
          isStoreOpenOrAllowed();
      }
    }

    /* ============================================================
       PRODUCTS / COLLECTIONS / CONTENT
       ============================================================ */

    match /products/{productId} {
      allow read: if isStoreOpenOrAllowed();

      allow create: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (isAdmin() || isAgent() || isViewer()) &&
          currentRolePermAllows('productos', 'crear')
        );

      allow update: if isSuperAdmin() ||
        sparkStockUpdateValid(productId) ||
        (
          isStoreOpenOrAllowed() &&
          (isAdmin() || isAgent()) &&
          currentRolePermAllows('productos', 'editar')
        );

      allow delete: if isSuperAdmin();
    }

    match /collections/{collectionId} {
      allow read: if isStoreOpenOrAllowed();

      allow create: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (isAdmin() || isAgent()) &&
          currentRolePermAllows('colecciones', 'crear')
        );

      allow update: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (isAdmin() || isAgent()) &&
          currentRolePermAllows('colecciones', 'editar')
        );

      allow delete: if isSuperAdmin();
    }

    match /site_content/{pageId} {
      allow read: if isStoreOpenOrAllowed();

      allow create: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (isAdmin() || isAgent()) &&
          (
            currentRolePermAllows('contenido', 'editarTextos') ||
            currentRolePermAllows('contenido', 'activarDesactivarSecciones')
          )
        );

      allow update: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (isAdmin() || isAgent()) &&
          (
            currentRolePermAllows('contenido', 'editarTextos') ||
            currentRolePermAllows('contenido', 'activarDesactivarSecciones')
          )
        );

      allow delete: if isSuperAdmin();
    }

    /* ============================================================
       ORDERS
       ============================================================ */

    match /orders/{orderId} {
      allow create: if sparkOrderCreateValid(orderId);

      allow read: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (
            (
              (isAdmin() || isAgent() || isViewer()) &&
              currentRolePermAllows('pedidos', 'ver')
            ) ||
            isOwnOrderByUidOrEmail()
          )
        );

      allow update: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (
            (
              (hasRole("admin") || hasRole("agent")) &&
              request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly([
                  'status', 'payment', 'paymentStatus', 'resendCount',
                  'lastResendAt', 'notificationStatus', 'updatedAt'
                ]) &&
              (
                !request.resource.data.diff(resource.data)
                  .affectedKeys().hasAny(['status']) ||
                currentRolePermAllows('pedidos', 'cambiarEstado')
              ) &&
              (
                !request.resource.data.diff(resource.data)
                  .affectedKeys().hasAny(['payment', 'paymentStatus']) ||
                currentRolePermAllows('pedidos', 'cambiarPago')
              ) &&
              (
                !request.resource.data.diff(resource.data)
                  .affectedKeys().hasAny([
                    'resendCount', 'lastResendAt', 'notificationStatus'
                  ]) ||
                currentRolePermAllows('pedidos', 'reenviarCorreo')
              )
            )
          )
        );

      allow delete: if isSuperAdmin();
    }

    /* ============================================================
       AUDIT / PERMISSIONS
       ============================================================ */

    match /auditLog/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (hasRole("admin") || hasRole("agent"))
        );
      allow update, delete: if false;
    }

    match /rolePermissions/{docId} {
      allow read: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (
            hasRole("admin") ||
            hasRole("agent") ||
            hasRole("viewer") ||
            hasRole("moderator") ||
            hasRole("support")
          )
        );
      allow write: if isSuperAdmin();
    }

    /* ============================================================
       EMAIL MODULE
       ============================================================ */

    match /emailSettings/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /emailTemplates/{templateId} {
      allow read, write: if isSuperAdmin();
    }

    match /emailLogs/{logId} {
      allow read: if isSuperAdmin();

      allow create: if isSuperAdmin() ||
        (
          isStoreOpenOrAllowed() &&
          (
            (
              (hasRole("admin") || hasRole("agent")) &&
              currentRolePermAllows('pedidos', 'reenviarCorreo')
            ) ||
            (
              isSignedIn() &&
              !isBlockedUser() &&
              request.resource.data.category == 'pedido' &&
              request.resource.data.type == 'pedido_nuevo' &&
              request.resource.data.orderId is string &&
              request.resource.data.sentBy == request.auth.token.email &&
              get(
                /databases/$(database)/documents/orders/$(request.resource.data.orderId)
              ).data.userId == request.auth.uid
            )
          )
        );

      allow update, delete: if false;
    }

    match /emailCampaigns/{campaignId} {
      allow read, create, update: if isSuperAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
